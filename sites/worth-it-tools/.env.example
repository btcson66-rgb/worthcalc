# ─── Per-site configuration ──────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values for each of the 5 sites.
# Variables prefixed with PUBLIC_ are exposed to client-side code (GA4 / AdSense).

# Canonical production origin (no trailing slash). Used for canonical URLs,
# Open Graph, sitemap.xml and robots.txt.
SITE_URL=https://worthcalc.win

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX.
# Leave empty to disable analytics entirely (no gtag is injected).
PUBLIC_GA_ID=

# Google AdSense publisher ID, e.g. ca-pub-0000000000000000.
# Leave empty to render inert ad placeholders that never load AdSense.
PUBLIC_ADSENSE_CLIENT=

# Google Search Console HTML-tag verification token — the `content` value from
# the <meta name="google-site-verification" content="..."> snippet GSC gives you.
# Leave empty to omit the tag (e.g. if verifying via DNS instead).
PUBLIC_GSC_VERIFICATION=
