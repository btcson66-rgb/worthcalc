---
import { SITE } from '../consts';
import { getLocaleFromUrl, localizedCorePath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p>{t('site.tagline')}</p>
    <section aria-labelledby="footer-legal-heading">
      <h2 id="footer-legal-heading">{t('footer.legal')}</h2>
      <nav class="footer-links" aria-label={t('footer.legal')}>
        <a href={localizedCorePath(locale, '/about')}>{t('footer.about')}</a>
        <a href={localizedCorePath(locale, '/privacy')}>{t('footer.privacy')}</a>
        <a href={localizedCorePath(locale, '/terms')}>{t('footer.terms')}</a>
        <a href={localizedCorePath(locale, '/contact')}>{t('footer.contact')}</a>
        <a href={localizedCorePath(locale, '/disclaimer')}>{t('footer.disclaimer')}</a>
        <a href={localizedCorePath(locale, '/changelog')}>{t('footer.changelog')}</a>
      </nav>
    </section>
    <p class="footer-site-stats" data-site-stats="worthcalc.win" data-lang={locale} hidden data-nosnippet></p>
    <p>&copy; {year} {SITE.name}. {t('footer.rights')}</p>
  </div>
</footer>

<script is:inline>
// 累積數據為 GA4 真實快照（funnytools release 時刷新並發佈）；
// 低於門檻或抓取失敗時保持隱藏，不顯示任何估算數字。
(function () {
  var el = document.querySelector('p[data-site-stats]');
  if (!el || !('fetch' in window)) return;
  var MIN_PAGEVIEWS = 1000;
  var run = function () {
    fetch('https://funnytools.win/data/site-stats.json')
      .then(function (res) { return res.ok ? res.json() : null; })
      .then(function (data) {
        if (!data || !data.sites) return;
        var s = data.sites[el.getAttribute('data-site-stats')];
        if (!s || !(s.pageviews >= MIN_PAGEVIEWS)) return;
        var fmt = function (n) { return Number(n).toLocaleString('en-US'); };
        var lang = el.getAttribute('data-lang');
        var labels = {
          en: fmt(s.pageviews) + ' total views · ' + fmt(s.users) + ' users and counting',
          zh: '累積瀏覽 ' + fmt(s.pageviews) + ' 次 · 累積使用者 ' + fmt(s.users) + ' 位',
          es: fmt(s.pageviews) + ' visitas · ' + fmt(s.users) + ' usuarios',
          fr: fmt(s.pageviews) + ' vues · ' + fmt(s.users) + ' utilisateurs',
          de: fmt(s.pageviews) + ' Aufrufe · ' + fmt(s.users) + ' Nutzer',
        };
        el.textContent = labels[lang] || labels.en;
        el.hidden = false;
      })
      .catch(function () {});
  };
  if ('requestIdleCallback' in window) requestIdleCallback(run, { timeout: 4000 });
  else setTimeout(run, 1500);
})();
</script>
