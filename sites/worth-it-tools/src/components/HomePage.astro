---
import type { CoreLocale } from '../consts';
import { localizedPath } from '../i18n/utils';
import { homeContent } from '../lib/home';
import { getCollection } from 'astro:content';
import FAQ from './FAQ.astro';
import NewsletterSignup from './NewsletterSignup.astro';

interface Props {
  locale: CoreLocale;
}

const { locale } = Astro.props;
const content = homeContent[locale];
const growthTools = (await getCollection('growthTools', ({ data }) => data.locale === locale && !data.draft))
  .sort((a, b) => a.data.title.localeCompare(b.data.title, locale));
const growthHeading = {
  en: 'More planning calculators', zh: '更多財務規劃試算', es: 'Más calculadoras de planificación', fr: 'Autres calculateurs de planification', de: 'Weitere Planungsrechner',
}[locale];
---

<section class="hero">
  <span class="hero__eyebrow">💸 {content.eyebrow}</span>
  <h1>{content.heading}<span class="accent">{content.accent}</span>{content.headingSuffix}</h1>
  <p>{content.intro}</p>
  <ul class="hero__badges">
    {content.badges.map((badge) => <li>{badge}</li>)}
  </ul>
</section>

<section id="tools">
  <h2>{content.toolsHeading}</h2>
  <p class="section-lead">{content.toolsLead}</p>
  <div class="grid">
    {content.tools.map((tool) => (
      <article class="card">
        <span class="card__icon" aria-hidden="true">{tool.icon}</span>
        <h3><a href={localizedPath(locale, tool.path)}>{tool.title}</a></h3>
        <p>{tool.description}</p>
        <span class="card__cta">{content.toolsCta}</span>
      </article>
    ))}
    {growthTools.map((entry) => (
      <article class="card">
        <span class="card__icon" aria-hidden="true">📊</span>
        <h3><a href={localizedPath(locale, `/tools/${entry.data.toolSlug}`)}>{entry.data.title}</a></h3>
        <p>{entry.data.description}</p>
        <span class="card__cta">{content.toolsCta}</span>
      </article>
    ))}
  </div>
  <p class="section-lead growth-tool-note"><strong>{growthHeading}:</strong> {growthTools.length}</p>
</section>

<section class="home-method" aria-labelledby="home-method-heading">
  <h2 id="home-method-heading">{content.methodHeading}</h2>
  <p class="section-lead">{content.methodLead}</p>
  <ol>
    {content.methodSteps.map((step) => <li>{step}</li>)}
  </ol>
</section>

<section class="home-guides" aria-labelledby="home-guides-heading">
  <h2 id="home-guides-heading">{content.guidesHeading}</h2>
  <p class="section-lead">{content.guidesLead}</p>
  <div class="guide-grid">
    {content.guides.map((guide) => (
      <article class="guide-card">
        <h3><a href={localizedPath(locale, guide.path)}>{guide.title}</a></h3>
        <p>{guide.description}</p>
        <span>{content.guidesCta} →</span>
      </article>
    ))}
  </div>
</section>

<section class="seo-copy" aria-labelledby="home-seo-heading">
  <h2 id="home-seo-heading">{content.seoHeading}</h2>
  {content.seoParagraphs.map((paragraph) => <p>{paragraph}</p>)}
</section>

<FAQ items={content.faq} heading={content.faqHeading} />

{locale === 'en' && <NewsletterSignup id="home-newsletter-signup" />}
