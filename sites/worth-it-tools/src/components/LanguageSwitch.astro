---
import { LOCALE_LABELS, LOCALES, type Locale } from '../consts';
import { getLocaleFromUrl, switchLocalePath, useTranslations } from '../i18n/utils';

interface Props {
  locales?: Locale[];
}

const { locales = [...LOCALES] } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<nav class="language-switch" aria-label={t('lang.switch')}>
  {locales.map((target) => (
    <a
      href={switchLocalePath(Astro.url, target)}
      aria-current={target === locale ? 'true' : undefined}
    >
      {LOCALE_LABELS[target]}
    </a>
  ))}
</nav>
