---
import type { LocalizedCoreToolContent } from '../data/coreToolContent';

interface Props {
  content: LocalizedCoreToolContent;
}

const { content } = Astro.props;
const config = {
  kind: content.kind,
  currency: content.currency,
  numberLocale: content.numberLocale,
  initialVerdict: content.initialVerdict,
  invalidVerdict: content.invalidVerdict,
  favorableVerdict: content.favorableVerdict,
  unfavorableVerdict: content.unfavorableVerdict,
};
---

<div class="localized-calculator" data-localized-calculator>
  <p class="tool-intro">{content.intro}</p>
  <div class="calculator-grid">
    <section class="input-panel" aria-labelledby="localized-tool-inputs">
      <h2 id="localized-tool-inputs">{content.inputsHeading}</h2>
      <div class="input-grid">
        {content.fields.map((field) => (
          <div class="field">
            <label for={`calc-${field.id}`}>{field.label}</label>
            <input
              id={`calc-${field.id}`}
              data-field={field.id}
              type="number"
              inputmode="decimal"
              min={field.min ?? 0}
              step={field.step ?? 1}
              value={field.value}
            />
            <p class="helper">{field.helper}</p>
          </div>
        ))}
      </div>
    </section>
    <section class="result-panel" aria-live="polite" aria-labelledby="localized-tool-verdict">
      <p class="eyebrow">{content.verdictLabel}</p>
      <p id="localized-tool-verdict" class="verdict" data-verdict>{content.initialVerdict}</p>
      <div class="metric-grid">
        {content.metrics.map((metric) => (
          <p class="metric"><span>{metric.label}</span><strong data-output={metric.id}>—</strong></p>
        ))}
      </div>
    </section>
  </div>
  <script type="application/json" class="calculator-config" is:inline set:html={JSON.stringify(config)} />
</div>

<script>
  import { aprFromMonthlyRate, irrMonthly } from '../lib/money';

  interface CalculatorConfig {
    kind: 'installment' | 'subscription' | 'membership' | 'ev';
    currency: string;
    numberLocale: string;
    initialVerdict: string;
    invalidVerdict: string;
    favorableVerdict: string;
    unfavorableVerdict: string;
  }

  document.querySelectorAll<HTMLElement>('[data-localized-calculator]').forEach((container) => {
    if (container.dataset.ready === 'true') return;
    container.dataset.ready = 'true';
    const configNode = container.querySelector<HTMLScriptElement>('.calculator-config');
    if (!configNode?.textContent) return;
    const config = JSON.parse(configNode.textContent) as CalculatorConfig;
    const fields = new Map(
      [...container.querySelectorAll<HTMLInputElement>('[data-field]')].map((input) => [input.dataset.field ?? '', input]),
    );
    const verdict = container.querySelector<HTMLElement>('[data-verdict]');
    const money = new Intl.NumberFormat(config.numberLocale, { style: 'currency', currency: config.currency, maximumFractionDigits: 2 });

    function read(id: string): number {
      const value = Number(fields.get(id)?.value ?? 0);
      return Number.isFinite(value) ? value : 0;
    }

    function output(id: string, value: string): void {
      const node = container.querySelector<HTMLElement>(`[data-output="${id}"]`);
      if (node) node.textContent = value;
    }

    function percent(value: number): string {
      return `${value.toFixed(2)}%`;
    }

    function fill(template: string, values: Record<string, string>): string {
      return Object.entries(values).reduce((result, [key, value]) => result.replaceAll(`{${key}}`, value), template);
    }

    function updateInstallment(): void {
      const price = Math.max(0, read('cash-price'));
      const count = Math.max(1, Math.round(read('installments')));
      const totalInstallments = Math.max(0, read('total-paid'));
      const upfront = Math.max(0, read('upfront-fee'));
      const threshold = Math.max(0, read('acceptable-apr'));
      const payment = totalInstallments / count;
      const fullPaid = totalInstallments + upfront;
      const financingCost = fullPaid - price;
      const cashflows = [price - upfront, ...Array.from({ length: count }, () => -payment)];
      const apr = aprFromMonthlyRate(irrMonthly(cashflows));

      output('monthly-payment', money.format(payment));
      output('full-paid', money.format(fullPaid));
      output('finance-cost', money.format(financingCost));
      output('apr', Number.isFinite(apr) ? percent(apr) : '—');
      if (!verdict) return;
      if (price <= 0 || totalInstallments <= 0 || !Number.isFinite(apr)) {
        verdict.textContent = config.invalidVerdict;
        return;
      }
      verdict.textContent = fill(apr <= threshold ? config.favorableVerdict : config.unfavorableVerdict, {
        apr: percent(apr),
        threshold: percent(threshold),
      });
    }

    function updateSubscription(): void {
      const monthlyBills = Math.max(0, read('monthly-bills'));
      const quarterly = Math.max(0, read('quarterly-renewals'));
      const annual = Math.max(0, read('annual-renewals'));
      const monthly = monthlyBills + quarterly / 3 + annual / 12;
      const used = Math.max(0, read('used-monthly-cost'));
      const reviewable = Math.max(0, monthly - used);

      output('monthly-total', money.format(monthly));
      output('yearly-total', money.format(monthly * 12));
      output('five-year-total', money.format(monthly * 60));
      output('reviewable', money.format(reviewable));
      if (!verdict) return;
      if (monthly <= 0) {
        verdict.textContent = config.invalidVerdict;
        return;
      }
      verdict.textContent = fill(reviewable <= 0.01 ? config.favorableVerdict : config.unfavorableVerdict, {
        monthly: money.format(monthly),
        reviewable: money.format(reviewable),
      });
    }

    function updateMembership(): void {
      const fee = Math.max(0, read('annual-fee'));
      const monthlySpend = Math.max(0, read('monthly-spend'));
      const annualSpend = monthlySpend * 12;
      const rate = (Math.max(0, read('savings-rate')) + Math.max(0, read('reward-rate'))) / 100;
      const extras = Math.max(0, read('extra-costs'));
      const gross = annualSpend * rate;
      const net = gross - fee - extras;
      const breakEven = rate > 0 ? (fee + extras) / rate / 12 : Number.POSITIVE_INFINITY;

      output('gross-benefit', money.format(gross));
      output('net-benefit', money.format(net));
      output('break-even', Number.isFinite(breakEven) ? money.format(breakEven) : '—');
      output('annual-spend', money.format(annualSpend));
      if (!verdict) return;
      if (rate <= 0) {
        verdict.textContent = config.invalidVerdict;
        return;
      }
      verdict.textContent = fill(net >= 0 ? config.favorableVerdict : config.unfavorableVerdict, {
        net: money.format(net),
        loss: money.format(Math.abs(net)),
        breakEven: money.format(breakEven),
      });
    }

    function updateEv(): void {
      const evPrice = Math.max(0, read('ev-price'));
      const gasPrice = Math.max(0, read('gas-price'));
      const subsidy = Math.max(0, read('subsidy'));
      const monthlyKm = Math.max(0, read('monthly-km'));
      const years = Math.max(1, read('years'));
      const annualKm = monthlyKm * 12;
      const evEnergy = annualKm * Math.max(0, read('ev-consumption')) / 100 * Math.max(0, read('electricity-price'));
      const gasEnergy = annualKm * Math.max(0, read('gas-consumption')) / 100 * Math.max(0, read('fuel-price'));
      const evAnnual = evEnergy + Math.max(0, read('ev-maintenance'));
      const gasAnnual = gasEnergy + Math.max(0, read('gas-maintenance'));
      const evTotal = Math.max(0, evPrice - subsidy) + evAnnual * years;
      const gasTotal = gasPrice + gasAnnual * years;
      const difference = Math.abs(evTotal - gasTotal);
      const upfrontGap = Math.max(0, evPrice - subsidy - gasPrice);
      const annualSavings = gasAnnual - evAnnual;
      const breakEven = annualSavings > 0 ? upfrontGap / annualSavings : Number.POSITIVE_INFINITY;

      output('ev-total', money.format(evTotal)); output('gas-total', money.format(gasTotal));
      output('difference', money.format(difference)); output('break-even-years', Number.isFinite(breakEven) ? breakEven.toFixed(1) : '—');
      if (!verdict) return;
      if (evPrice <= 0 || gasPrice <= 0 || read('ev-consumption') <= 0 || read('gas-consumption') <= 0 || years <= 0) { verdict.textContent = config.invalidVerdict; return; }
      verdict.textContent = fill(evTotal <= gasTotal ? config.favorableVerdict : config.unfavorableVerdict, { difference: money.format(difference), years: String(years) });
    }

    const update = config.kind === 'installment'
      ? updateInstallment
      : config.kind === 'subscription'
        ? updateSubscription
        : config.kind === 'membership'
          ? updateMembership
          : updateEv;
    fields.forEach((field) => field.addEventListener('input', update));
    update();
  });
</script>

<style>
  .tool-intro,
  .helper {
    color: var(--color-muted);
  }

  .calculator-grid,
  .input-grid,
  .metric-grid {
    display: grid;
    gap: 1rem;
  }

  .localized-calculator,
  .calculator-grid,
  .input-grid,
  .metric-grid,
  .input-panel,
  .result-panel,
  .field,
  .metric {
    min-width: 0;
  }

  .localized-calculator {
    box-sizing: border-box;
    max-width: 100%;
    width: 100%;
  }

  .input-panel,
  .result-panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    padding: 1rem;
    box-shadow: var(--shadow-soft);
  }

  .field label {
    display: block;
    margin-bottom: 0.3rem;
    font-weight: 650;
  }

  .field input {
    box-sizing: border-box;
    max-width: 100%;
    width: 100%;
  }

  .helper {
    margin: 0.25rem 0 0;
    font-size: 0.92rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .verdict {
    margin: 0.25rem 0 1rem;
    font-size: 1.25rem;
    font-weight: 750;
    line-height: 1.35;
  }

  .metric {
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    padding: 0.75rem;
  }

  .metric span,
  .metric strong {
    display: block;
    overflow-wrap: anywhere;
  }

  .metric span {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  @media (min-width: 760px) {
    .calculator-grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 0.8fr);
      align-items: start;
    }

    .input-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .result-panel {
      position: sticky;
      top: 1rem;
    }
  }
</style>
