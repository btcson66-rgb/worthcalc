---
import type { LocalizedCoreToolContent } from '../data/coreToolContent';

interface Props {
  content: LocalizedCoreToolContent;
}

const { content } = Astro.props;
const config = {
  kind: content.kind,
  currency: content.currency,
  numberLocale: content.numberLocale,
  initialVerdict: content.initialVerdict,
  invalidVerdict: content.invalidVerdict,
  favorableVerdict: content.favorableVerdict,
  unfavorableVerdict: content.unfavorableVerdict,
};
---

<div class="localized-calculator" data-localized-calculator>
  <p class="tool-intro">{content.intro}</p>
  <div class="calculator-grid">
    <section class="input-panel" aria-labelledby="localized-tool-inputs">
      <h2 id="localized-tool-inputs">{content.inputsHeading}</h2>
      <div class="input-grid">
        {content.fields.map((field) => (
          <div class="field">
            <label for={`calc-${field.id}`}>{field.label}</label>
            <input
              id={`calc-${field.id}`}
              data-field={field.id}
              type="number"
              inputmode="decimal"
              min={field.min ?? 0}
              step={field.step ?? 1}
              value={field.value}
            />
            <p class="helper">{field.helper}</p>
          </div>
        ))}
      </div>
    </section>
    <section class="result-panel" aria-live="polite" aria-labelledby="localized-tool-verdict">
      <p class="eyebrow">{content.verdictLabel}</p>
      <p id="localized-tool-verdict" class="verdict" data-verdict>{content.initialVerdict}</p>
      <div class="metric-grid">
        {content.metrics.map((metric) => (
          <p class="metric"><span>{metric.label}</span><strong data-output={metric.id}>—</strong></p>
        ))}
      </div>
    </section>
  </div>
  <script type="application/json" class="calculator-config" is:inline set:html={JSON.stringify(config)} />
</div>

<script>
  import { aprFromMonthlyRate, irrMonthly } from '../lib/money';

  interface CalculatorConfig {
    kind: 'installment';
    currency: string;
    numberLocale: string;
    initialVerdict: string;
    invalidVerdict: string;
    favorableVerdict: string;
    unfavorableVerdict: string;
  }

  document.querySelectorAll<HTMLElement>('[data-localized-calculator]').forEach((container) => {
    if (container.dataset.ready === 'true') return;
    container.dataset.ready = 'true';
    const configNode = container.querySelector<HTMLScriptElement>('.calculator-config');
    if (!configNode?.textContent) return;
    const config = JSON.parse(configNode.textContent) as CalculatorConfig;
    const fields = new Map(
      [...container.querySelectorAll<HTMLInputElement>('[data-field]')].map((input) => [input.dataset.field ?? '', input]),
    );
    const verdict = container.querySelector<HTMLElement>('[data-verdict]');
    const money = new Intl.NumberFormat(config.numberLocale, { style: 'currency', currency: config.currency, maximumFractionDigits: 2 });

    function read(id: string): number {
      const value = Number(fields.get(id)?.value ?? 0);
      return Number.isFinite(value) ? value : 0;
    }

    function output(id: string, value: string): void {
      const node = container.querySelector<HTMLElement>(`[data-output="${id}"]`);
      if (node) node.textContent = value;
    }

    function percent(value: number): string {
      return `${value.toFixed(2)}%`;
    }

    function fill(template: string, values: Record<string, string>): string {
      return Object.entries(values).reduce((result, [key, value]) => result.replaceAll(`{${key}}`, value), template);
    }

    function updateInstallment(): void {
      const price = Math.max(0, read('cash-price'));
      const count = Math.max(1, Math.round(read('installments')));
      const totalInstallments = Math.max(0, read('total-paid'));
      const upfront = Math.max(0, read('upfront-fee'));
      const threshold = Math.max(0, read('acceptable-apr'));
      const payment = totalInstallments / count;
      const fullPaid = totalInstallments + upfront;
      const financingCost = fullPaid - price;
      const cashflows = [price - upfront, ...Array.from({ length: count }, () => -payment)];
      const apr = aprFromMonthlyRate(irrMonthly(cashflows));

      output('monthly-payment', money.format(payment));
      output('full-paid', money.format(fullPaid));
      output('finance-cost', money.format(financingCost));
      output('apr', Number.isFinite(apr) ? percent(apr) : '—');
      if (!verdict) return;
      if (price <= 0 || totalInstallments <= 0 || !Number.isFinite(apr)) {
        verdict.textContent = config.invalidVerdict;
        return;
      }
      verdict.textContent = fill(apr <= threshold ? config.favorableVerdict : config.unfavorableVerdict, {
        apr: percent(apr),
        threshold: percent(threshold),
      });
    }

    const update = config.kind === 'installment' ? updateInstallment : () => undefined;
    fields.forEach((field) => field.addEventListener('input', update));
    update();
  });
</script>

<style>
  .tool-intro,
  .helper {
    color: var(--color-muted);
  }

  .calculator-grid,
  .input-grid,
  .metric-grid {
    display: grid;
    gap: 1rem;
  }

  .localized-calculator,
  .calculator-grid,
  .input-grid,
  .metric-grid,
  .input-panel,
  .result-panel,
  .field,
  .metric {
    min-width: 0;
  }

  .localized-calculator {
    box-sizing: border-box;
    max-width: 100%;
    width: 100%;
  }

  .input-panel,
  .result-panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    padding: 1rem;
    box-shadow: var(--shadow-soft);
  }

  .field label {
    display: block;
    margin-bottom: 0.3rem;
    font-weight: 650;
  }

  .field input {
    box-sizing: border-box;
    max-width: 100%;
    width: 100%;
  }

  .helper {
    margin: 0.25rem 0 0;
    font-size: 0.92rem;
  }

  .eyebrow {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .verdict {
    margin: 0.25rem 0 1rem;
    font-size: 1.25rem;
    font-weight: 750;
    line-height: 1.35;
  }

  .metric {
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    padding: 0.75rem;
  }

  .metric span,
  .metric strong {
    display: block;
    overflow-wrap: anywhere;
  }

  .metric span {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  @media (min-width: 760px) {
    .calculator-grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 0.8fr);
      align-items: start;
    }

    .input-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .result-panel {
      position: sticky;
      top: 1rem;
    }
  }
</style>
