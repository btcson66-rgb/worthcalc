---
type CalculatorLocale = 'en' | 'zh' | 'es' | 'fr' | 'de';
type CurrencyCode = 'USD' | 'TWD' | 'EUR';

interface Props {
  locale: CalculatorLocale;
  currency: CurrencyCode;
  defaults: { repairQuote: number; repairMonths: number; recurrenceProbability: number; recurrenceCost: number; extraEnergyMonthly: number; replacementPrice: number; replacementFees: number; currentValue: number; replacementMonths: number };
  copy: Record<'heading' | 'intro' | 'repairQuote' | 'repairMonths' | 'recurrenceProbability' | 'recurrenceCost' | 'extraEnergyMonthly' | 'replacementPrice' | 'replacementFees' | 'currentValue' | 'replacementMonths' | 'repairExpected' | 'repairMonthly' | 'replacementNet' | 'replacementMonthly' | 'repairRatio' | 'breakEvenQuote' | 'verdictRepair' | 'verdictReplace' | 'privacy', string>;
}

const { locale, currency, defaults, copy } = Astro.props;
const localeTags: Record<CalculatorLocale, string> = { en: 'en-US', zh: 'zh-TW', es: 'es-ES', fr: 'fr-FR', de: 'de-DE' };
---

<section id="repair-replace-calculator" class="repair-calc" data-repair-replace-calculator data-locale={localeTags[locale]} data-currency={currency} data-verdict-repair={copy.verdictRepair} data-verdict-replace={copy.verdictReplace}>
  <h2>{copy.heading}</h2>
  <p>{copy.intro}</p>
  <div class="calc-grid">
    <div class="inputs">
      <label><span>{copy.repairQuote}</span><input data-field="repairQuote" type="number" min="0" step="1" value={defaults.repairQuote} /></label>
      <label><span>{copy.repairMonths}</span><input data-field="repairMonths" type="number" min="1" step="1" value={defaults.repairMonths} /></label>
      <label><span>{copy.recurrenceProbability}</span><input data-field="recurrenceProbability" type="number" min="0" max="100" step="1" value={defaults.recurrenceProbability} /></label>
      <label><span>{copy.recurrenceCost}</span><input data-field="recurrenceCost" type="number" min="0" step="1" value={defaults.recurrenceCost} /></label>
      <label><span>{copy.extraEnergyMonthly}</span><input data-field="extraEnergyMonthly" type="number" min="0" step="0.1" value={defaults.extraEnergyMonthly} /></label>
      <label><span>{copy.replacementPrice}</span><input data-field="replacementPrice" type="number" min="0" step="1" value={defaults.replacementPrice} /></label>
      <label><span>{copy.replacementFees}</span><input data-field="replacementFees" type="number" min="0" step="1" value={defaults.replacementFees} /></label>
      <label><span>{copy.currentValue}</span><input data-field="currentValue" type="number" min="0" step="1" value={defaults.currentValue} /></label>
      <label class="wide"><span>{copy.replacementMonths}</span><input data-field="replacementMonths" type="number" min="1" step="1" value={defaults.replacementMonths} /></label>
    </div>
    <div class="results" aria-live="polite">
      <p class="verdict" data-output="verdict"></p>
      <dl>
        <div><dt>{copy.repairExpected}</dt><dd data-output="repairExpected">—</dd></div>
        <div><dt>{copy.repairMonthly}</dt><dd data-output="repairMonthly">—</dd></div>
        <div><dt>{copy.replacementNet}</dt><dd data-output="replacementNet">—</dd></div>
        <div><dt>{copy.replacementMonthly}</dt><dd data-output="replacementMonthly">—</dd></div>
        <div><dt>{copy.repairRatio}</dt><dd data-output="repairRatio">—</dd></div>
        <div><dt>{copy.breakEvenQuote}</dt><dd data-output="breakEvenQuote">—</dd></div>
      </dl>
    </div>
  </div>
  <p class="note">{copy.privacy}</p>
</section>

<script>
  for (const root of document.querySelectorAll<HTMLElement>('[data-repair-replace-calculator]')) {
    const formatter = new Intl.NumberFormat(root.dataset.locale || 'en-US', { style: 'currency', currency: root.dataset.currency || 'USD', maximumFractionDigits: 0 });
    const number = new Intl.NumberFormat(root.dataset.locale || 'en-US', { maximumFractionDigits: 1 });
    const field = (name: string) => root.querySelector<HTMLInputElement>(`[data-field="${name}"]`)!;
    const out = (name: string) => root.querySelector<HTMLElement>(`[data-output="${name}"]`)!;
    const value = (name: string) => Math.max(0, Number(field(name).value) || 0);
    const money = (amount: number) => root.dataset.currency === 'TWD' ? `${amount < 0 ? '-' : ''}NT$${number.format(Math.abs(amount))}` : formatter.format(amount);
    const calculate = () => {
      const repairMonths = Math.max(1, value('repairMonths'));
      const replacementMonths = Math.max(1, value('replacementMonths'));
      const probability = Math.min(100, value('recurrenceProbability')) / 100;
      const recurrenceExpected = probability * value('recurrenceCost');
      const energyPenalty = value('extraEnergyMonthly') * repairMonths;
      const repairExpected = value('repairQuote') + recurrenceExpected + energyPenalty;
      const replacementNet = Math.max(0, value('replacementPrice') + value('replacementFees') - value('currentValue'));
      const repairMonthly = repairExpected / repairMonths;
      const replacementMonthly = replacementNet / replacementMonths;
      const repairRatio = replacementNet ? value('repairQuote') / replacementNet * 100 : 0;
      const breakEvenQuote = Math.max(0, repairMonths * replacementMonthly - recurrenceExpected - energyPenalty);
      const repairWins = repairMonthly <= replacementMonthly;
      const difference = Math.abs(repairMonthly - replacementMonthly);
      out('repairExpected').textContent = money(repairExpected);
      out('repairMonthly').textContent = money(repairMonthly);
      out('replacementNet').textContent = money(replacementNet);
      out('replacementMonthly').textContent = money(replacementMonthly);
      out('repairRatio').textContent = `${number.format(repairRatio)}%`;
      out('breakEvenQuote').textContent = money(breakEvenQuote);
      out('verdict').textContent = `${repairWins ? root.dataset.verdictRepair : root.dataset.verdictReplace} ${money(difference)}`.trim();
    };
    root.querySelectorAll('input').forEach((input) => input.addEventListener('input', calculate));
    calculate();
  }
</script>

<style>
  .repair-calc { margin: 2rem 0; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-surface); box-shadow: var(--shadow-soft); }
  .repair-calc h2 { margin-top: 0; }
  .calc-grid { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(18rem, .75fr); gap: 1.25rem; margin-top: 1.25rem; }
  .inputs { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .85rem; }
  .inputs .wide { grid-column: 1 / -1; }
  .inputs label span { display: block; min-height: 2.8rem; margin-bottom: .35rem; font-weight: 650; }
  .inputs input { box-sizing: border-box; width: 100%; min-width: 0; padding: .7rem .75rem; border: 1px solid var(--color-border); border-radius: .55rem; background: var(--color-bg); color: var(--color-text); font: inherit; }
  .results { align-self: start; padding: 1rem; border-radius: .8rem; background: var(--color-bg); }
  .results .verdict { margin-top: 0; font-weight: 800; }
  .results dl { margin: 0; }
  .results dl div { display: flex; justify-content: space-between; gap: 1rem; padding: .6rem 0; border-bottom: 1px solid var(--color-border); }
  .results dt { font-weight: 600; }
  .results dd { margin: 0; text-align: right; font-weight: 750; }
  .note { margin-bottom: 0; color: var(--color-text-muted); font-size: .92rem; }
  @media (max-width: 760px) { .repair-calc { padding: 1rem; } .calc-grid, .inputs { grid-template-columns: 1fr; } .inputs .wide { grid-column: auto; } .inputs label span { min-height: 0; } }
</style>
