---
import ArticleLayout from '../../layouts/ArticleLayout.astro'; import DecisionGuide from '../../components/DecisionGuide.astro'; import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro'; import FAQ from '../../components/FAQ.astro'; import { bulkBuyingGuides } from '../../data/decisionGuides'; import type { FaqItem } from '../../lib/seo';
type L='en'|'zh'|'es'|'fr'|'de';
const articles:Record<L,{title:string;description:string;faq:FaqItem[]}>= {
 en:{title:'Bulk buy or small pack? Effective unit cost after waste and storage',description:'Compare bulk and small packs using usable quantity, spoilage, expiry, membership, shipping and storage—not sticker unit price.',faq:[{question:'What is effective unit cost?',answer:'All purchase-related cost divided by the quantity you will actually use after waste, spoilage or expiry.'},{question:'How should I estimate waste?',answer:'Use household history and the time until opening or use-by, then test a higher-waste case.'},{question:'Do I include the whole membership fee?',answer:'Only if this purchase causes the membership. Otherwise allocate a consistent share or use zero when the fee is already unavoidable.'},{question:'What if the label uses different units?',answer:'Convert both to the same weight, volume or count before comparing.'},{question:'Can best-before food always be kept longer?',answer:'No blanket assumption is safe. Follow the package, storage guidance and use-by rules; the calculator must not override safety.'}]},
 zh:{title:'大包裝真的比較省嗎？耗損、效期、會員與保存成本計算器',description:'把小包與大包換成耗損後有效單價，納入有效日期、會員分攤、運費、分裝與保存空間。',faq:[{question:'什麼是有效單價？',answer:'商品、會員分攤、運費與保存成本的總和，除以耗損後真正會用到的數量。'},{question:'耗損率怎麼估？',answer:'用同類食品過去丟棄、過期或開封後未用完的紀錄，再做較悲觀情境。'},{question:'會員費要整年算進去嗎？',answer:'只有這次購買是入會主因才可全算；本來就會續會時應用一致分攤或列為零。'},{question:'公斤和公克可以直接比嗎？',answer:'不行，先把兩者換成相同重量、容量或件數。'},{question:'計算器能判斷過期食品安全嗎？',answer:'不能。有效日期與保存標示是安全限制，算式只比較成本。'}]},
 es:{title:'Comprar formato grande o pequeño: coste útil, merma y caducidad',description:'Compara coste por unidad aprovechada incluyendo merma, caducidad, cuota, envío y almacenaje.',faq:[{question:'¿Qué es el coste por unidad útil?',answer:'El coste total de compra y conservación dividido entre la cantidad que realmente se consumirá.'},{question:'¿Cómo estimo la merma?',answer:'Parte del historial del hogar y del tiempo hasta abrir o caducar, y prueba un escenario peor.'},{question:'¿Imputo toda la cuota anual?',answer:'Solo si este producto causa el alta. Si la cuota ya se pagaría, usa una asignación coherente o cero.'},{question:'¿Cómo comparo unidades distintas?',answer:'Convierte ambos formatos al mismo peso, volumen o número antes de calcular.'},{question:'¿La calculadora decide si un alimento es seguro?',answer:'No. Respeta caducidad, consumo preferente, integridad del envase e instrucciones de conservación.'}]},
 fr:{title:'Grand ou petit format : coût utile, pertes, DLC et stockage',description:'Comparez le coût par unité utilisable avec pertes, DLC ou DDM, adhésion, livraison et stockage.',faq:[{question:'Qu’est-ce que le coût par unité utile ?',answer:'Le coût total d’achat et de conservation divisé par la quantité réellement utilisée.'},{question:'Comment estimer les pertes ?',answer:'Partez de l’historique du foyer, de la date, de l’ouverture et du stockage, puis testez un cas défavorable.'},{question:'Faut-il compter toute la cotisation ?',answer:'Seulement si ce produit provoque l’adhésion ; sinon imputez une part cohérente ou zéro.'},{question:'Comment comparer deux unités ?',answer:'Convertissez les deux formats dans le même poids, volume ou nombre.'},{question:'Le calcul décide-t-il si un aliment reste sûr ?',answer:'Non. La DLC, la DDM, l’intégrité et les consignes de stockage restent déterminantes.'}]},
 de:{title:'Großpackung oder klein: echte Stückkosten nach Verderb und Lagerung',description:'Vergleichen Sie nutzbare Stückkosten mit Verlust, MHD oder Verbrauchsdatum, Beitrag, Versand und Lagerung.',faq:[{question:'Was sind effektive Kosten je nutzbarer Einheit?',answer:'Gesamte Kauf- und Lagerkosten geteilt durch die Menge, die wirklich verwendet wird.'},{question:'Wie schätze ich den Verlust?',answer:'Mit Haushaltsverlauf, Öffnung, Datum und Lagerkapazität; zusätzlich einen schlechten Fall rechnen.'},{question:'Kommt der ganze Jahresbeitrag hinein?',answer:'Nur wenn dieser Artikel die Mitgliedschaft auslöst; sonst konsistent anteilig oder gar nicht.'},{question:'Wie vergleiche ich verschiedene Einheiten?',answer:'Beide Packungen zuerst in dasselbe Gewicht, Volumen oder dieselbe Stückzahl umrechnen.'},{question:'Entscheidet der Rechner über Lebensmittelsicherheit?',answer:'Nein. Verbrauchsdatum, MHD, Verpackung und Lagerhinweise gelten unabhängig vom Preis.'}]}
};
const fields={
 en:[{key:'smallPrice',label:'Small-pack final price',step:.01},{key:'smallQty',label:'Small-pack quantity',step:.01},{key:'smallWaste',label:'Small-pack waste (%)',step:.1,max:99.9},{key:'bulkPrice',label:'Bulk-pack final price',step:.01},{key:'bulkQty',label:'Bulk-pack quantity',step:.01},{key:'bulkWaste',label:'Bulk-pack waste (%)',step:.1,max:99.9},{key:'membership',label:'Allocated membership fee',step:.01},{key:'shipping',label:'Extra shipping and handling',step:.01},{key:'storage',label:'Extra storage cost',step:.01}],
 zh:[{key:'smallPrice',label:'小包最終價',step:.1},{key:'smallQty',label:'小包數量',step:.01},{key:'smallWaste',label:'小包耗損（%）',step:.1,max:99.9},{key:'bulkPrice',label:'大包最終價',step:.1},{key:'bulkQty',label:'大包數量',step:.01},{key:'bulkWaste',label:'大包耗損（%）',step:.1,max:99.9},{key:'membership',label:'會員費分攤',step:.1},{key:'shipping',label:'額外運費與處理費',step:.1},{key:'storage',label:'額外保存成本',step:.1}],
 es:[{key:'smallPrice',label:'Precio final pequeño',step:.01},{key:'smallQty',label:'Cantidad pequeña',step:.01},{key:'smallWaste',label:'Merma pequeña (%)',step:.1,max:99.9},{key:'bulkPrice',label:'Precio final grande',step:.01},{key:'bulkQty',label:'Cantidad grande',step:.01},{key:'bulkWaste',label:'Merma grande (%)',step:.1,max:99.9},{key:'membership',label:'Cuota imputada',step:.01},{key:'shipping',label:'Envío y manipulación extra',step:.01},{key:'storage',label:'Almacenaje adicional',step:.01}],
 fr:[{key:'smallPrice',label:'Prix final petit',step:.01},{key:'smallQty',label:'Quantité petit',step:.01},{key:'smallWaste',label:'Perte petit (%)',step:.1,max:99.9},{key:'bulkPrice',label:'Prix final grand',step:.01},{key:'bulkQty',label:'Quantité grand',step:.01},{key:'bulkWaste',label:'Perte grand (%)',step:.1,max:99.9},{key:'membership',label:'Adhésion imputée',step:.01},{key:'shipping',label:'Livraison et frais supplémentaires',step:.01},{key:'storage',label:'Coût de stockage',step:.01}],
 de:[{key:'smallPrice',label:'Endpreis klein',step:.01},{key:'smallQty',label:'Menge klein',step:.01},{key:'smallWaste',label:'Verlust klein (%)',step:.1,max:99.9},{key:'bulkPrice',label:'Endpreis groß',step:.01},{key:'bulkQty',label:'Menge groß',step:.01},{key:'bulkWaste',label:'Verlust groß (%)',step:.1,max:99.9},{key:'membership',label:'Beitragsanteil',step:.01},{key:'shipping',label:'Zusatzversand und Bearbeitung',step:.01},{key:'storage',label:'Zusätzliche Lagerkosten',step:.01}]
};
const calculators={
 en:{currency:'USD' as const,defaults:{smallPrice:5,smallQty:1,smallWaste:5,bulkPrice:40,bulkQty:10,bulkWaste:15,membership:2,shipping:0,storage:1},fields:fields.en,copy:{heading:'Bulk effective unit-cost calculator',intro:'Use one common unit and the quantity you expect to consume safely.',output1:'Small effective unit cost',output2:'Bulk effective unit cost',output3:'Bulk total savings',verdictPositive:'Bulk costs less per usable unit.',verdictNegative:'The small pack costs less per usable unit.',privacy:'Planning model only; package dates and storage directions remain safety constraints.'}},
 zh:{currency:'TWD' as const,defaults:{smallPrice:120,smallQty:1,smallWaste:5,bulkPrice:900,bulkQty:10,bulkWaste:20,membership:60,shipping:0,storage:40},fields:fields.zh,copy:{heading:'大包裝有效單價計算器',intro:'兩邊使用相同單位，並以能在安全保存期限內用完的數量估算。',output1:'小包有效單價',output2:'大包有效單價',output3:'大包總節省',verdictPositive:'大包每個可用單位較省。',verdictNegative:'小包每個可用單位較省。',privacy:'成本情境模型；有效日期與保存標示仍是安全限制。'}},
 es:{currency:'EUR' as const,defaults:{smallPrice:4.8,smallQty:1,smallWaste:5,bulkPrice:36,bulkQty:10,bulkWaste:20,membership:3,shipping:0,storage:1},fields:fields.es,copy:{heading:'Calculadora de coste efectivo del formato grande',intro:'Usa una unidad común y solo la cantidad que se consumirá con conservación segura.',output1:'Coste útil del pequeño',output2:'Coste útil del grande',output3:'Ahorro total del grande',verdictPositive:'El grande cuesta menos por unidad útil.',verdictNegative:'El pequeño cuesta menos por unidad útil.',privacy:'Modelo de costes; las fechas y condiciones del envase siguen siendo límites de seguridad.'}},
 fr:{currency:'EUR' as const,defaults:{smallPrice:4.5,smallQty:1,smallWaste:5,bulkPrice:33,bulkQty:10,bulkWaste:20,membership:3,shipping:0,storage:1},fields:fields.fr,copy:{heading:'Calculateur du coût effectif du grand format',intro:'Même unité des deux côtés et seulement la quantité utilisable dans de bonnes conditions.',output1:'Coût utile du petit',output2:'Coût utile du grand',output3:'Gain total du grand',verdictPositive:'Le grand format coûte moins par unité utile.',verdictNegative:'Le petit format coûte moins par unité utile.',privacy:'Modèle de coût ; DLC, DDM et conservation restent des contraintes de sécurité.'}},
 de:{currency:'EUR' as const,defaults:{smallPrice:4.6,smallQty:1,smallWaste:5,bulkPrice:35,bulkQty:10,bulkWaste:15,membership:2,shipping:0,storage:2},fields:fields.de,copy:{heading:'Rechner für effektive Großpackungskosten',intro:'Gleiche Einheit und nur die bei richtiger Lagerung nutzbare Menge ansetzen.',output1:'Effektive Kleinkosten',output2:'Effektive Großkosten',output3:'Gesamtvorteil groß',verdictPositive:'Die Großpackung kostet je nutzbarer Einheit weniger.',verdictNegative:'Die kleine Packung kostet je nutzbarer Einheit weniger.',privacy:'Kostenmodell; Verbrauchsdatum, MHD und Lagerhinweise bleiben Sicherheitsgrenzen.'}}
};
export function getStaticPaths(){return ['en','zh','es','fr','de'].map(locale=>({params:{locale}}));} const locale=Astro.params.locale as L,article=articles[locale],guide=bulkBuyingGuides[locale]!,calculator=calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={['en','zh','es','fr','de']}>
 {locale==='en'&&<><p>The shelf label answers price per printed unit. Your budget needs price per usable unit. A large package can lose its advertised advantage through spoilage, an annual-fee allocation, delivery or extra freezer space.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="bulk-buy-calculator" mode="bulk" locale={locale} {...calculator}/><h2>Estimate use before the safety limit</h2><p>Start with meals or uses per week and the package’s instructions. FoodSafety.gov’s FoodKeeper and cold-storage guidance can frame storage; do not convert a cost assumption into permission to keep food longer.</p><h2>Allocate shared fees without gaming the result</h2><p>If the membership and trip would happen anyway, do not charge them fully to this item. If the item is the reason for joining or placing the order, include the incremental amount.</p><p class="privacy-note">General consumer education, not food-safety, financial or product advice.</p></>}
 {locale==='zh'&&<><p>賣場標出的每公斤價格只用了包裝淨重；家庭真正花掉的是「總支出 ÷ 在效期與正確保存下用完的數量」。大包即使牌價低，也可能被耗損、會員與冷凍空間吃掉。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="bulk-buy-calculator" mode="bulk" locale={locale} {...calculator}/><h2>先用消耗速度對照有效日期</h2><p>食藥署 2026 年提醒要依效期適量選購，並確認冷藏、冷凍或避光等保存方式。把每週用量乘上可保存週數，超出的數量先列為可能耗損。</p><h2>會員與運費只算增量</h2><p>若本來就續會、同趟還買其他用品，不能把整年會員費與整趟成本都塞給這一包；若只為這個優惠入會或湊單，增量就應完整納入。</p><p class="privacy-note">一般消費教育資訊，不是食品安全、財務或商品建議。</p></>}
 {locale==='es'&&<><p>El precio por kilo de la etiqueta usa toda la cantidad envasada. La economía doméstica debe dividir el desembolso completo entre lo que se consumirá respetando apertura, frío y fecha.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="bulk-buy-calculator" mode="bulk" locale={locale} {...calculator}/><h2>Caducidad y consumo preferente no son lo mismo</h2><p>AESAN indica que no debe consumirse un alimento pasada la fecha de caducidad; el consumo preferente trata de calidad si se respetan conservación e integridad. El cálculo no puede borrar esa diferencia.</p><h2>Compra según necesidades y cadena de frío</h2><p>La guía de compra segura de AESAN recomienda lista, orden de compra y atención a las fechas. Si el hogar no tiene ritmo o espacio para conservar el lote, refleja esa parte como merma o coste.</p><p class="privacy-note">Información general de consumo; no es consejo alimentario, financiero ni de producto.</p></>}
 {locale==='fr'&&<><p>Le prix au kilo utilise la quantité vendue ; votre budget doit utiliser la quantité réellement consommée. Un faible écart de prix disparaît vite avec une DLC proche, des frais ou un stockage insuffisant.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="bulk-buy-calculator" mode="bulk" locale={locale} {...calculator}/><h2>DLC, DDM et ouverture imposent trois horizons</h2><p>La DGCCRF rappelle que la DLC ne doit pas être dépassée, tandis que la DDM concerne les qualités d’un produit intact. Après ouverture, ce sont les consignes et le délai indiqué qui priment : estimez les pertes sur le bon horizon.</p><h2>Prix TTC et frais supplémentaires</h2><p>Le coût comparé inclut livraison et frais indispensables annoncés avant l’achat. Une cotisation ou un trajet déjà décidé ne doit toutefois pas être compté deux fois.</p><p class="privacy-note">Information générale de consommation, pas un conseil alimentaire, financier ou produit.</p></>}
 {locale==='de'&&<><p>Der Regalpreis teilt durch die volle Nennmenge. Für den Haushalt zählt, wie viel vor Verbrauchsdatum oder bei richtiger Lagerung tatsächlich genutzt wird.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="bulk-buy-calculator" mode="bulk" locale={locale} {...calculator}/><h2>Nur lagerbare und rechtzeitig verbrauchbare Mengen</h2><p>Die Verbraucherzentrale empfiehlt ausdrücklich, nur Vorräte zu kaufen, die vorschriftsmäßig gelagert und vor MHD beziehungsweise Verbrauchsdatum verzehrt werden können. Fehlender Kühlplatz ist damit keine Nebensache.</p><h2>MHD ist nicht Verbrauchsdatum</h2><p>Das MHD bezieht sich auf ungeöffnete, durchgehend richtig gelagerte Ware; das Verbrauchsdatum ist die strengere Grenze. Der Rechner vergleicht Geld, nicht Essbarkeit.</p><p class="privacy-note">Allgemeine Verbraucherbildung, keine Lebensmittel-, Finanz- oder Produktberatung.</p></>}
 <FAQ items={article.faq}/>
</ArticleLayout>
