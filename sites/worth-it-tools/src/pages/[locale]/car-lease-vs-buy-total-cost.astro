---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import CarLeaseBuyCalculator from '../../components/CarLeaseBuyCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { carLeaseBuyGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type EditorialLocale = 'en' | 'zh' | 'es';

const articles: Record<EditorialLocale, { title: string; description: string; faq: FaqItem[] }> = {
  en: {
    title: 'Lease vs buy a car: compare total cost, mileage, and resale risk',
    description: 'Compare a car lease return with buying over the same months, including due-at-signing cash, mileage limits, end fees, loan interest, resale and residual risk.',
    faq: [
      { question: 'Is leasing cheaper because the monthly payment is lower?', answer: 'Not necessarily. A lease payment covers expected depreciation, rent charge, taxes and fees but usually does not build ownership. Compare total due at signing, all payments, nonincluded costs, mileage and return fees with purchase cost minus resale.' },
      { question: 'How do mileage limits change lease cost?', answer: 'Multiply miles above the contractual allowance over the full term by the stated per-mile charge. Unused miles may have no value unless the contract provides a credit; purchased-car resale should also reflect its actual mileage.' },
      { question: 'Who takes residual-value risk in a lease?', answer: 'In a typical closed-end return lease, the lessor generally bears ordinary market-value risk, while the lessee remains responsible for contractual mileage, wear and end fees. Open-end leases can allocate more residual liability to the lessee.' },
      { question: 'Should I include a lease purchase option in the return cost?', answer: 'No. First compare returning the lease with selling a purchased car. Show the option price against expected market value separately; add it only in a distinct buyout scenario.' },
      { question: 'What if I may end the lease early?', answer: 'Do not assume you can return the car and stop paying. Obtain the early-termination formula and run it as a separate downside because the charge can be large.' },
    ],
  },
  zh: {
    title: '租賃還是買車？總成本、里程限制與轉售風險怎麼算',
    description: '用相同期間比較汽車長租／租賃與買車，納入簽約金、月租、保險保養、超里程、還車費、貸款利息、轉售與買回價。',
    faq: [
      { question: '長租月租比車貸月付低就比較省嗎？', answer: '不一定。月租之外可能有簽約金、未含保險保養、超里程、車損、提前終止與還車費；車貸月付則包含償還本金。必須比較同期間淨成本。' },
      { question: '台灣長租、租賃和以租代購是一樣的嗎？', answer: '不一定。是否在期末取得所有權、是否有約定買回價、誰負擔稅費保險與維修，都以書面契約為準，不能只看方案名稱。' },
      { question: '沒用完的里程會退錢嗎？', answer: '只有契約明列才有。計算器對未用完里程不給預設收益；超出里程則依全期超額乘每公里費率。' },
      { question: '保證金要算長租成本嗎？', answer: '若依約可完整返還，保證金是占用資金而不是成本；若可能因車損或其他條款被抵扣，應把合理扣款放進預估還車費情境。' },
      { question: '租期末買回價怎麼判斷？', answer: '把書面買回價和當時同車型、里程、車況的市場估值比較。買回價高於市場並不代表已付月租應追回，應把還車與買回當兩個方案。' },
    ],
  },
  es: {
    title: 'Renting, leasing o compra: cómo comparar coste total, kilometraje y valor residual',
    description: 'Compara renting, leasing y compra durante los mismos meses con cuota, servicios, kilómetros, devolución, intereses, reventa, opción y valor residual.',
    faq: [
      { question: '¿Renting y leasing de coche son lo mismo en España?', answer: 'No necesariamente. Banco de España describe el renting como alquiler de servicios sin opción contractual de compra y el leasing financiero como cesión con intereses, gastos y una opción que suele representar el valor residual.' },
      { question: '¿La cuota de renting incluye todos los gastos?', answer: 'Depende del contrato. Puede incluir seguro, mantenimiento, impuestos, reparaciones o neumáticos, pero hay que revisar franquicia, exclusiones, kilómetros, sustitución, cancelación y devolución.' },
      { question: '¿Cómo calculo el exceso de kilómetros?', answer: 'Resta los kilómetros totales incluidos a los previstos durante todo el contrato y multiplica solo el exceso por la tarifa. Ajusta también la reventa de compra si su kilometraje será mayor.' },
      { question: '¿El renting elimina el riesgo de valor residual?', answer: 'Al devolverlo, el usuario evita normalmente vender el coche, pero conserva los riesgos contractuales de kilometraje, daños y cancelación. Si existe opción de compra, compara su precio con el mercado por separado.' },
      { question: '¿Puedo cancelar el renting sin pagar el resto?', answer: 'No debe suponerse. El contenido e indemnización dependen del contrato y pueden ser elevados. Pide la fórmula por escrito antes de firmar y prueba un escenario de salida anticipada.' },
    ],
  },
};

