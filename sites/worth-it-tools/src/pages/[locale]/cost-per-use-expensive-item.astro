---
import ArticleLayout from '../../layouts/ArticleLayout.astro'; import DecisionGuide from '../../components/DecisionGuide.astro'; import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro'; import FAQ from '../../components/FAQ.astro'; import { costPerUseGuides } from '../../data/decisionGuides'; import type { FaqItem } from '../../lib/seo';
type L='en'|'zh'|'es';
const articles:Record<L,{title:string;description:string;faq:FaqItem[]}>= {
 en:{title:'Cost per use calculator for expensive items: expected vs actual value',description:'Calculate net cost per use from purchase, maintenance, consumables, resale, expected uses, actual uses and an alternative.',faq:[{question:'What belongs in net ownership cost?',answer:'Purchase, financing, required maintenance and ownership-only consumables, minus conservative net resale. Avoid counting costs shared with the alternative.'},{question:'Should I use expected or actual uses?',answer:'Use both. Expected uses support the purchase decision; actual uses provide a post-purchase review and reveal optimism.'},{question:'How do I estimate resale?',answer:'Use recent comparable completed sales where available, then subtract platform, shipping, refurbishment and condition deductions.'},{question:'What is the right alternative?',answer:'The cheapest feasible option with comparable quality and availability: rental, membership, service, borrowing or a lower-cost product.'},{question:'Is a high past cost a reason to keep using it?',answer:'No. Past purchase cost is sunk. Compare future maintenance and consumables with today’s sale value and future alternatives.'}]},
 zh:{title:'高價物品每次使用成本：預期、實際與損益次數計算器',description:'用購買、維護、耗材、淨轉售、預期與實際次數，計算高價物品每次成本及租用替代損益點。',faq:[{question:'持有淨成本要放哪些？',answer:'完整購買、融資、必要維護與持有才有的耗材，扣掉保守淨轉售；替代方案也會發生的成本不要重複。'},{question:'要用預期還是實際次數？',answer:'購買前用低／中／高預期；購買後持續用實際次數重算，才能看出是否高估使用。'},{question:'轉售價怎麼估？',answer:'優先看相同型號、年限與狀況的實際成交，再扣平台、運送、整理與議價。'},{question:'替代方案怎麼選？',answer:'選品質、可用性相近且真正可行的租用、共享、服務或低價品，不要拿不存在的優惠價。'},{question:'買很貴就應繼續用嗎？',answer:'不是。過去購入價已沉沒；是否保留要比較未來維護、耗材、現在可賣價與未來替代。'}]},
 es:{title:'Coste por uso de un artículo caro: valor previsto, real y punto de equilibrio',description:'Calcula coste neto por uso con compra, mantenimiento, consumibles, reventa, usos previstos y reales y alternativa.',faq:[{question:'¿Qué incluye el coste neto?',answer:'Compra, financiación, mantenimiento necesario y consumibles propios de tenerlo, menos reventa neta prudente.'},{question:'¿Usos previstos o reales?',answer:'Ambos. Los previstos sirven antes de comprar; los reales auditan la decisión y muestran optimismo.'},{question:'¿Cómo estimo reventa?',answer:'Busca ventas comparables cerradas y resta comisión, envío, reacondicionamiento y descuento por estado.'},{question:'¿Qué alternativa comparo?',answer:'La opción factible más barata con calidad y disponibilidad similares: alquiler, servicio, suscripción, préstamo o producto sencillo.'},{question:'¿El coste pasado obliga a conservarlo?',answer:'No. Es hundido. Compara desde hoy mantenimiento y consumibles futuros con venta actual y alternativa futura.'}]}
};
const fields={en:[{key:'purchase',label:'Purchase and financing cost'},{key:'maintenance',label:'Lifetime maintenance and repairs'},{key:'consumables',label:'Ownership-only consumables'},{key:'resale',label:'Net resale value'},{key:'expectedUses',label:'Expected lifetime uses'},{key:'actualUses',label:'Actual uses so far'},{key:'alternativePerUse',label:'Comparable alternative per use',step:.01}],zh:[{key:'purchase',label:'完整購買與融資成本'},{key:'maintenance',label:'持有期維護與維修'},{key:'consumables',label:'持有才有的耗材'},{key:'resale',label:'淨轉售價值'},{key:'expectedUses',label:'預期總使用次數'},{key:'actualUses',label:'目前實際使用次數'},{key:'alternativePerUse',label:'可行替代每次成本',step:.1}],es:[{key:'purchase',label:'Compra y financiación'},{key:'maintenance',label:'Mantenimiento y reparaciones'},{key:'consumables',label:'Consumibles de propiedad'},{key:'resale',label:'Reventa neta'},{key:'expectedUses',label:'Usos totales previstos'},{key:'actualUses',label:'Usos reales hasta hoy'},{key:'alternativePerUse',label:'Alternativa comparable por uso',step:.01}]};
const calculators={en:{currency:'USD' as const,defaults:{purchase:2500,maintenance:300,consumables:200,resale:800,expectedUses:500,actualUses:200,alternativePerUse:8},fields:fields.en,copy:{heading:'Expected and actual cost-per-use calculator',intro:'Use conservative resale and a feasible like-for-like alternative.',output1:'Expected cost per use',output2:'Actual cost per use',output3:'Break-even uses',verdictPositive:'Ownership is lower per actual use.',verdictNegative:'The alternative is lower per actual use.',privacy:'Planning model; use net resale and do not let sunk cost dictate the next decision.'}},zh:{currency:'TWD' as const,defaults:{purchase:60000,maintenance:8000,consumables:4000,resale:15000,expectedUses:600,actualUses:200,alternativePerUse:300},fields:fields.zh,copy:{heading:'預期與實際每次成本計算器',intro:'使用保守淨轉售與真正可行的同品質替代方案。',output1:'預期每次成本',output2:'實際每次成本',output3:'損益使用次數',verdictPositive:'目前持有的實際每次成本較低。',verdictNegative:'目前替代方案的每次成本較低。',privacy:'情境模型；轉售需扣費，後續決策不可被沉沒成本綁架。'}},es:{currency:'EUR' as const,defaults:{purchase:1800,maintenance:200,consumables:100,resale:500,expectedUses:400,actualUses:160,alternativePerUse:8},fields:fields.es,copy:{heading:'Calculadora de coste previsto y real por uso',intro:'Usa reventa neta prudente y una alternativa viable equivalente.',output1:'Coste previsto por uso',output2:'Coste real por uso',output3:'Usos de equilibrio',verdictPositive:'Comprar cuesta menos por uso real.',verdictNegative:'La alternativa cuesta menos por uso real.',privacy:'Modelo de planificación; descuenta vender y no dejes que el coste hundido dicte el futuro.'}}};
export function getStaticPaths(){return ['en','zh','es'].map(locale=>({params:{locale}}));} const locale=Astro.params.locale as L,article=articles[locale],guide=costPerUseGuides[locale]!,calculator=calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={[locale]}>
 {locale==='en'&&<><p>“Cost per use” is useful only when the numerator includes ownership costs and the denominator survives contact with real behavior. Track actual use after purchase instead of preserving the optimistic forecast.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="cost-per-use-calculator" mode="costPerUse" locale={locale} {...calculator}/><h2>Forecast from a calendar, not an identity</h2><p>List the dates you would actually use the item in a normal month, including seasons, travel and setup friction. “I am a photographer” is not a use count; twelve booked sessions are.</p><h2>Recalculate a keep-or-sell decision from today</h2><p>The original price is no longer avoidable. Compare future maintenance and consumables plus the value forgone by not selling today against future rental or service cost.</p><p class="privacy-note">General education, not financial, tax, warranty, resale or product advice.</p></>}
 {locale==='zh'&&<><p>「單次成本低」常建立在永遠沒有發生的使用次數上。購買前用行事曆估低／中／高次數，購買後以實際紀錄取代願望，才是可查核的價值判斷。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="cost-per-use-calculator" mode="costPerUse" locale={locale} {...calculator}/><h2>總價、保固與售後先寫清楚</h2><p>行政院消保會要求電商揭露總價、品質保證、保固與售後服務；把運送、安裝、必要服務與耗材列進成本，不能只抓商品頁大字價格。</p><h2>買後是否保留要重設起點</h2><p>原購入價已無法回收。今天的選擇應比較：繼續持有的未來費用與放棄的現在轉售價，對上未來租用或服務成本。</p><p class="privacy-note">一般教育資訊，不是財務、稅務、保固、轉售或產品建議。</p></>}
 {locale==='es'&&<><p>El coste por uso deja de ser útil si el denominador es una aspiración. Antes de comprar, crea un calendario bajo, central y alto; después, sustituye la previsión por usos registrados.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="cost-per-use-calculator" mode="costPerUse" locale={locale} {...calculator}/><h2>La garantía cambia el mantenimiento, no el número de usos</h2><p>En España los productos nuevos tienen tres años de garantía legal con carácter general. No presupuestes como reparación pagada una falta de conformidad cubierta, ni cuentes dos veces un plan adicional.</p><h2>Vender hoy es una decisión nueva</h2><p>El precio pagado es hundido. Desde hoy compara mantenimiento y consumibles futuros más el valor de venta perdido con el alquiler o servicio futuro.</p><p class="privacy-note">Información general; no es asesoramiento financiero, fiscal, de garantía, reventa o producto.</p></>}
 <FAQ items={article.faq}/>
</ArticleLayout>
