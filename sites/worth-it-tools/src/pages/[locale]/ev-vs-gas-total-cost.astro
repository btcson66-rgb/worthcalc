---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import EVGasTcoCalculator from '../../components/EVGasTcoCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { LOCALES } from '../../consts';
import { evGasTcoGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type EditorialLocale = 'en' | 'zh' | 'es' | 'fr' | 'de';

const articles: Record<EditorialLocale, { title: string; description: string; faq: FaqItem[] }> = {
  en: {
    title: 'EV vs gas car: how to compare total cost of ownership',
    description: 'Compare an EV and gas car using out-the-door price, charging or fuel, insurance, maintenance, taxes, depreciation and resale over your actual ownership period.',
    faq: [
      { question: 'What costs belong in an EV versus gas total cost comparison?', answer: 'Include each vehicle’s all-in purchase price, confirmed incentives, one-time setup and financing costs, energy, insurance, maintenance, recurring taxes and fees, and resale proceeds at the same ownership year.' },
      { question: 'Should I assume an EV tax credit in the base case?', answer: 'Only if the exact vehicle, purchase, income and use satisfy current rules and you expect to keep the benefit. Otherwise enter zero and show eligibility as a separate scenario.' },
      { question: 'How should public charging be included?', answer: 'Use a blended electricity rate: home kWh times its share, workplace or subscription charging times its share, and public fast charging times its share. Add charging losses before multiplying by the rate.' },
      { question: 'Is depreciation the purchase price minus resale value?', answer: 'In this cash TCO model, yes: net purchase price minus expected sale proceeds. Charger installation and other one-time expenses remain separate because they may not be recovered in the vehicle sale.' },
      { question: 'Does the lower five-year TCO prove which car I should buy?', answer: 'No. It is a cost estimate. Charging access, range, reliability, safety, utility, emissions and financing risk must still be evaluated, especially when the modeled difference is small.' },
    ],
  },
  zh: {
    title: '電動車和油車怎麼比較五年總持有成本',
    description: '用實際成交價、家充建置、電費或油錢、保險、保養、牌照稅、汽車燃料使用費、折舊與轉售價比較電動車和油車五年成本。',
    faq: [
      { question: '電動車免牌照稅就一定比較省嗎？', answer: '不一定。地方政府可依法決定免徵期間，且省下的年度稅費可能小於購車價差、保費差或轉售價差。應用車籍地和實際車款重新計算。' },
      { question: '電動車現在要繳汽車燃料使用費嗎？', answer: '現行汽車燃料使用費徵收及分配辦法把電動汽車列為免徵車輛；購車前仍應查核當時法規與是否已有道路養護費制度調整。' },
      { question: '社區充電費怎麼填？', answer: '把家用、社區管理加價、公司與公共快充依預計度數占比加權，並加入充電損耗。只有住宅電價會低估大量快充者的成本。' },
      { question: '為什麼轉售價對結果影響很大？', answer: '五年持有的折舊通常是最大成本之一。若電動車與油車的轉售差估錯數十萬元，可能遠大於五年能源差額，所以必須測試保守轉售情境。' },
      { question: '五年總成本較低就代表該買那台車嗎？', answer: '不是。總成本不判斷家中能否裝充電樁、長途需求、空間、安全、電池保固或貸款負擔；差額很小時更不應把試算當成保證。' },
    ],
  },
  es: {
    title: 'Coche eléctrico o gasolina: cómo comparar el coste total de propiedad',
    description: 'Compara precio final, ayuda confirmada, recarga o combustible, seguro, mantenimiento, impuestos, depreciación y reventa durante el mismo plazo.',
    faq: [
      { question: '¿Qué incluye el coste total de propiedad de un coche?', answer: 'Incluye precio final, ayuda realmente aplicable, instalación o financiación inicial, energía, seguro, mantenimiento, impuestos y tasas recurrentes, menos el valor de reventa al final del mismo plazo.' },
      { question: '¿Puedo restar automáticamente la ayuda MOVES?', answer: 'No. La gestión y disponibilidad dependen de la convocatoria de la comunidad autónoma, y puede existir efecto fiscal. Usa cero hasta confirmar solicitud, elegibilidad, concesión e importe neto.' },
      { question: '¿La etiqueta Cero garantiza una bonificación del IVTM?', answer: 'No. La etiqueta identifica la categoría ambiental, pero las bonificaciones fiscales, de estacionamiento o acceso dependen de la norma municipal vigente.' },
      { question: '¿Cómo mezclo carga doméstica y carga rápida?', answer: 'Calcula un precio ponderado por kWh con el porcentaje real de energía de cada canal y añade pérdidas. No uses solo la tarifa doméstica si dependes habitualmente de carga pública.' },
      { question: '¿Es fiable el valor de reventa a cinco años?', answer: 'Es una hipótesis, no una cotización garantizada. Comprueba precios del modelo y kilometraje comparables y prueba un escenario de reventa baja antes de aceptar una ventaja pequeña.' },
