---
import HomePage from '../../components/HomePage.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { homeContent, homeJsonLd } from '../../lib/home';
import type { CoreLocale } from '../../consts';

export function getStaticPaths() {
  return ['es', 'fr', 'de'].map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as CoreLocale;
const content = homeContent[locale];
---

<BaseLayout title={content.title} description={content.description} locale={locale} jsonLd={homeJsonLd(locale, Astro.site)}>
  <HomePage locale={locale} />
</BaseLayout>
