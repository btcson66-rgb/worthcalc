---
import ArticleLayout from '../../layouts/ArticleLayout.astro'; import DecisionGuide from '../../components/DecisionGuide.astro'; import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro'; import FAQ from '../../components/FAQ.astro'; import { mealPrepGuides } from '../../data/decisionGuides'; import type { FaqItem } from '../../lib/seo';
type L='en'|'zh'|'es';
const articles:Record<L,{title:string;description:string;faq:FaqItem[]}>= {
 en:{title:'Meal prep vs takeout cost: food, time, waste and delivery per serving',description:'Compare meal prep and takeout per equivalent serving with ingredient waste, batch time, delivery, tip, transport and waiting.',faq:[{question:'Should I count my cooking time?',answer:'Show cash-only and time-valued results separately. Time is an opportunity-cost scenario, not automatic lost wages.'},{question:'How do I count ingredient waste?',answer:'Increase ingredient cost by the portion routinely unused, and reduce servings when prepared food is discarded.'},{question:'What counts as a serving?',answer:'A portion actually eaten with comparable size, quality and nutrition—not every container filled.'},{question:'What takeout fees belong in the model?',answer:'Food, delivery, service fee, tip, pickup travel, parking and ordering or waiting time.'},{question:'Can meal prep servings stay in the denominator indefinitely?',answer:'No. Only safely cooled, stored and eaten portions count; follow food-specific official guidance.'}]},
 zh:{title:'自煮備餐還是外食？食材、時間、耗損與外送費計算器',description:'用同等每份比較自煮與外食，納入食材耗損、批次時間、容器能源、外送、交通與等待。',faq:[{question:'備餐時間要算錢嗎？',answer:'現金與含時間兩種結果分開看；時間價值是情境，不是沒叫外送就少領的薪水。'},{question:'食材耗損怎麼算？',answer:'把經常沒用完的食材加進成本，成品未吃完則直接減少實際份數。'},{question:'什麼才算一份？',answer:'份量、品質與營養相近且實際吃完的一餐，不是裝了幾個盒子。'},{question:'外食還要算什麼？',answer:'餐價、外送／服務費、小費、自取交通停車與下單等候時間。'},{question:'一次做很多份一定比較省嗎？',answer:'不一定；吃不完、冰箱放不下或無法安全保存時，分母會下降。'}]},
 es:{title:'Cocinar por lotes o pedir comida: coste por ración con tiempo y merma',description:'Compara ingredientes, merma, tiempo, energía y recipientes con comida, entrega, propina, transporte y espera.',faq:[{question:'¿Cuento el tiempo de cocinar?',answer:'Muestra efectivo y tiempo por separado; el tiempo es un escenario, no salario perdido automático.'},{question:'¿Cómo cuento la merma?',answer:'Aumenta ingredientes por lo que no se usa y reduce raciones por comida preparada que se tira.'},{question:'¿Qué es una ración comparable?',answer:'Una porción realmente consumida de tamaño, calidad y composición similares.'},{question:'¿Qué costes del pedido incluyo?',answer:'Comida, entrega, servicio, propina, transporte, aparcamiento y espera.'},{question:'¿Puedo contar todas las fiambreras?',answer:'Solo las raciones enfriadas, almacenadas y consumidas de forma segura.'}]}
};
const fields={en:[{key:'ingredients',label:'Ingredients for the batch',step:.01},{key:'waste',label:'Ingredient and serving waste (%)',step:.1},{key:'batchExtras',label:'Containers, energy and batch extras',step:.01},{key:'homeTimeHours',label:'Active home time (hours)',step:.05},{key:'timeValue',label:'Time value per hour',step:.01},{key:'servings',label:'Equivalent servings actually eaten'},{key:'takeoutFood',label:'Takeout food price',step:.01},{key:'delivery',label:'Delivery and service fees',step:.01},{key:'tip',label:'Tip',step:.01},{key:'transport',label:'Pickup travel and parking',step:.01},{key:'takeoutTimeHours',label:'Order/wait time (hours)',step:.05},{key:'takeoutServings',label:'Takeout servings'},{key:'mealsPerMonth',label:'Compared meals per month'}],zh:[{key:'ingredients',label:'整批食材成本',step:.1},{key:'waste',label:'食材與份數耗損（%）',step:.1},{key:'batchExtras',label:'容器、能源與批次額外成本',step:.1},{key:'homeTimeHours',label:'自煮主動時間（小時）',step:.05},{key:'timeValue',label:'每小時時間價值',step:.1},{key:'servings',label:'實際吃完的同等份數'},{key:'takeoutFood',label:'外食餐價',step:.1},{key:'delivery',label:'外送與服務費',step:.1},{key:'tip',label:'小費',step:.1},{key:'transport',label:'自取交通與停車',step:.1},{key:'takeoutTimeHours',label:'下單／等候時間（小時）',step:.05},{key:'takeoutServings',label:'外食份數'},{key:'mealsPerMonth',label:'每月比較餐數'}],es:[{key:'ingredients',label:'Ingredientes del lote',step:.01},{key:'waste',label:'Merma de ingredientes y raciones (%)',step:.1},{key:'batchExtras',label:'Recipientes, energía y extras',step:.01},{key:'homeTimeHours',label:'Tiempo activo en casa (horas)',step:.05},{key:'timeValue',label:'Valor de una hora',step:.01},{key:'servings',label:'Raciones equivalentes consumidas'},{key:'takeoutFood',label:'Precio de comida preparada',step:.01},{key:'delivery',label:'Entrega y servicio',step:.01},{key:'tip',label:'Propina',step:.01},{key:'transport',label:'Transporte y aparcamiento',step:.01},{key:'takeoutTimeHours',label:'Tiempo de pedido/espera',step:.05},{key:'takeoutServings',label:'Raciones del pedido'},{key:'mealsPerMonth',label:'Comidas comparadas al mes'}]};
const calculators={en:{currency:'USD' as const,defaults:{ingredients:36,waste:10,batchExtras:6,homeTimeHours:2,timeValue:18,servings:8,takeoutFood:18,delivery:4,tip:3,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:12},fields:fields.en,copy:{heading:'Meal prep vs takeout per-serving calculator',intro:'Compare like-for-like servings and show time value explicitly.',output1:'Home cost per serving',output2:'Takeout cost per serving',output3:'Monthly amount saved by home prep',verdictPositive:'Home prep is lower per comparable serving.',verdictNegative:'Takeout is lower per comparable serving.',privacy:'Cost scenario only; use official food-safety guidance for cooling, storage and reheating.'}},zh:{currency:'TWD' as const,defaults:{ingredients:1200,waste:10,batchExtras:200,homeTimeHours:3,timeValue:200,servings:10,takeoutFood:250,delivery:50,tip:0,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:20},fields:fields.zh,copy:{heading:'自煮備餐與外食每份成本計算器',intro:'比較同份量，時間價值另列，份數只算安全保存並吃完的餐。',output1:'自煮每份成本',output2:'外食每份成本',output3:'自煮每月差額',verdictPositive:'自煮每個同等份數較低。',verdictNegative:'外食每個同等份數較低。',privacy:'成本情境；冷卻、保存與復熱仍應依官方食安指引。'}},es:{currency:'EUR' as const,defaults:{ingredients:40,waste:10,batchExtras:6,homeTimeHours:2,timeValue:12,servings:8,takeoutFood:14,delivery:2.5,tip:1,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:12},fields:fields.es,copy:{heading:'Calculadora por ración: casa o pedido',intro:'Compara raciones equivalentes y muestra el valor del tiempo de forma explícita.',output1:'Coste en casa por ración',output2:'Coste del pedido por ración',output3:'Ahorro mensual cocinando',verdictPositive:'Cocinar cuesta menos por ración comparable.',verdictNegative:'Pedir cuesta menos por ración comparable.',privacy:'Escenario de costes; sigue las indicaciones oficiales para enfriar, conservar y recalentar.'}}};
export function getStaticPaths(){return ['en','zh','es'].map(locale=>({params:{locale}}));} const locale=Astro.params.locale as L,article=articles[locale],guide=mealPrepGuides[locale]!,calculator=calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={[locale]}>
 {locale==='en'&&<><p>Meal prep is not “ingredient receipt versus menu price.” The denominator is comparable servings actually eaten; the numerator includes waste, batch supplies and active time. Takeout also includes every fee, pickup and waiting.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>Batch only what the storage plan supports</h2><p>USDA says cooked leftovers generally keep three to four days refrigerated and can be frozen. Match batch size to the fridge/freezer plan; a discarded ninth serving is cost, not value.</p><h2>Keep cash and time in separate views</h2><p>Time can change the choice, but it is not automatically cash. Record the receipt-only result first, then test a time value that reflects what the saved hour would actually enable.</p><p class="privacy-note">General consumer education, not food-safety, nutrition, financial or product advice.</p></>}
 {locale==='zh'&&<><p>只拿食材發票比便當價格，通常會高估自煮優勢；但把整段週末都算成可接案時薪也會高估時間成本。先算現金，再用實際主動時間做獨立情境。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>份數必須真的安全吃完</h2><p>食藥署 2026 年大量備餐提醒：未食用完應在 2 小時內冷藏或冷凍，再吃前中心溫度達 70°C 以上。沒有冷藏空間或吃不完的盒數不能留在分母。</p><h2>外食也要算等候與交通</h2><p>外送費、服務費、自取油資停車與等待都屬選擇差額；兩邊同樣會花的吃飯時間則不要重複計入。</p><p class="privacy-note">一般消費教育資訊，不是食品安全、營養、財務或商品建議。</p></>}
 {locale==='es'&&<><p>La comparación útil no es ticket de supermercado contra precio de carta. Usa raciones equivalentes realmente comidas, merma y tiempo activo; al pedido añade todas las tarifas, desplazamiento y espera.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>El lote termina donde acaba el plan de frío</h2><p>AESAN recomienda refrigerar inmediatamente comida cocinada y sobras, no dejarlas más de dos horas y recalentarlas suficientemente. Una ración que no puede conservarse no abarata el lote.</p><h2>Comida de casa en la oficina</h2><p>La guía española aconseja bolsa isotérmica, refrigeración al llegar y recipiente apto para recalentar. Bolsa, envase y desplazamiento pertenecen al escenario si son incrementales.</p><p class="privacy-note">Información general; no es consejo alimentario, nutricional, financiero ni de producto.</p></>}
 <FAQ items={article.faq}/>
</ArticleLayout>
