---
import ArticleLayout from '../../layouts/ArticleLayout.astro'; import DecisionGuide from '../../components/DecisionGuide.astro'; import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro'; import FAQ from '../../components/FAQ.astro'; import { mealPrepGuides } from '../../data/decisionGuides'; import type { FaqItem } from '../../lib/seo';
type L='en'|'zh'|'es'|'fr'|'de';
const articles:Record<L,{title:string;description:string;faq:FaqItem[]}>= {
 en:{title:'Meal prep vs takeout cost: food, time, waste and delivery per serving',description:'Compare meal prep and takeout per equivalent serving with ingredient waste, batch time, delivery, tip, transport and waiting.',faq:[{question:'Should I count my cooking time?',answer:'Show cash-only and time-valued results separately. Time is an opportunity-cost scenario, not automatic lost wages.'},{question:'How do I count ingredient waste?',answer:'Increase ingredient cost by the portion routinely unused, and reduce servings when prepared food is discarded.'},{question:'What counts as a serving?',answer:'A portion actually eaten with comparable size, quality and nutrition—not every container filled.'},{question:'What takeout fees belong in the model?',answer:'Food, delivery, service fee, tip, pickup travel, parking and ordering or waiting time.'},{question:'Can meal prep servings stay in the denominator indefinitely?',answer:'No. Only safely cooled, stored and eaten portions count; follow food-specific official guidance.'}]},
 zh:{title:'自煮備餐還是外食？食材、時間、耗損與外送費計算器',description:'用同等每份比較自煮與外食，納入食材耗損、批次時間、容器能源、外送、交通與等待。',faq:[{question:'備餐時間要算錢嗎？',answer:'現金與含時間兩種結果分開看；時間價值是情境，不是沒叫外送就少領的薪水。'},{question:'食材耗損怎麼算？',answer:'把經常沒用完的食材加進成本，成品未吃完則直接減少實際份數。'},{question:'什麼才算一份？',answer:'份量、品質與營養相近且實際吃完的一餐，不是裝了幾個盒子。'},{question:'外食還要算什麼？',answer:'餐價、外送／服務費、小費、自取交通停車與下單等候時間。'},{question:'一次做很多份一定比較省嗎？',answer:'不一定；吃不完、冰箱放不下或無法安全保存時，分母會下降。'}]},
 es:{title:'Cocinar por lotes o pedir comida: coste por ración con tiempo y merma',description:'Compara ingredientes, merma, tiempo, energía y recipientes con comida, entrega, propina, transporte y espera.',faq:[{question:'¿Cuento el tiempo de cocinar?',answer:'Muestra efectivo y tiempo por separado; el tiempo es un escenario, no salario perdido automático.'},{question:'¿Cómo cuento la merma?',answer:'Aumenta ingredientes por lo que no se usa y reduce raciones por comida preparada que se tira.'},{question:'¿Qué es una ración comparable?',answer:'Una porción realmente consumida de tamaño, calidad y composición similares.'},{question:'¿Qué costes del pedido incluyo?',answer:'Comida, entrega, servicio, propina, transporte, aparcamiento y espera.'},{question:'¿Puedo contar todas las fiambreras?',answer:'Solo las raciones enfriadas, almacenadas y consumidas de forma segura.'}]},
 fr:{title:'Cuisiner en lot ou commander : coût par portion, temps et pertes',description:'Comparez ingrédients, pertes, temps, énergie et contenants avec repas, livraison, pourboire, trajet et attente.',faq:[{question:'Faut-il valoriser le temps de cuisine ?',answer:'Présentez dépenses et temps séparément ; le temps est un scénario, pas un salaire perdu automatique.'},{question:'Comment compter les pertes ?',answer:'Augmentez les ingrédients non utilisés et réduisez le nombre de portions si des plats sont jetés.'},{question:'Qu’est-ce qu’une portion comparable ?',answer:'Une portion réellement mangée de taille, qualité et composition proches.'},{question:'Quels frais de commande inclure ?',answer:'Repas, livraison, service, pourboire, déplacement, stationnement et attente.'},{question:'Combien de portions puis-je compter ?',answer:'Seulement celles refroidies, stockées et consommées selon les recommandations françaises.'}]},
 de:{title:'Meal Prep oder bestellen: Kosten je Portion mit Zeit und Verlust',description:'Vergleichen Sie Zutaten, Verlust, Zeit, Energie und Boxen mit Essen, Lieferung, Trinkgeld, Fahrt und Warten.',faq:[{question:'Soll Kochzeit bewertet werden?',answer:'Bargeld und Zeit getrennt zeigen; Zeit ist ein Szenario, nicht automatisch verlorener Lohn.'},{question:'Wie wird Verlust erfasst?',answer:'Nicht genutzte Zutaten erhöhen Kosten; weggeworfene fertige Mahlzeiten senken Portionen.'},{question:'Was ist eine vergleichbare Portion?',answer:'Eine tatsächlich gegessene Portion ähnlicher Größe, Qualität und Zusammensetzung.'},{question:'Welche Bestellkosten zählen?',answer:'Essen, Lieferung, Service, Trinkgeld, Abholung, Parken und Warten.'},{question:'Zählen alle gefüllten Boxen?',answer:'Nur richtig abgekühlte, gelagerte und tatsächlich gegessene Portionen.'}]}
};
const fields={en:[{key:'ingredients',label:'Ingredients for the batch',step:.01},{key:'waste',label:'Ingredient and serving waste (%)',step:.1},{key:'batchExtras',label:'Containers, energy and batch extras',step:.01},{key:'homeTimeHours',label:'Active home time (hours)',step:.05},{key:'timeValue',label:'Time value per hour',step:.01},{key:'servings',label:'Equivalent servings actually eaten'},{key:'takeoutFood',label:'Takeout food price',step:.01},{key:'delivery',label:'Delivery and service fees',step:.01},{key:'tip',label:'Tip',step:.01},{key:'transport',label:'Pickup travel and parking',step:.01},{key:'takeoutTimeHours',label:'Order/wait time (hours)',step:.05},{key:'takeoutServings',label:'Takeout servings'},{key:'mealsPerMonth',label:'Compared meals per month'}],zh:[{key:'ingredients',label:'整批食材成本',step:.1},{key:'waste',label:'食材與份數耗損（%）',step:.1},{key:'batchExtras',label:'容器、能源與批次額外成本',step:.1},{key:'homeTimeHours',label:'自煮主動時間（小時）',step:.05},{key:'timeValue',label:'每小時時間價值',step:.1},{key:'servings',label:'實際吃完的同等份數'},{key:'takeoutFood',label:'外食餐價',step:.1},{key:'delivery',label:'外送與服務費',step:.1},{key:'tip',label:'小費',step:.1},{key:'transport',label:'自取交通與停車',step:.1},{key:'takeoutTimeHours',label:'下單／等候時間（小時）',step:.05},{key:'takeoutServings',label:'外食份數'},{key:'mealsPerMonth',label:'每月比較餐數'}],es:[{key:'ingredients',label:'Ingredientes del lote',step:.01},{key:'waste',label:'Merma de ingredientes y raciones (%)',step:.1},{key:'batchExtras',label:'Recipientes, energía y extras',step:.01},{key:'homeTimeHours',label:'Tiempo activo en casa (horas)',step:.05},{key:'timeValue',label:'Valor de una hora',step:.01},{key:'servings',label:'Raciones equivalentes consumidas'},{key:'takeoutFood',label:'Precio de comida preparada',step:.01},{key:'delivery',label:'Entrega y servicio',step:.01},{key:'tip',label:'Propina',step:.01},{key:'transport',label:'Transporte y aparcamiento',step:.01},{key:'takeoutTimeHours',label:'Tiempo de pedido/espera',step:.05},{key:'takeoutServings',label:'Raciones del pedido'},{key:'mealsPerMonth',label:'Comidas comparadas al mes'}],fr:[{key:'ingredients',label:'Ingrédients du lot',step:.01},{key:'waste',label:'Pertes ingrédients et portions (%)',step:.1},{key:'batchExtras',label:'Contenants, énergie et extras',step:.01},{key:'homeTimeHours',label:'Temps actif maison (heures)',step:.05},{key:'timeValue',label:'Valeur d’une heure',step:.01},{key:'servings',label:'Portions comparables consommées'},{key:'takeoutFood',label:'Prix du repas commandé',step:.01},{key:'delivery',label:'Livraison et service',step:.01},{key:'tip',label:'Pourboire',step:.01},{key:'transport',label:'Transport et stationnement',step:.01},{key:'takeoutTimeHours',label:'Temps commande/attente',step:.05},{key:'takeoutServings',label:'Portions commandées'},{key:'mealsPerMonth',label:'Repas comparés par mois'}],de:[{key:'ingredients',label:'Zutaten des Kochlaufs',step:.01},{key:'waste',label:'Zutaten- und Portionsverlust (%)',step:.1},{key:'batchExtras',label:'Boxen, Energie und Extras',step:.01},{key:'homeTimeHours',label:'Aktive Kochzeit (Stunden)',step:.05},{key:'timeValue',label:'Zeitwert je Stunde',step:.01},{key:'servings',label:'Gegessene Vergleichsportionen'},{key:'takeoutFood',label:'Preis des bestellten Essens',step:.01},{key:'delivery',label:'Lieferung und Service',step:.01},{key:'tip',label:'Trinkgeld',step:.01},{key:'transport',label:'Abholung und Parken',step:.01},{key:'takeoutTimeHours',label:'Bestell-/Wartezeit',step:.05},{key:'takeoutServings',label:'Bestellte Portionen'},{key:'mealsPerMonth',label:'Verglichene Mahlzeiten/Monat'}]};
const calculators={en:{currency:'USD' as const,defaults:{ingredients:36,waste:10,batchExtras:6,homeTimeHours:2,timeValue:18,servings:8,takeoutFood:18,delivery:4,tip:3,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:12},fields:fields.en,copy:{heading:'Meal prep vs takeout per-serving calculator',intro:'Compare like-for-like servings and show time value explicitly.',output1:'Home cost per serving',output2:'Takeout cost per serving',output3:'Monthly amount saved by home prep',verdictPositive:'Home prep is lower per comparable serving.',verdictNegative:'Takeout is lower per comparable serving.',privacy:'Cost scenario only; use official food-safety guidance for cooling, storage and reheating.'}},zh:{currency:'TWD' as const,defaults:{ingredients:1200,waste:10,batchExtras:200,homeTimeHours:3,timeValue:200,servings:10,takeoutFood:250,delivery:50,tip:0,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:20},fields:fields.zh,copy:{heading:'自煮備餐與外食每份成本計算器',intro:'比較同份量，時間價值另列，份數只算安全保存並吃完的餐。',output1:'自煮每份成本',output2:'外食每份成本',output3:'自煮每月差額',verdictPositive:'自煮每個同等份數較低。',verdictNegative:'外食每個同等份數較低。',privacy:'成本情境；冷卻、保存與復熱仍應依官方食安指引。'}},es:{currency:'EUR' as const,defaults:{ingredients:40,waste:10,batchExtras:6,homeTimeHours:2,timeValue:12,servings:8,takeoutFood:14,delivery:2.5,tip:1,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:12},fields:fields.es,copy:{heading:'Calculadora por ración: casa o pedido',intro:'Compara raciones equivalentes y muestra el valor del tiempo de forma explícita.',output1:'Coste en casa por ración',output2:'Coste del pedido por ración',output3:'Ahorro mensual cocinando',verdictPositive:'Cocinar cuesta menos por ración comparable.',verdictNegative:'Pedir cuesta menos por ración comparable.',privacy:'Escenario de costes; sigue las indicaciones oficiales para enfriar, conservar y recalentar.'}},fr:{currency:'EUR' as const,defaults:{ingredients:42,waste:10,batchExtras:7,homeTimeHours:2,timeValue:15,servings:8,takeoutFood:15,delivery:3,tip:1.5,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:12},fields:fields.fr,copy:{heading:'Calculateur par portion : maison ou commande',intro:'Comparez des portions équivalentes et affichez séparément la valeur du temps.',output1:'Coût maison par portion',output2:'Coût commandé par portion',output3:'Économie mensuelle maison',verdictPositive:'La cuisine maison coûte moins par portion comparable.',verdictNegative:'La commande coûte moins par portion comparable.',privacy:'Scénario de coût ; respectez les consignes françaises de refroidissement et conservation.'}},de:{currency:'EUR' as const,defaults:{ingredients:45,waste:10,batchExtras:7,homeTimeHours:2,timeValue:16,servings:8,takeoutFood:16,delivery:3,tip:1.5,transport:0,takeoutTimeHours:.25,takeoutServings:1,mealsPerMonth:12},fields:fields.de,copy:{heading:'Portionsrechner: Meal Prep oder bestellen',intro:'Vergleichbare Portionen und Zeitwert ausdrücklich getrennt ansetzen.',output1:'Selbstgekocht je Portion',output2:'Bestellt je Portion',output3:'Monatlicher Vorteil Meal Prep',verdictPositive:'Selbstgekocht kostet je Vergleichsportion weniger.',verdictNegative:'Bestellen kostet je Vergleichsportion weniger.',privacy:'Kostenszenario; deutsche Hinweise zum Abkühlen, Lagern und Erhitzen beachten.'}}};
export function getStaticPaths(){return ['en','zh','es','fr','de'].map(locale=>({params:{locale}}));} const locale=Astro.params.locale as L,article=articles[locale],guide=mealPrepGuides[locale]!,calculator=calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={['en','zh','es','fr','de']}>
 {locale==='en'&&<><p>Meal prep is not “ingredient receipt versus menu price.” The denominator is comparable servings actually eaten; the numerator includes waste, batch supplies and active time. Takeout also includes every fee, pickup and waiting.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>Batch only what the storage plan supports</h2><p>USDA says cooked leftovers generally keep three to four days refrigerated and can be frozen. Match batch size to the fridge/freezer plan; a discarded ninth serving is cost, not value.</p><h2>Keep cash and time in separate views</h2><p>Time can change the choice, but it is not automatically cash. Record the receipt-only result first, then test a time value that reflects what the saved hour would actually enable.</p><p class="privacy-note">General consumer education, not food-safety, nutrition, financial or product advice.</p></>}
 {locale==='zh'&&<><p>只拿食材發票比便當價格，通常會高估自煮優勢；但把整段週末都算成可接案時薪也會高估時間成本。先算現金，再用實際主動時間做獨立情境。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>份數必須真的安全吃完</h2><p>食藥署 2026 年大量備餐提醒：未食用完應在 2 小時內冷藏或冷凍，再吃前中心溫度達 70°C 以上。沒有冷藏空間或吃不完的盒數不能留在分母。</p><h2>外食也要算等候與交通</h2><p>外送費、服務費、自取油資停車與等待都屬選擇差額；兩邊同樣會花的吃飯時間則不要重複計入。</p><p class="privacy-note">一般消費教育資訊，不是食品安全、營養、財務或商品建議。</p></>}
 {locale==='es'&&<><p>La comparación útil no es ticket de supermercado contra precio de carta. Usa raciones equivalentes realmente comidas, merma y tiempo activo; al pedido añade todas las tarifas, desplazamiento y espera.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>El lote termina donde acaba el plan de frío</h2><p>AESAN recomienda refrigerar inmediatamente comida cocinada y sobras, no dejarlas más de dos horas y recalentarlas suficientemente. Una ración que no puede conservarse no abarata el lote.</p><h2>Comida de casa en la oficina</h2><p>La guía española aconseja bolsa isotérmica, refrigeración al llegar y recipiente apto para recalentar. Bolsa, envase y desplazamiento pertenecen al escenario si son incrementales.</p><p class="privacy-note">Información general; no es consejo alimentario, nutricional, financiero ni de producto.</p></>}
 {locale==='fr'&&<><p>Le ticket d’ingrédients ne suffit pas : divisez toutes les dépenses et le temps actif par les portions comparables réellement mangées. La commande comprend aussi livraison, pourboire, trajet et attente.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>En France, dimensionner le lot sur 48 heures</h2><p>Le ministère de l’Agriculture recommande de consommer les restes maison au réfrigérateur au plus vite, au maximum sous 48 heures, et de ne pas attendre plus de deux heures avant réfrigération. Les portions au-delà exigent un plan de congélation adapté.</p><h2>Le froid disponible limite le rendement</h2><p>L’Anses situe la zone la plus froide entre 0 et 4°C et déconseille de surcharger le réfrigérateur. Une boîte qui ne peut pas refroidir correctement ne doit pas faire baisser le coût par portion.</p><p class="privacy-note">Information générale, pas un conseil alimentaire, nutritionnel, financier ou produit.</p></>}
 {locale==='de'&&<><p>Zutatenbon gegen Lieferpreis ist zu kurz. Teilen Sie Zutatenverlust, Boxen, Energie und aktive Zeit durch tatsächlich gegessene Vergleichsportionen; zur Bestellung kommen alle Gebühren und Wartewege.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="meal-prep-calculator" mode="meal" locale={locale} {...calculator}/><h2>Meal Prep nach Kühlkapazität planen</h2><p>Das BZfE empfiehlt, Speisen nach dem Kochen abzukühlen, luftdicht im Kühlschrank zu lagern und vor dem Essen gut zu erhitzen. Die einfache Hygienelehre nennt für selbst zubereitete Speisen ungefähr zwei Tage.</p><h2>Reste sind nur dann Ersparnis, wenn sie gegessen werden</h2><p>Plan, Einkaufsliste und flexible Zutaten können Verschwendung senken. Eine vergessene oder weggeworfene Portion ist jedoch Kostenbestandteil und keine zusätzliche Mahlzeit.</p><p class="privacy-note">Allgemeine Verbraucherbildung, keine Lebensmittel-, Ernährungs-, Finanz- oder Produktberatung.</p></>}
 <FAQ items={article.faq}/>
</ArticleLayout>
