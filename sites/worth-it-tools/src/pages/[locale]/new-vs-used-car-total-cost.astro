---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import NewUsedCarTcoCalculator from '../../components/NewUsedCarTcoCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { newUsedCarGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type EditorialLocale = 'en' | 'zh' | 'es' | 'fr' | 'de';

const articles: Record<EditorialLocale, { title: string; description: string; faq: FaqItem[] }> = {
  en: {
    title: 'New vs used car: compare depreciation, repairs, financing, and resale',
    description: 'Compare new and used car total cost over the same holding period, including fees, loan interest, repair risk, resale value and remaining balance at sale.',
    faq: [
      { question: 'Is buying a used car always cheaper than buying new?', answer: 'No. A lower purchase price can be offset by a higher APR, repairs, a short remaining warranty or weak resale. Compare both vehicles over the same holding period and test a major-repair scenario.' },
      { question: 'Why does the calculator show the loan balance at sale separately?', answer: 'If you sell before the loan ends, sale proceeds must first pay the outstanding balance. The balance is not a second ownership cost, but it changes how much cash you receive and whether the sale can close without bringing money.' },
      { question: 'How should I estimate used-car repair risk?', answer: 'Use the exact model, mileage, service records and an independent pre-purchase inspection. Enter an annual repair budget plus one plausible major repair and test both its probability-weighted value and the full downside.' },
      { question: 'Does a vehicle-history report replace a mechanic inspection?', answer: 'No. The FTC says history information is not a substitute for an independent inspection. Check title and mileage history, open recalls, warranty terms and the physical vehicle.' },
      { question: 'Should I compare car loans by monthly payment?', answer: 'Not by monthly payment alone. Compare APR, amount financed, finance charge, total payments, term, required add-ons and the balance that will remain at your planned sale date.' },
    ],
  },
  zh: {
    title: '新車還是中古車？折舊、維修、貸款與轉售怎麼比較',
    description: '以相同持有年限比較新車和中古車成交價、規費、貸款利息、維修風險、轉售價與賣車時未清償餘額。',
    faq: [
      { question: '中古車車價低就一定比較省嗎？', answer: '不一定。中古車可能有較高貸款利率、耗材與維修支出，也可能因事故、里程或車況影響轉售。要用相同持有年限比較完整成本。' },
      { question: '中古車重大維修機率要怎麼填？', answer: '這不是精準預測，而是壓力測試。依車型通病、里程、保養紀錄、第三方檢查與技師估價設定，並同時看期望值和完整維修真的發生的結果。' },
      { question: '監理里程紀錄可以證明沒有調表嗎？', answer: '它是重要核對線索，但不是完整保證。仍要比對定型化契約揭露、保養工單、車況報告、儀表與實車磨耗是否一致。' },
      { question: '為什麼賣車時貸款餘額要另外看？', answer: '持有成本已計入期間內利息；未清償本金不是再一次成本，但售車款必須先拿去清償，會影響能否順利過戶以及實際拿回多少現金。' },
