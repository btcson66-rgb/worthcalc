---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { raiseInflationGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type L = 'en' | 'zh' | 'es' | 'fr' | 'de';
const articles: Record<L, { title: string; description: string; faq: FaqItem[] }> = {
  en: { title: 'Pay raise vs inflation: did purchasing power increase?', description: 'Calculate exact real pay change with a matching CPI period, old-dollar purchasing power and clear gross-pay limits.', faq: [{ question: 'What is the exact real-raise formula?', answer: 'Divide one plus the raise rate by one plus the matching inflation rate, subtract one, then multiply by 100.' }, { question: 'Can I just subtract inflation from the raise?', answer: 'It is a close shortcut for small percentages, but the ratio formula is the exact compounded comparison.' }, { question: 'Which CPI number should I enter?', answer: 'Use an official CPI change with the same start and end boundary as the pay comparison and record whether it is annual average or month-over-month.' }, { question: 'Does CPI equal my cost of living?', answer: 'No. CPI reflects an average consumer basket; your housing, transport and family costs can move differently.' }, { question: 'Should I use gross or take-home pay?', answer: 'This page isolates gross purchasing power. Check take-home, benefits and hours separately before judging total compensation.' }] },
  zh: { title: '加薪有追上通膨嗎？計算實質購買力變化', description: '用同期間官方 CPI、精確比例公式與舊期購買力，判斷名目加薪後是否真的變富。', faq: [{ question: '實質加薪的精確公式是什麼？', answer: '（1＋加薪率）除以（1＋同期間通膨率），減 1 後乘 100。' }, { question: '加薪率減通膨率不行嗎？', answer: '小幅變動時可作近似，但精確結果要用比例公式。' }, { question: 'CPI 要填哪一個？', answer: '填與加薪起訖期間相同的主計總處官方漲幅，並註明同月年增、任兩月或全年平均。' }, { question: 'CPI 就是我的生活成本嗎？', answer: '不是；它是一般家庭平均消費籃，個人房租、交通與育兒比重可能不同。' }, { question: '這能代表實領薪資嗎？', answer: '不能；本頁先比較稅前固定薪資，扣繳、保費、獎金、工時與福利要另算。' }] },
  es: { title: 'Subida salarial e inflación: ¿aumentó tu poder adquisitivo?', description: 'Compara subida nominal e IPC del mismo periodo con fórmula real exacta y equivalente a precios anteriores.', faq: [{ question: '¿Cuál es la fórmula exacta?', answer: 'Divide uno más la subida entre uno más la inflación, resta uno y multiplica por 100.' }, { question: '¿Basta con restar IPC a subida?', answer: 'Sirve como aproximación con tasas pequeñas, pero la división compuesta es exacta.' }, { question: '¿Qué dato del IPC uso?', answer: 'El del INE para los mismos periodos salariales, indicando si es tasa interanual, media anual o variación entre meses.' }, { question: '¿El IPC es mi coste de vida?', answer: 'No. Resume una cesta representativa; tu patrón de vivienda, alimentación o transporte puede ser distinto.' }, { question: '¿Debo usar bruto o líquido?', answer: 'Esta comparación parte del bruto; revisa por separado IRPF, cotizaciones, jornada, bonus y beneficios.' }] },
  fr: { title: 'Hausse de salaire et inflation : votre pouvoir d’achat a-t-il augmenté ?', description: 'Calculez la hausse réelle exacte avec l’IPC Insee de la même période et l’équivalent aux prix antérieurs.', faq: [{ question: 'Quelle est la formule exacte ?', answer: 'Diviser un plus la hausse par un plus l’inflation, retirer un puis multiplier par 100.' }, { question: 'Peut-on simplement soustraire l’inflation ?', answer: 'C’est une approximation proche pour de petits taux ; le rapport composé donne le résultat exact.' }, { question: 'Quel IPC saisir ?', answer: 'La variation Insee correspondant aux mêmes dates que le salaire, avec le type de comparaison et la date de consultation.' }, { question: 'L’IPC mesure-t-il mon coût de la vie ?', answer: 'Non. Il mesure l’évolution moyenne d’un panier de consommation et non chaque budget personnel.' }, { question: 'Faut-il comparer le brut ou le net ?', answer: 'Le calcul isole le brut ; comparez aussi net, temps, primes, mutuelle et avantages.' }] },
  de: { title: 'Gehaltserhöhung und Inflation: Ist die Kaufkraft gestiegen?', description: 'Nominale Erhöhung und passenden Destatis-VPI exakt vergleichen und in Preisen der Vorperiode ausdrücken.', faq: [{ question: 'Wie lautet die exakte Formel?', answer: 'Eins plus Erhöhung durch eins plus Inflation teilen, eins abziehen und mit 100 multiplizieren.' }, { question: 'Reicht Erhöhung minus Inflation?', answer: 'Bei kleinen Raten ist das eine Näherung; der Quotient ist die exakte Aufzinsung.' }, { question: 'Welche Inflationsrate gehört hinein?', answer: 'Die amtliche VPI-Veränderung für dieselben Anfangs- und Endzeitpunkte, mit Periodenart und Abrufdatum.' }, { question: 'Ist der VPI meine persönliche Teuerung?', answer: 'Nein. Er nutzt einen durchschnittlich gewichteten Warenkorb.' }, { question: 'Brutto oder netto vergleichen?', answer: 'Der Rechner isoliert Brutto; Netto, Stunden, Bonus und Zusatzleistungen separat prüfen.' }] },
};
const fields = {
  en: [{ key: 'oldPay', label: 'Old gross pay', step: 1 }, { key: 'raiseRate', label: 'Nominal raise (%)', step: .1 }, { key: 'inflationRate', label: 'Matching CPI change (%)', step: .1 }],
  zh: [{ key: 'oldPay', label: '加薪前稅前薪資', step: 1 }, { key: 'raiseRate', label: '名目加薪率（%）', step: .1 }, { key: 'inflationRate', label: '同期間 CPI 漲幅（%）', step: .1 }],
  es: [{ key: 'oldPay', label: 'Salario bruto anterior', step: 1 }, { key: 'raiseRate', label: 'Subida nominal (%)', step: .1 }, { key: 'inflationRate', label: 'Variación IPC equivalente (%)', step: .1 }],
  fr: [{ key: 'oldPay', label: 'Ancien salaire brut', step: 1 }, { key: 'raiseRate', label: 'Hausse nominale (%)', step: .1 }, { key: 'inflationRate', label: 'Variation IPC correspondante (%)', step: .1 }],
  de: [{ key: 'oldPay', label: 'Altes Bruttogehalt', step: 1 }, { key: 'raiseRate', label: 'Nominale Erhöhung (%)', step: .1 }, { key: 'inflationRate', label: 'Passende VPI-Änderung (%)', step: .1 }],
};
const calculators = {
  en: { currency: 'USD' as const, defaults: { oldPay: 70000, raiseRate: 4, inflationRate: 5 }, fields: fields.en, copy: { heading: 'Real pay-raise calculator', intro: 'Enter an official CPI change covering the same period as the raise.', output1: 'New nominal pay', output2: 'Exact real change', output3: 'New pay in old-period dollars', verdictPositive: 'The nominal raise preserves or increases average CPI purchasing power.', verdictNegative: 'The nominal raise does not preserve average CPI purchasing power.', privacy: 'Gross-pay scenario only; no personal data leaves your browser.' } },
  zh: { currency: 'TWD' as const, defaults: { oldPay: 60000, raiseRate: 3, inflationRate: 2.6 }, fields: fields.zh, copy: { heading: '加薪後實質購買力計算器', intro: '請自行填入與加薪期間一致、已註明口徑與日期的官方 CPI。', output1: '加薪後名目薪資', output2: '精確實質變動', output3: '換成舊期物價的購買力', verdictPositive: '名目加薪已維持或增加平均 CPI 購買力。', verdictNegative: '名目加薪未維持平均 CPI 購買力。', privacy: '只比較稅前薪資情境，輸入不會離開瀏覽器。' } },
  es: { currency: 'EUR' as const, defaults: { oldPay: 30000, raiseRate: 3, inflationRate: 3.2 }, fields: fields.es, copy: { heading: 'Calculadora de subida real', intro: 'Introduce el IPC oficial del mismo inicio y final que la subida.', output1: 'Nuevo salario nominal', output2: 'Variación real exacta', output3: 'Salario nuevo a precios anteriores', verdictPositive: 'La subida mantiene o aumenta el poder adquisitivo medio según el IPC.', verdictNegative: 'La subida no mantiene el poder adquisitivo medio según el IPC.', privacy: 'Escenario de bruto; los datos no salen del navegador.' } },
  fr: { currency: 'EUR' as const, defaults: { oldPay: 36000, raiseRate: 2, inflationRate: 1.8 }, fields: fields.fr, copy: { heading: 'Calculateur de hausse réelle', intro: 'Saisissez l’IPC Insee couvrant exactement la même période.', output1: 'Nouveau salaire nominal', output2: 'Variation réelle exacte', output3: 'Salaire aux prix antérieurs', verdictPositive: 'La hausse maintient ou augmente le pouvoir d’achat moyen selon l’IPC.', verdictNegative: 'La hausse ne maintient pas le pouvoir d’achat moyen selon l’IPC.', privacy: 'Scénario sur salaire brut ; les données restent dans le navigateur.' } },
  de: { currency: 'EUR' as const, defaults: { oldPay: 48000, raiseRate: 2, inflationRate: 2.3 }, fields: fields.de, copy: { heading: 'Rechner für die reale Gehaltserhöhung', intro: 'Amtliche VPI-Änderung für denselben Anfang und dasselbe Ende eingeben.', output1: 'Neues Nominalgehalt', output2: 'Exakte reale Veränderung', output3: 'Gehalt in Preisen der Vorperiode', verdictPositive: 'Die Erhöhung erhält oder steigert die durchschnittliche VPI-Kaufkraft.', verdictNegative: 'Die Erhöhung erhält die durchschnittliche VPI-Kaufkraft nicht.', privacy: 'Bruttoszenario; Eingaben bleiben im Browser.' } },
};

export function getStaticPaths() { return ['en', 'zh', 'es', 'fr', 'de'].map((locale) => ({ params: { locale } })); }
const locale = Astro.params.locale as L;
const article = articles[locale];
const guide = raiseInflationGuides[locale]!;
const calculator = calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={['en', 'zh', 'es', 'fr', 'de']}>
  {locale === 'en' && <><p>A bigger number on the offer letter is nominal. To test purchasing power, align one pay period with one official CPI comparison and compound the two rates.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="raise-inflation-calculator" mode="raiseInflation" locale={locale} {...calculator}/><h2>Match BLS periods before calculating</h2><p>The BLS calculator uses calendar-year average CPI for completed years and the latest monthly index for the current year. If your raise begins in a particular month, obtain the CPI change for matching months instead of mixing it with an annual average.</p><h2>Keep compensation outside the CPI formula visible</h2><p>A promotion can change hours, bonus eligibility, health premiums, retirement match or tax withholding. The real-raise result answers one narrow question about gross base pay; it does not settle total compensation.</p><p class="privacy-note">General education, not individualized financial, tax or employment advice.</p></>}
  {locale === 'zh' && <><p>薪資單上的增加是名目值；要判斷是否真的變富，必須把同一起訖期間的固定薪資與官方 CPI 放進精確比例公式。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="raise-inflation-calculator" mode="raiseInflation" locale={locale} {...calculator}/><h2>先選口徑，再抄數字</h2><p>主計總處換算頁可以比較任兩時點，也能用全年平均。若加薪從 2025 年 7 月到 2026 年 7 月，就比較相同月份；不能拿單月月增率或別的起訖區間替代。</p><h2>平均 CPI 不等於個人帳單</h2><p>結果反映平均消費籃的購買力。租屋、通勤、育兒或醫療占比若特別高，應另做自己的固定支出前後表；也要把工時、獎金、勞退提撥與實領差額列在旁邊。</p><p class="privacy-note">一般教育資訊，不是個人化財務、稅務或勞資建議。</p></>}
  {locale === 'es' && <><p>Una subida en nómina es nominal. Para saber si mejora la capacidad de compra, compara el salario y el IPC oficial entre el mismo inicio y final.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="raise-inflation-calculator" mode="raiseInflation" locale={locale} {...calculator}/><h2>Elegir la serie correcta del INE</h2><p>El INE permite calcular entre meses y por ámbito. Conserva los dos periodos, el tipo de índice y la fecha de consulta; una tasa interanual no se sustituye por la variación mensual ni por otra comunidad.</p><h2>El bruto real no es el paquete completo</h2><p>IRPF, cotizaciones, jornada, variable, seguro y otros beneficios pueden cambiar a la vez. Anota esos efectos por separado antes de decidir si la oferta o promoción compensa.</p><p class="privacy-note">Información general, no asesoramiento financiero, fiscal o laboral individual.</p></>}
  {locale === 'fr' && <><p>La hausse inscrite sur le contrat est nominale. Pour tester le pouvoir d’achat, alignez le salaire et la variation officielle de l’IPC sur les mêmes dates.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="raise-inflation-calculator" mode="raiseInflation" locale={locale} {...calculator}/><h2>Identifier précisément l’indice Insee</h2><p>Depuis janvier 2026, l’IPC est publié en base 2025. Utilisez une variation officielle ou calculez un rapport entre indices compatibles ; notez population, territoire, produits inclus, périodes et date de consultation.</p><h2>Ne pas confondre IPC et budget personnel</h2><p>L’Insee distingue l’indice des prix du coût de la vie. Refaites en parallèle vos postes logement, transport et alimentation, puis examinez net, temps de travail, primes et avantages.</p><p class="privacy-note">Information générale, sans conseil financier, fiscal ou social individualisé.</p></>}
  {locale === 'de' && <><p>Die Zahl im Änderungsvertrag ist nominal. Für Kaufkraft müssen Grundgehalt und amtliche VPI-Veränderung genau dieselben Zeitpunkte abdecken.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="raise-inflation-calculator" mode="raiseInflation" locale={locale} {...calculator}/><h2>Vorjahresrate und Monatsrate trennen</h2><p>Destatis nennt die Veränderung gegenüber dem Vorjahresmonat oder Vorjahr Inflationsrate. Eine monatliche Bewegung beantwortet eine andere Frage; dokumentieren Sie Zeitraum, Datenstand und ob der Wert vorläufig ist.</p><h2>Den persönlichen Warenkorb danebenlegen</h2><p>Der VPI gewichtet rund 700 Güterarten im Durchschnitt. Miete, Energie und Mobilität können im eigenen Budget anders wirken; Netto, Arbeitszeit, Bonus und Zusatzleistungen ebenfalls separat vergleichen.</p><p class="privacy-note">Allgemeine Information, keine individuelle Finanz-, Steuer- oder Arbeitsberatung.</p></>}
  <FAQ items={article.faq}/>
</ArticleLayout>
