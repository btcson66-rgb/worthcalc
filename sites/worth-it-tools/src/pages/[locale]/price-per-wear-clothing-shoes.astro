---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { pricePerWearGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type L = 'en' | 'zh' | 'es' | 'fr' | 'de';
const articles: Record<L, { title: string; description: string; faq: FaqItem[] }> = {
  en: { title: 'Price per wear: compare clothing and shoes by actual use', description: 'Calculate clothing or shoe cost per actual wear after care, repair and net resale—not an imagined lifetime.', faq: [{ question: 'What is the price-per-wear formula?', answer: 'Purchase plus care and repair, minus net resale, divided by actual wears.' }, { question: 'Should I count planned wears?', answer: 'Use a conservative scenario or a wear log; do not present an aspirational lifetime as fact.' }, { question: 'How do I include resale?', answer: 'Use proceeds after selling fees, shipping, cleaning and likely discounts.' }, { question: 'Do laundry and dry cleaning count?', answer: 'Yes. Follow the care label and include regular care attributable to the item.' }, { question: 'Can I compare any two clothes?', answer: 'Only if they serve a comparable fit, safety, weather and occasion need.' }] },
  zh: { title: '每次穿著成本怎麼算？用真實次數比較衣服和鞋子', description: '把購入、洗燙、修補、淨轉售與實際穿著次數合併計算，不拿想像壽命美化結果。', faq: [{ question: '每次穿著成本公式是什麼？', answer: '購入加清潔維護、扣淨轉售，再除以實際穿著次數。' }, { question: '預計穿三年可以直接算嗎？', answer: '只能當敏感度情境；主結果應用已記錄或保守可達的次數。' }, { question: '轉售要填刊登價格嗎？', answer: '不是，要填扣除平台、運費、折價與整理後真的能拿到的淨額。' }, { question: '洗衣也要算嗎？', answer: '要，依洗標納入水洗、乾燥、熨燙或專業維護的可歸屬成本。' }, { question: '衣服鞋子都能互相比嗎？', answer: '只能比較同等場合、尺寸、保暖、安全與功能。' }] },
  es: { title: 'Coste por uso de ropa y calzado: comparar por veces reales', description: 'Suma compra, cuidado y reparación, resta reventa neta y divide por puestas reales para comparar sin marcas.', faq: [{ question: '¿Cuál es la fórmula?', answer: 'Compra más cuidado y reparación, menos reventa neta, dividido entre puestas reales.' }, { question: '¿Puedo usar las puestas que imagino?', answer: 'Solo como escenario; el resultado principal debe basarse en un registro o una previsión conservadora.' }, { question: '¿Qué reventa introduzco?', answer: 'El importe neto tras comisión, envío, preparación y descuento probable.' }, { question: '¿Cuenta la limpieza?', answer: 'Sí: lavado, secado, planchado o limpieza profesional según la etiqueta.' }, { question: '¿Sirve para comparar cualquier prenda?', answer: 'No; la función, talla, clima, seguridad y ocasión deben ser equivalentes.' }] },
  fr: { title: 'Coût par utilisation des vêtements et chaussures : usage réel', description: 'Additionnez achat, entretien et réparation, retirez la revente nette puis divisez par les ports réellement atteints.', faq: [{ question: 'Quelle est la formule ?', answer: 'Achat plus entretien et réparation, moins revente nette, divisé par les ports réels.' }, { question: 'Puis-je utiliser une durée prévue ?', answer: 'Seulement comme scénario ; le résultat principal doit utiliser un suivi ou une estimation prudente.' }, { question: 'Quelle revente saisir ?', answer: 'Le produit net après commission, envoi, nettoyage et remise probable.' }, { question: 'L’entretien est-il obligatoire en France ?', answer: 'L’étiquette de composition l’est ; l’entretien est facultatif mais fortement recommandé selon la DGCCRF.' }, { question: 'Peut-on comparer n’importe quels vêtements ?', answer: 'Non : taille, protection, saison et occasion doivent rendre les usages équivalents.' }] },
  de: { title: 'Kosten pro Tragen: Kleidung und Schuhe nach echter Nutzung vergleichen', description: 'Kauf plus Pflege und Reparatur, minus Nettoverkauf, geteilt durch reale Tragevorgänge – ohne Marken-Rangliste.', faq: [{ question: 'Wie lautet die Formel?', answer: 'Kauf plus Pflege und Reparatur, minus Netto-Wiederverkauf, geteilt durch tatsächliche Tragevorgänge.' }, { question: 'Darf ich geplante Nutzungen ansetzen?', answer: 'Nur als Szenario; das Hauptergebnis sollte auf einem Protokoll oder einer vorsichtigen Erwartung beruhen.' }, { question: 'Welchen Wiederverkauf trage ich ein?', answer: 'Den Nettoerlös nach Gebühren, Versand, Aufbereitung und realistischer Verhandlung.' }, { question: 'Zählt Pflege mit?', answer: 'Ja: Waschen, Trocknen, Bügeln, Reinigung und Reparatur, soweit dem Artikel zurechenbar.' }, { question: 'Belegt ein Siegel automatisch Langlebigkeit?', answer: 'Nein. Das Umweltbundesamt warnt vor diesem automatischen Schluss.' }] },
};

const fields = {
  en: [{ key: 'purchase', label: 'Purchase price', step: .01 }, { key: 'carePerWear', label: 'Care and repair per wear', step: .01 }, { key: 'wears', label: 'Actual wears' }, { key: 'resale', label: 'Net resale proceeds', step: .01 }, { key: 'alternativePricePerWear', label: 'Alternative cost per wear', step: .01 }],
  zh: [{ key: 'purchase', label: '實付購入價', step: 1 }, { key: 'carePerWear', label: '每次洗燙維護', step: 1 }, { key: 'wears', label: '實際穿著次數' }, { key: 'resale', label: '扣費後淨轉售', step: 1 }, { key: 'alternativePricePerWear', label: '替代方案每次成本', step: 1 }],
  es: [{ key: 'purchase', label: 'Precio de compra', step: .01 }, { key: 'carePerWear', label: 'Cuidado y arreglo por puesta', step: .01 }, { key: 'wears', label: 'Puestas reales' }, { key: 'resale', label: 'Reventa neta', step: .01 }, { key: 'alternativePricePerWear', label: 'Alternativa por uso', step: .01 }],
  fr: [{ key: 'purchase', label: 'Prix d’achat', step: .01 }, { key: 'carePerWear', label: 'Entretien et réparation par port', step: .01 }, { key: 'wears', label: 'Ports réels' }, { key: 'resale', label: 'Revente nette', step: .01 }, { key: 'alternativePricePerWear', label: 'Alternative par port', step: .01 }],
  de: [{ key: 'purchase', label: 'Kaufpreis', step: .01 }, { key: 'carePerWear', label: 'Pflege und Reparatur je Tragen', step: .01 }, { key: 'wears', label: 'Reale Tragevorgänge' }, { key: 'resale', label: 'Netto-Wiederverkauf', step: .01 }, { key: 'alternativePricePerWear', label: 'Alternative je Tragen', step: .01 }],
};
const calculators = {
  en: { currency: 'USD' as const, defaults: { purchase: 120, carePerWear: .8, wears: 80, resale: 20, alternativePricePerWear: 2.5 }, fields: fields.en, copy: { heading: 'Price-per-wear calculator', intro: 'Use logged or conservatively achievable wears and net resale after fees.', output1: 'This item per wear', output2: 'Alternative per wear', output3: 'Break-even wears', verdictPositive: 'This item costs less per actual wear.', verdictNegative: 'The alternative costs less per actual wear.', privacy: 'Values stay in your browser; no brand ranking is created.' } },
  zh: { currency: 'TWD' as const, defaults: { purchase: 3000, carePerWear: 30, wears: 60, resale: 600, alternativePricePerWear: 100 }, fields: fields.zh, copy: { heading: '衣鞋每次穿著成本計算器', intro: '使用保守可達或已記錄的次數，轉售填扣費淨額。', output1: '本品每次穿著', output2: '替代方案每次', output3: '損益穿著次數', verdictPositive: '本品依實際穿著成本較低。', verdictNegative: '替代方案依實際穿著成本較低。', privacy: '資料只在瀏覽器計算，不建立品牌排名。' } },
  es: { currency: 'EUR' as const, defaults: { purchase: 90, carePerWear: .6, wears: 60, resale: 15, alternativePricePerWear: 2.2 }, fields: fields.es, copy: { heading: 'Calculadora de coste por puesta', intro: 'Usa puestas alcanzables y reventa neta tras todos los gastos.', output1: 'Esta prenda por uso', output2: 'Alternativa por uso', output3: 'Puestas de equilibrio', verdictPositive: 'Esta opción cuesta menos por puesta real.', verdictNegative: 'La alternativa cuesta menos por puesta real.', privacy: 'Cálculo local; no crea clasificaciones de marcas.' } },
  fr: { currency: 'EUR' as const, defaults: { purchase: 110, carePerWear: 1.2, wears: 70, resale: 20, alternativePricePerWear: 2.8 }, fields: fields.fr, copy: { heading: 'Calculateur du coût par port', intro: 'Utilisez des ports atteignables et une revente nette de tous frais.', output1: 'Cet article par port', output2: 'Alternative par port', output3: 'Ports au seuil', verdictPositive: 'Cet article coûte moins par port réel.', verdictNegative: 'L’alternative coûte moins par port réel.', privacy: 'Calcul local ; aucune hiérarchie de marques.' } },
  de: { currency: 'EUR' as const, defaults: { purchase: 130, carePerWear: .7, wears: 100, resale: 25, alternativePricePerWear: 2.1 }, fields: fields.de, copy: { heading: 'Rechner für Kosten pro Tragen', intro: 'Erreichbare Nutzungen und Nettoverkauf nach allen Kosten verwenden.', output1: 'Dieser Artikel je Tragen', output2: 'Alternative je Tragen', output3: 'Tragevorgänge bis Gewinnschwelle', verdictPositive: 'Dieser Artikel kostet je tatsächlichem Tragen weniger.', verdictNegative: 'Die Alternative kostet je tatsächlichem Tragen weniger.', privacy: 'Lokale Berechnung; keine Marken-Rangliste.' } },
};

export function getStaticPaths() { return ['en', 'zh', 'es', 'fr', 'de'].map((locale) => ({ params: { locale } })); }
const locale = Astro.params.locale as L;
const article = articles[locale];
const guide = pricePerWearGuides[locale]!;
const calculator = calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={['en', 'zh', 'es', 'fr', 'de']}>
  {locale === 'en' && <><p>A low price tag can still be expensive if fit, care or occasion limits actual wear. Compare net ownership cost per logged wear; do not build a brand verdict from marketing promises.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="price-per-wear-calculator" mode="pricePerWear" locale={locale} {...calculator}/><h2>Read care before predicting durability</h2><p>The FTC requires care instructions to have a reasonable basis and remain legible through the product’s useful life. Dry cleaning, heat restrictions and component warnings can change both cost and the number of wears you can reach.</p><h2>Separate resale asking price from proceeds</h2><p>Use a conservative completed-sale amount after platform fees, shipping, cleaning and negotiation. If you cannot substantiate a buyer market, use zero and treat any later resale as upside.</p><p class="privacy-note">General consumer education, not financial, textile-care or product advice.</p></>}
  {locale === 'zh' && <><p>標價便宜不代表每次穿著便宜；尺寸、場合與洗燙限制會決定真的穿幾次。本頁只比較同等用途，不做品牌內容農場。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="price-per-wear-calculator" mode="pricePerWear" locale={locale} {...calculator}/><h2>先看洗標，再估耐用與維護</h2><p>台灣服飾標示基準要求標示水洗、漂白、乾燥、熨燙與專業維護。需乾洗、不可烘乾或不同部件要分開照護，都可能提高成本或降低實際穿著頻率。</p><h2>用成交淨額，不用刊登夢想價</h2><p>轉售要扣平台費、寄送、清潔、議價與滯銷風險。找不到可驗證的成交市場時填零，之後真的賣出再回填。</p><p class="privacy-note">一般消費教育資訊，不是財務、洗護或商品建議。</p></>}
  {locale === 'es' && <><p>Una etiqueta barata puede salir cara si la talla, el clima o el cuidado reducen las puestas. Esta página compara usos equivalentes y no fabrica páginas por marca.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="price-per-wear-calculator" mode="pricePerWear" locale={locale} {...calculator}/><h2>La conservación forma parte del coste</h2><p>La información oficial de Consumo distingue composición y conservación: lavado, planchado, limpieza en seco y secado. Esas condiciones influyen en el gasto y en la duración realmente alcanzable.</p><h2>Reventa neta, no precio anunciado</h2><p>Resta comisión, envío, preparación, negociación y riesgo de no vender. Si no puedes justificar un mercado real, usa cero para no abaratar artificialmente el resultado.</p><p class="privacy-note">Información general; no es consejo financiero, de cuidado textil ni de producto.</p></>}
  {locale === 'fr' && <><p>Un petit prix peut rester coûteux si la coupe, la saison ou l’entretien limitent les ports. Comparez le service réellement rendu, sans transformer une marque en mot-clé.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="price-per-wear-calculator" mode="pricePerWear" locale={locale} {...calculator}/><h2>Composition obligatoire, entretien facultatif</h2><p>La DGCCRF exige une composition lisible en français, tandis que l’étiquette d’entretien est facultative mais fortement conseillée. Son absence augmente l’incertitude : chiffrez prudemment nettoyage, séchage et risque d’endommagement.</p><h2>La conservation fait partie de la valeur</h2><p>Une pièce qui garde sa forme, se répare et trouve un acheteur peut atteindre plus de ports et une revente nette. Utilisez toutefois un montant après frais, pas le prix espéré d’une annonce.</p><p class="privacy-note">Information générale, sans conseil financier, textile ou produit.</p></>}
  {locale === 'de' && <><p>Ein günstiges Preisschild kann teuer werden, wenn Passform, Anlass oder Pflege die Nutzung begrenzen. Entscheidend sind protokollierte Tragevorgänge statt Markenversprechen.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="price-per-wear-calculator" mode="pricePerWear" locale={locale} {...calculator}/><h2>Langlebigkeit nicht aus einem Siegel ableiten</h2><p>Das Umweltbundesamt beschreibt Langlebigkeit bei Bekleidung als nicht einheitlich definiert. Prüfen Sie Nähte, Gewebefestigkeit, Sohle und Reparaturmöglichkeit und rechnen Sie mehrere erreichbare Nutzungszahlen.</p><h2>Weniger, aber richtig pflegen</h2><p>UBA empfiehlt, so oft wie nötig und so wenig wie möglich zu waschen. Pflegekosten und Lebensdauer hängen zusammen; beide gehören als Szenarien in die Entscheidung.</p><p class="privacy-note">Allgemeine Verbraucherinformation, keine Finanz-, Textilpflege- oder Produktempfehlung.</p></>}
  <FAQ items={article.faq}/>
</ArticleLayout>
