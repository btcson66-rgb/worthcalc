---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import FAQ from '../../components/FAQ.astro';
import RentBuyBreakevenCalculator from '../../components/RentBuyBreakevenCalculator.astro';
import type { Locale } from '../../consts';
import { rentBuyBreakevenGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type EditorialLocale = 'en' | 'zh' | 'es';

const articles: Record<EditorialLocale, { title: string; description: string; faq: FaqItem[] }> = {
  en: {
    title: 'How long do you need to stay before buying can beat renting?',
    description: 'Find the first rent-vs-buy break-even year after mortgage balance, closing and selling costs, maintenance, rent growth, appreciation and opportunity cost.',
    faq: [
      { question: 'Is five years always enough for buying to beat renting?', answer: 'No. Five years is a rule of thumb, not a result. Price growth, mortgage rate, purchase and sale costs, maintenance, comparable rent and opportunity return can move the crossover earlier, later or beyond the chosen horizon.' },
      { question: 'Why does the calculation subtract the mortgage balance at sale?', answer: 'The buyer must repay the outstanding loan from sale proceeds. Principal already repaid is not treated as a lost expense; it appears as additional equity recovered when the home is sold.' },
      { question: 'Do I count the entire mortgage payment as a cost?', answer: 'For cash flow, yes. For net economic cost, principal builds equity and is recovered through lower remaining debt. The yearly sale calculation prevents principal from being counted as both a payment and a permanent loss.' },
      { question: 'What if buying never breaks even in the calculator?', answer: 'Report that result for the selected horizon. Do not extend the stay or raise appreciation just to force a crossover. Test whether the inputs are realistic, then compare nonfinancial reasons separately.' },
      { question: 'Does a break-even year mean I should buy?', answer: 'No. It only identifies a modeled cost crossover. Affordability, reserves, job stability, mobility, repair risk, taxes and personal housing needs remain separate decisions.' },
    ],
  },
  zh: {
    title: '買房住幾年才可能比租屋划算？損益年分計算',
    description: '逐年比較房貸餘額、買賣成本、房屋稅與修繕、租金成長、房價變動及頭期款機會成本，找出首次損益交叉年。',
    faq: [
      { question: '台灣買房住滿六年就一定比租屋划算嗎？', answer: '不一定。連續持有、設籍並實際居住滿六年可能影響自住房地租稅優惠，但財務損益還取決於房價、利率、買賣費用、稅費、修繕、租金與頭期款機會報酬。' },
      { question: '為什麼不能把整筆房貸月付都當成本？', answer: '月付中的利息是成本，本金會降低房貸餘額並形成權益。計算器先記錄所有現金支出，再在預計出售年扣除清償房貸後可回收的淨售屋款，避免把本金重複算成損失。' },
      { question: '房地合一稅要填在哪裡？', answer: '頁內簡化計算器可把預估稅費合併進賣出成本率，但不會自動判斷自住、戶籍、出租、取得日或免稅條件。正式決策應以國稅局資料或專業試算換成實際金額。' },
      { question: '房價持平時 30 年都沒交叉代表什麼？', answer: '只代表這組房價、租金、利率、費用與機會報酬在 30 年內沒有讓買房淨成本低於租屋。不要把房價漲幅調高來製造答案，應檢查輸入並誠實保留「未交叉」。' },
      { question: '損益年分到了就應該買房嗎？', answer: '不是。它只回答模型中的成本何時交叉，不代表房貸負擔、現金預備、工作穩定、修繕風險或生活需求已經適合。' },
    ],
  },
  es: {
    title: 'Cuántos años debes quedarte para que comprar pueda ser mejor que alquilar',
    description: 'Calcula el primer año de equilibrio con capital pendiente, gastos de compra y venta, mantenimiento, alquiler, revalorización y coste de oportunidad.',
    faq: [
      { question: '¿Comprar siempre supera al alquiler después de cinco años?', answer: 'No. Cinco años no es una regla matemática. El cruce depende del tipo hipotecario, entrada, impuestos, gastos de compra y venta, mantenimiento, alquiler comparable, revalorización y rentabilidad alternativa.' },
      { question: '¿Por qué se descuenta el capital pendiente al vender?', answer: 'La deuda restante se cancela con el precio de venta. La parte de principal ya amortizada no desaparece: se refleja en un saldo menor y, por tanto, en más efectivo neto recuperado.' },
      { question: '¿Los gastos de la hipoteca son todos los gastos de comprar?', answer: 'No. Banco de España explica el reparto de formalización del préstamo, pero la compraventa añade impuestos, notaría, registro y otros importes según vivienda y comunidad autónoma. Deben registrarse por separado.' },
      { question: '¿Qué ocurre si no aparece equilibrio dentro del plazo?', answer: 'El resultado correcto es “no alcanzado” para esos supuestos. No aumentes la revalorización ni amplíes artificialmente la permanencia; revisa datos y compara estabilidad, movilidad y preferencias aparte.' },
      { question: '¿El año de equilibrio recomienda comprar?', answer: 'No. Es un cruce de costes simplificado. Cuota asumible, ahorro de emergencia, tipo variable, derramas, fiscalidad y cambios laborales requieren análisis adicional.' },
    ],
  },
};

const calculators = {
  en: {
    currency: 'USD' as const,
    defaults: { purchasePrice: 400000, downPayment: 80000, annualRate: 6.5, termYears: 30, buyingCosts: 12000, annualOwnerCosts: 6000, sellingCostRate: 5, appreciationRate: 2, monthlyRent: 2200, rentGrowthRate: 3, opportunityRate: 5, maxYears: 30 },
    copy: {
      heading: 'Rent-vs-buy break-even year calculator', intro: 'The calculator tests a sale at the end of each year and returns the first modeled crossover. Replace every example input with documents and local quotes.', purchasePrice: 'Home purchase price', downPayment: 'Down payment', annualRate: 'Mortgage rate (%)', termYears: 'Mortgage term (years)', buyingCosts: 'Upfront buying and loan costs', annualOwnerCosts: 'Annual tax, insurance, HOA and maintenance', sellingCostRate: 'Selling costs (% of future value)', appreciationRate: 'Annual home-price change (%)', monthlyRent: 'Comparable monthly rent', rentGrowthRate: 'Annual rent growth (%)', opportunityRate: 'Return on upfront cash (%)', maxYears: 'Maximum years to test', breakEvenYear: 'First break-even year', ownerCost: 'Owner net cost at shown year', renterCost: 'Renter net cost at shown year', ownerAdvantage: 'Modeled owner advantage', monthlyPayment: 'Scheduled mortgage payment', remainingBalance: 'Mortgage balance at shown year', yearUnit: 'years', noBreakEven: 'Not reached', verdictFound: 'Buying first moves below renting in', verdictMissing: 'No crossover found within', privacy: 'Inputs stay in your browser. Constant-rate, year-end sale and upfront-cash investment assumptions are simplified; this is not financial, mortgage, tax, legal or real-estate advice.',
    },
  },
  zh: {
    currency: 'TWD' as const,
    defaults: { purchasePrice: 15000000, downPayment: 3000000, annualRate: 2.2, termYears: 30, buyingCosts: 450000, annualOwnerCosts: 200000, sellingCostRate: 4, appreciationRate: 1.5, monthlyRent: 38000, rentGrowthRate: 2, opportunityRate: 4, maxYears: 30 },
    copy: {
      heading: '租屋買房損益年分計算器', intro: '計算器假設每年年底出售，逐年尋找第一次成本交叉。所有數字都是示範輸入，請改成核貸、稅費、修繕與可比租金的實際資料。', purchasePrice: '房屋成交總價', downPayment: '頭期款', annualRate: '房貸年利率（%）', termYears: '房貸年限', buyingCosts: '契稅、規費、代書、仲介與貸款前期成本', annualOwnerCosts: '每年房屋稅、地價稅、管理、保險與修繕', sellingCostRate: '賣出成本占未來售價（%）', appreciationRate: '房價年變動率（%）', monthlyRent: '同條件房屋月租', rentGrowthRate: '租金年增率（%）', opportunityRate: '前期現金機會報酬率（%）', maxYears: '最多測試年數', breakEvenYear: '首次損益交叉年', ownerCost: '該年買房淨成本', renterCost: '該年租屋淨成本', ownerAdvantage: '模型中的買房成本優勢', monthlyPayment: '估算房貸月付', remainingBalance: '該年房貸餘額', yearUnit: '年', noBreakEven: '尚未交叉', verdictFound: '買房淨成本首次低於租屋在第', verdictMissing: '在測試年限內沒有交叉；年限為', privacy: '輸入只留在瀏覽器。固定利率、年底出售、賣出成本率與只投資前期現金都是簡化假設；不構成購屋、投資、貸款、稅務、法律或房仲建議。',
    },
  },
  es: {
    currency: 'EUR' as const,
    defaults: { purchasePrice: 240000, downPayment: 48000, annualRate: 3.25, termYears: 30, buyingCosts: 24000, annualOwnerCosts: 3000, sellingCostRate: 5, appreciationRate: 1.5, monthlyRent: 1000, rentGrowthRate: 2, opportunityRate: 4, maxYears: 30 },
    copy: {
      heading: 'Calculadora del año de equilibrio entre comprar y alquilar', intro: 'Se simula una venta al final de cada año y se muestra el primer cruce. Sustituye impuestos, escritura, FEIN, comunidad, mantenimiento y alquiler por datos reales.', purchasePrice: 'Precio de compra de la vivienda', downPayment: 'Entrada', annualRate: 'TIN hipotecario (%)', termYears: 'Plazo de la hipoteca (años)', buyingCosts: 'Impuestos y gastos iniciales de compraventa e hipoteca', annualOwnerCosts: 'IBI, seguro, comunidad y mantenimiento al año', sellingCostRate: 'Coste de venta sobre valor futuro (%)', appreciationRate: 'Cambio anual del precio (%)', monthlyRent: 'Alquiler mensual comparable', rentGrowthRate: 'Subida anual del alquiler (%)', opportunityRate: 'Rentabilidad del efectivo inicial (%)', maxYears: 'Máximo de años analizados', breakEvenYear: 'Primer año de equilibrio', ownerCost: 'Coste neto de compra en ese año', renterCost: 'Coste neto de alquiler en ese año', ownerAdvantage: 'Ventaja modelizada de compra', monthlyPayment: 'Cuota hipotecaria estimada', remainingBalance: 'Capital pendiente en ese año', yearUnit: 'años', noBreakEven: 'No alcanzado', verdictFound: 'Comprar queda por debajo por primera vez en', verdictMissing: 'No se encuentra cruce dentro de', privacy: 'Los datos permanecen en el navegador. Tipo constante, venta a fin de año e inversión solo del efectivo inicial son simplificaciones; no es asesoramiento financiero, hipotecario, fiscal, jurídico o inmobiliario.',
    },
  },
};

export function getStaticPaths() {
  return (['en', 'zh', 'es'] as Locale[]).map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: EditorialLocale };
const article = articles[locale];
const guide = rentBuyBreakevenGuides[locale];
const calculator = calculators[locale];
if (!guide) throw new Error(`Missing rent-buy break-even guide for ${locale}`);
---

<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={[locale]}>
  {locale === 'en' && <>
    <p>A five-year rule cannot know your closing cash, mortgage balance, repair history or likely sale cost. The practical question is conditional: if you sell at the end of year one, two, three and so on, when does the net owner cost first fall below the net cost of the comparable rental?</p>
    <p>The CFPB explicitly connects rent-versus-buy tradeoffs to how long you expect to stay and warns that calculators must assume future home-price growth. A useful result therefore names the assumptions and can honestly return “not reached.”</p>
    <DecisionGuide content={guide} />
    <RentBuyBreakevenCalculator locale={locale} {...calculator} />

    <h2>Reconstruct the cash you recover at each exit year</h2>
    <p>Start with projected home value, subtract selling costs, then subtract the mortgage balance for that year. This is net sale proceeds. Do not label every principal dollar in the mortgage payment as lost: principal lowers the remaining loan and comes back as equity if the sale price supports it. Interest, by contrast, is not recovered.</p>
    <p>Use the amortization schedule from the actual offer when possible. The simplified calculator assumes a constant rate and monthly payment. Adjustable rates, interest-only periods, extra principal and prepayment penalties need their own year-by-year balance.</p>

    <h2>Use cash to close, not a generic closing-cost percentage</h2>
    <p>The Closing Disclosure separates closing costs from total cash to close. For the model, record the down payment and every purchase cost you actually fund, but do not count the same charge twice. Taxes, title and settlement services, points, prepaid items and lender credits can change the first-year disadvantage materially.</p>
    <p>Selling is another transaction, not a reversal of the purchase. Model agent compensation, transfer or recording costs, concessions, repairs, moving and any loan payoff charge from quotes appropriate to your market and contract.</p>

    <h2>Owner carrying costs can move the crossover every year</h2>
    <p>Property tax, homeowners insurance, association dues and necessary maintenance continue after closing. A smooth annual allowance is useful for sensitivity, but an aging roof, deductible after a loss or special assessment can concentrate several years of costs at once. Run a second scenario with the known major project in its likely year.</p>
    <p>Keep utilities and services paid in both homes outside both sides, or include them symmetrically. Compare the same housing level: a larger purchased home and a smaller rental combine a lifestyle upgrade with a financing choice.</p>

    <h2>Let zero appreciation and a later sale challenge the answer</h2>
    <p>The base example crosses in year 7, but zero appreciation moves it to year 16. That gap is the point of the page. Test price decline, stability and moderate growth, along with multiple sale-cost and repair cases. Opportunity return should match an investment the renter could actually hold after fees and taxes.</p>
    <p>If a move is plausible before the modeled crossover, report that mismatch. If no crossover appears inside the realistic horizon, keep the result. Stability, control of the home and protection from rent changes may still matter, but they are benefits to value explicitly rather than reasons to alter the financial inputs.</p>
    <p class="privacy-note">General educational model only. Confirm the Loan Estimate, Closing Disclosure, taxes, insurance, inspection, sale costs and legal terms with qualified sources. WorthCalc does not predict prices or provide personalized financial advice.</p>
  </>}

  {locale === 'zh' && <>
    <p>「買房至少住五年」和「自住滿六年」是兩種不同概念。前者只是常見口訣，後者可能牽涉台灣自住房地租稅條件；兩者都不會自動算出你的房貸利息、房貸餘額、買賣費用、修繕與租金。</p>
    <p>真正的問題是：若分別在第 1 年、第 2 年到第 30 年出售，哪一年清償房貸並扣除賣出成本後，買房淨成本第一次不高於租屋？這一頁逐年找交叉，而不是先決定答案再挑假設。</p>
    <DecisionGuide content={guide} />
    <RentBuyBreakevenCalculator locale={locale} {...calculator} />

    <h2>六年租稅門檻不等於六年回本</h2>
    <p>我的 E 政府 2026 年整理指出，自住房地優惠涉及本人或家屬設籍、連續持有並實際居住滿六年、期間未出租或營業，以及使用次數等條件。房屋稅、地價稅、土地增值稅與房地合一稅也有不同課稅基礎。模型不能把「第六年」直接改成免稅。</p>
    <p>正式試算應依取得日、用途、戶籍、成交所得與可列成本計算可能稅額，再放進對應出售年。頁內計算器只提供合併賣出成本率，適合先測敏感度，不適合取代申報判定。</p>

    <h2>用房貸餘額還原賣掉後真正拿回的錢</h2>
    <p>每個出售年的淨售屋款等於當年估計房價，扣除賣出費用與尚未清償的房貸。本金月付不是完全消失的成本，因為它會降低房貸餘額；但若房價下跌或賣出費很高，可回收權益仍可能低於投入現金。</p>
    <p>寬限期、機動利率、提前清償違約金與額外還本都會改變餘額曲線。應用銀行攤還表取代固定利率示範，並在寬限期結束或利率重訂後重新跑結果。</p>

    <h2>買入現金與每年持有成本都要用實際單據</h2>
    <p>頭期款之外，契稅按契價而不是成交總價計算；另有印花稅、代書、規費、仲介與貸款相關成本。財政部也列出部分取得房地前必要費用可作房地交易成本，但能否列報與證明文件應依個案確認。</p>
    <p>持有期間要加入房屋稅、地價稅、管理費、保險與必要修繕。裝潢若純屬個人偏好，可分開呈現；已知的外牆、防水、電梯或管線工程不能只用低比例平均掩蓋。</p>

    <h2>實價登錄只能幫你找可比資料，不能預測未來</h2>
    <p>用實價登錄篩選相同生活圈、坪數、屋齡、樓層與車位條件，再把車位價格與管理費口徑對齊。租金也應來自真正可替代的住宅，不能用較小、較遠或屋況較差的房子讓租屋看起來便宜。</p>
    <p>基準算例第 9 年才交叉，房價持平則 30 年內沒有交叉。這不是預測，而是提醒：同一組租金在不同房價路徑下會得到完全不同答案。至少保留房價下跌、持平、溫和成長和重大修繕四個情境。</p>
    <p class="privacy-note">本頁是一般教育模型，不提供個人購屋、投資、貸款、稅務、法律或房仲建議。請用契約、核貸文件、稅務資料與專業報價替換示範值；輸入資料只在瀏覽器處理。</p>
  </>}

  {locale === 'es' && <>
    <p>La frase “si te quedas cinco años, comprar compensa” ignora que cada vivienda tiene otra entrada, impuestos, comunidad, hipoteca y coste de salida. El cálculo útil simula la venta al final de cada año y busca la primera fecha en que el coste neto de comprar deja de superar al de alquilar.</p>
    <p>Ese año no es una promesa de mercado. Debe cambiar cuando cambian el TIN, la revalorización, la comunidad autónoma, la compensación por cancelación, una derrama o el alquiler de una vivienda realmente equivalente.</p>
    <DecisionGuide content={guide} />
    <RentBuyBreakevenCalculator locale={locale} {...calculator} />

    <h2>Separar la compraventa de la formalización hipotecaria</h2>
    <p>Banco de España explica que, para hipotecas sujetas a la Ley 5/2019, el cliente paga la tasación y la entidad asume determinados gastos de notaría, registro, impuestos y gestoría de la formalización del préstamo. Eso no elimina los gastos propios de comprar la vivienda.</p>
    <p>El Notariado distingue impuestos y minutas de la compraventa. Vivienda nueva o usada, comunidad autónoma y pacto determinan IVA o ITP, AJD y otros importes. Introduce el efectivo de tu escritura y presupuesto, no un porcentaje nacional que mezcle préstamo y adquisición.</p>

    <h2>La cuota contiene capital y los intereses dependen del saldo</h2>
    <p>En el sistema francés, una parte de la cuota amortiza capital y otra paga intereses; al principio pesa más el interés. Para cada año de salida, resta del valor neto de venta el capital pendiente. Así, el principal amortizado aparece como más patrimonio y no como una pérdida duplicada.</p>
    <p>Una hipoteca variable necesita varios tramos de tipo. Si la venta exige cancelación total, revisa la compensación aplicable según fecha, contrato, modalidad y momento. Añádela al coste de salida en el año correspondiente.</p>

    <h2>IBI, comunidad, seguro y derramas pueden retrasar el cruce</h2>
    <p>Usa recibos, actas y presupuestos. Una media anual puede servir para mantenimiento ordinario, pero una fachada, ascensor o cubierta concentra el gasto. Ejecuta un escenario con la derrama conocida y otro con una reserva prudente; no confíes en que toda reforma aumente el precio euro por euro.</p>
    <p>En alquiler, conserva solo los gastos propios del inquilino. Suministros y servicios presentes en ambos casos se excluyen o se ponen en las dos columnas. Alinea barrio, superficie, garaje, estado y eficiencia para no comparar dos niveles de vivienda.</p>

    <h2>Un margen de 69 euros no es un equilibrio robusto</h2>
    <p>En el escenario base el primer cruce aparece en el año 9. Subir el coste de venta del 5% al 7% mantiene el año, pero deja solo 69 € de margen: redondeos, una reparación o un mes vacío lo eliminan. El resultado debe mostrar tanto el año como la diferencia.</p>
    <p>Con precio estable, el cruce se desplaza al año 17; con alquiler de 1.200 €, al año 6. Prueba caídas, estabilidad y subida moderada, además de varios tipos y costes. Si tu permanencia realista termina antes, la respuesta financiera del modelo es que comprar no alcanza el equilibrio dentro de tu horizonte.</p>
    <p class="privacy-note">Modelo educativo general, sin recomendación personalizada. Confirma FEIN, FiAE, escritura, impuestos, capital pendiente, comunidad, seguro y costes de venta con documentos y profesionales cualificados. Los datos permanecen en el navegador.</p>
  </>}

  <FAQ items={article.faq} />
</ArticleLayout>
