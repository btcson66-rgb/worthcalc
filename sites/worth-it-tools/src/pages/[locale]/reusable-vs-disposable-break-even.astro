---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { reusableGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type L = 'en' | 'zh' | 'es' | 'fr' | 'de';
const articles: Record<L, { title: string; description: string; faq: FaqItem[] }> = {
  en: { title: 'Reusable vs disposable break-even: cost per actual use', description: 'Calculate when reusable beats disposable after purchase, cleaning, consumables, actual life and comparable performance.', faq: [{ question: 'What is the reusable break-even formula?', answer: 'Initial cost divided by disposable cost per use minus reusable cleaning and consumables per use.' }, { question: 'Do cleaning costs matter?', answer: 'Yes. Include product-appropriate water, energy and cleaner rather than assuming zero.' }, { question: 'Which use count should I enter?', answer: 'Actual expected uses before loss, damage, hygiene retirement or replacement—not the advertised maximum.' }, { question: 'Does financial break-even prove environmental benefit?', answer: 'No. Environmental claims require product-specific evidence and lifecycle boundaries.' }, { question: 'What if variable reusable cost exceeds disposable?', answer: 'There is no financial break-even under those inputs, regardless of the use count.' }] },
  zh: { title: '重複使用或一次性用品：真正回本次數與每次成本', description: '把購入、清洗、耗材、實際壽命與一次性單價放入同一模型；不做無來源環境結論。', faq: [{ question: '回本公式是什麼？', answer: '初始成本除以「一次性每次成本減去重複用品每次清洗與耗材」。' }, { question: '清洗成本一定要算嗎？', answer: '要，依商品指示納入水、電與清潔劑，不可一律設零。' }, { question: '次數要填設計壽命嗎？', answer: '填遺失、損壞或衛生汰換前真的可能使用次數。' }, { question: '金錢回本就比較環保嗎？', answer: '不能這樣推論；環境結論需要產品別與完整生命週期證據。' }, { question: '每次變動成本比一次性還高呢？', answer: '在該組輸入下沒有金錢回本點，增加使用次數也不會改變。' }] },
  es: { title: 'Reutilizable o desechable: coste por uso y punto de equilibrio real', description: 'Calcula compra, limpieza, consumibles, vida real y desechable equivalente sin inventar beneficios ambientales.', faq: [{ question: '¿Cuál es la fórmula de equilibrio?', answer: 'Coste inicial dividido entre coste desechable por uso menos limpieza y consumibles reutilizables por uso.' }, { question: '¿Incluyo limpieza?', answer: 'Sí, con agua, energía y producto según instrucciones, no cero por defecto.' }, { question: '¿Qué número de usos pongo?', answer: 'Usos reales antes de perder, romper o retirar por higiene, no el máximo publicitario.' }, { question: '¿Equilibrio económico significa ventaja ambiental?', answer: 'No. Hace falta evidencia específica y límites de ciclo de vida.' }, { question: '¿Y si el variable reutilizable supera al desechable?', answer: 'No existe equilibrio económico con esos datos.' }] },
  fr: { title: 'Réutilisable ou jetable : coût par usage et vrai seuil de rentabilité', description: 'Calculez achat, lavage, consommables et durée réellement atteinte, sans généraliser une promesse écologique.', faq: [{ question: 'Quelle est la formule du seuil ?', answer: 'Prix initial divisé par le coût jetable par usage moins lavage et consommables du réutilisable par usage.' }, { question: 'Faut-il compter le lavage ?', answer: 'Oui : eau, énergie et produit selon le protocole du produit, sans mettre zéro par défaut.' }, { question: 'Quel nombre d’usages saisir ?', answer: 'Le nombre vraisemblable avant perte, casse ou retrait pour hygiène, et non la durée maximale annoncée.' }, { question: 'Quatre usages suffisent-ils toujours ?', answer: 'Non. Le résultat ADEME cité porte sur les emballages en verre consignés étudiés, pas sur tout réutilisable.' }, { question: 'Le seuil financier prouve-t-il un bénéfice environnemental ?', answer: 'Non. Il faut une analyse propre au produit, au lavage, au transport et à la fin de vie.' }] },
  de: { title: 'Mehrweg oder Einweg: Kosten je Nutzung und echte Gewinnschwelle', description: 'Berechnen Sie Kauf, Spülen, Verbrauchsteile und reale Lebensdauer ohne pauschales Umweltversprechen.', faq: [{ question: 'Wie lautet die Gewinnschwellen-Formel?', answer: 'Anschaffung geteilt durch Einwegkosten je Nutzung minus Spül- und Verbrauchskosten von Mehrweg je Nutzung.' }, { question: 'Muss ich Spülkosten eintragen?', answer: 'Ja, mit Wasser, Energie und Reiniger nach Produktvorgabe statt pauschal null.' }, { question: 'Welche Nutzungszahl ist realistisch?', answer: 'Die erwartbaren Nutzungen bis Verlust, Bruch oder hygienischer Ausmusterung, nicht das Werbe-Maximum.' }, { question: 'Gelten Flaschen-Umläufe für jeden Mehrwegartikel?', answer: 'Nein. UBA-Angaben zu Glas- und PET-Mehrwegflaschen sind produktspezifisch.' }, { question: 'Beweist eine finanzielle Gewinnschwelle den Umweltvorteil?', answer: 'Nein. Dafür braucht es eine konkrete Bilanz von Herstellung, Spülen, Transport und Entsorgung.' }] },
};

const fields = {
  en: [{ key: 'initial', label: 'Reusable purchase and accessories', step: .01 }, { key: 'cleaning', label: 'Cleaning cost per use', step: .01 }, { key: 'consumables', label: 'Reusable consumables per use', step: .01 }, { key: 'uses', label: 'Actual lifetime uses' }, { key: 'disposablePerUse', label: 'Disposable cost per equivalent use', step: .01 }],
  zh: [{ key: 'initial', label: '重複用品購入與配件', step: .1 }, { key: 'cleaning', label: '每次清洗成本', step: .1 }, { key: 'consumables', label: '每次專屬耗材', step: .1 }, { key: 'uses', label: '實際壽命使用次數' }, { key: 'disposablePerUse', label: '一次性每個同等用途成本', step: .1 }],
  es: [{ key: 'initial', label: 'Compra y accesorios reutilizables', step: .01 }, { key: 'cleaning', label: 'Limpieza por uso', step: .01 }, { key: 'consumables', label: 'Consumibles reutilizables por uso', step: .01 }, { key: 'uses', label: 'Usos reales de vida' }, { key: 'disposablePerUse', label: 'Desechable por uso equivalente', step: .01 }],
  fr: [{ key: 'initial', label: 'Achat et accessoires réutilisables', step: .01 }, { key: 'cleaning', label: 'Lavage par usage', step: .01 }, { key: 'consumables', label: 'Consommables réutilisables par usage', step: .01 }, { key: 'uses', label: 'Usages réels atteints' }, { key: 'disposablePerUse', label: 'Jetable par usage équivalent', step: .01 }],
  de: [{ key: 'initial', label: 'Mehrweg-Kauf samt Zubehör', step: .01 }, { key: 'cleaning', label: 'Spülkosten je Nutzung', step: .01 }, { key: 'consumables', label: 'Mehrweg-Verbrauchsteile je Nutzung', step: .01 }, { key: 'uses', label: 'Reale Nutzungen' }, { key: 'disposablePerUse', label: 'Einwegkosten je gleiche Nutzung', step: .01 }],
};

const calculators = {
  en: { currency: 'USD' as const, defaults: { initial: 25, cleaning: .15, consumables: .05, uses: 100, disposablePerUse: .5 }, fields: fields.en, copy: { heading: 'Reusable break-even calculator', intro: 'Use actual life and product-appropriate cleaning.', output1: 'Reusable cost per use', output2: 'Disposable cost per use', output3: 'Break-even uses', verdictPositive: 'Reusable is financially lower at this use count.', verdictNegative: 'Disposable is financially lower at this use count.', privacy: 'Financial model only; no environmental benefit is inferred.' } },
  zh: { currency: 'TWD' as const, defaults: { initial: 600, cleaning: 3, consumables: 2, uses: 100, disposablePerUse: 12 }, fields: fields.zh, copy: { heading: '重複使用真正回本計算器', intro: '使用實際壽命，清洗成本依商品指示估算。', output1: '重複用品每次成本', output2: '一次性每次成本', output3: '損益使用次數', verdictPositive: '此使用次數下重複用品金錢較省。', verdictNegative: '此使用次數下一次性用品金錢較省。', privacy: '僅為金錢模型，不推論環境效益。' } },
  es: { currency: 'EUR' as const, defaults: { initial: 18, cleaning: .12, consumables: .08, uses: 100, disposablePerUse: .4 }, fields: fields.es, copy: { heading: 'Calculadora de equilibrio reutilizable', intro: 'Usa vida real y limpieza adecuada al producto.', output1: 'Coste reutilizable por uso', output2: 'Coste desechable por uso', output3: 'Usos de equilibrio', verdictPositive: 'El reutilizable cuesta menos con estos usos.', verdictNegative: 'El desechable cuesta menos con estos usos.', privacy: 'Solo modelo económico; no se infiere beneficio ambiental.' } },
  fr: { currency: 'EUR' as const, defaults: { initial: 20, cleaning: .18, consumables: .07, uses: 80, disposablePerUse: .55 }, fields: fields.fr, copy: { heading: 'Calculateur du seuil réutilisable', intro: 'Saisissez la durée réellement atteinte et le lavage propre au produit.', output1: 'Coût réutilisable par usage', output2: 'Coût jetable par usage', output3: 'Usages au seuil', verdictPositive: 'Le réutilisable coûte moins avec ce nombre d’usages.', verdictNegative: 'Le jetable coûte moins avec ce nombre d’usages.', privacy: 'Modèle financier uniquement ; aucun bénéfice environnemental n’est déduit.' } },
  de: { currency: 'EUR' as const, defaults: { initial: 22, cleaning: .16, consumables: .06, uses: 100, disposablePerUse: .48 }, fields: fields.de, copy: { heading: 'Mehrweg-Gewinnschwellenrechner', intro: 'Reale Lebensdauer und produkttaugliches Spülen eintragen.', output1: 'Mehrwegkosten je Nutzung', output2: 'Einwegkosten je Nutzung', output3: 'Nutzungen bis Gewinnschwelle', verdictPositive: 'Mehrweg kostet bei dieser Nutzungszahl weniger.', verdictNegative: 'Einweg kostet bei dieser Nutzungszahl weniger.', privacy: 'Nur Finanzmodell; kein pauschaler Umweltvorteil wird abgeleitet.' } },
};

export function getStaticPaths() { return ['en', 'zh', 'es', 'fr', 'de'].map((locale) => ({ params: { locale } })); }
const locale = Astro.params.locale as L;
const article = articles[locale];
const guide = reusableGuides[locale]!;
const calculator = calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={['en', 'zh', 'es', 'fr', 'de']}>
  {locale === 'en' && <><p>“Reusable” describes a design, not a guaranteed saving. Money breaks even only when actual use spreads the purchase cost and per-use cleaning remains below the disposable alternative.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="reusable-calculator" mode="reusable" locale={locale} {...calculator}/><h2>Keep the environmental question separate</h2><p>The FTC warns that broad green claims are difficult to substantiate. This calculator reports dollars and uses only; emissions, water and waste require product-specific evidence and boundaries.</p><h2>Use the retirement condition, not the advertised maximum</h2><p>Estimate loss, breakage, filter replacement and hygiene instructions. If the product is unlikely to reach the break-even count in normal behavior, the theoretical design life is irrelevant.</p><p class="privacy-note">General consumer education, not safety, environmental, financial or product advice.</p></>}
  {locale === 'zh' && <><p>「可以重複」只是設計，不是保證省錢。要先讓實際使用次數攤掉購入成本，並確保每次清洗與耗材仍低於一次性用品。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="reusable-calculator" mode="reusable" locale={locale} {...calculator}/><h2>循環杯的前提就是重複清洗</h2><p>環境部法規把循環杯定義為店家設計提供、可重複清洗使用的容器與杯蓋。清洗不是零成本，也不能忽略商品的衛生與汰換指示。</p><h2>環境效益另需證據</h2><p>本頁只回答金錢損益。碳排、水、製造與廢棄處理的界線不同，不能由「每次較便宜」直接推論整體環境較好。</p><p class="privacy-note">一般消費教育資訊，不是安全、環境、財務或商品建議。</p></>}
  {locale === 'es' && <><p>“Reutilizable” describe el diseño, no garantiza ahorro. Solo hay equilibrio cuando los usos reales reparten la compra y la limpieza más consumibles queda por debajo del desechable.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="reusable-calculator" mode="reusable" locale={locale} {...calculator}/><h2>La reutilización incluye lavado e higiene</h2><p>La nota oficial de MITECO sobre sistemas de reutilización incluye limpieza y lavado según condiciones higiénicas. Introduce ese coste y la vida que permite el producto concreto.</p><h2>No convertir euros en una afirmación ambiental</h2><p>El resultado económico no mide fabricación, energía, agua ni fin de vida. Cualquier conclusión ambiental necesita evidencia específica del producto y una comparación equivalente.</p><p class="privacy-note">Información general; no es consejo de seguridad, ambiental, financiero ni de producto.</p></>}
  {locale === 'fr' && <><p>« Réutilisable » décrit un usage possible, pas une économie garantie. Le seuil dépend des rotations réellement atteintes, du lavage et des consommables, pas d’un slogan.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="reusable-calculator" mode="reusable" locale={locale} {...calculator}/><h2>Ne pas généraliser le seuil de quatre rotations</h2><p>L’Observatoire ADEME indique un avantage dès quatre utilisations pour le verre consigné évalué. Ce résultat dépend d’un emballage, d’un lavage et d’une logistique précis : il ne remplace pas vos coûts ni la durée de l’objet comparé.</p><h2>Consigne, retour et lavage font partie du système</h2><p>Un dépôt remboursable n’est pas une dépense si le retour est réellement effectué. En revanche, trajet de retour, casse, lavage et produit nettoyant peuvent modifier le seuil. La DGCCRF rappelle qu’une allégation environnementale doit rester fiable et vérifiable.</p><p class="privacy-note">Information générale, sans conseil financier, environnemental, sanitaire ou produit.</p></>}
  {locale === 'de' && <><p>„Mehrweg“ ist eine Systembeschreibung, keine Spargarantie. Erst reale Umläufe verteilen die Anschaffung; Spülen, Verbrauchsteile, Verlust und Rückgabeweg bleiben echte Kosten.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="reusable-calculator" mode="reusable" locale={locale} {...calculator}/><h2>Flaschen-Umläufe nicht auf jedes Produkt übertragen</h2><p>Das Umweltbundesamt nennt bis zu 50 Wiederbefüllungen für Glas- und bis zu 20 für PET-Mehrwegflaschen. Diese Werte beschreiben Flaschensysteme. Für Becher, Filter oder Behälter zählt die realistisch erreichbare Nutzungszahl des konkreten Produkts.</p><h2>Spülen und Einweg-Zubehör in der Bilanz behalten</h2><p>UBA weist bei Mehrwegbechern auf den Spülvorgang und Einwegdeckel hin. Der Rechner macht daraus Euro-Eingaben; eine vollständige Umweltbilanz ersetzt er bewusst nicht.</p><p class="privacy-note">Allgemeine Verbraucherinformation, keine Finanz-, Umwelt-, Hygiene- oder Produktempfehlung.</p></>}
  <FAQ items={article.faq}/>
</ArticleLayout>
