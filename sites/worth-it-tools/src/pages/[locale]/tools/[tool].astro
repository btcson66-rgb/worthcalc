---
import DecisionGuide from '../../../components/DecisionGuide.astro';
import LocalizedCoreCalculator from '../../../components/LocalizedCoreCalculator.astro';
import { coreToolContent } from '../../../data/coreToolContent';
import { installmentGuides, paidMembershipGuides, subscriptionGuides } from '../../../data/decisionGuides';
import { localizedPath } from '../../../i18n/utils';
import ToolLayout from '../../../layouts/ToolLayout.astro';
import type { Locale } from '../../../consts';

type EditorialLocale = Exclude<Locale, 'en' | 'zh'>;

export function getStaticPaths() {
  const released = ['installment-true-apr', 'subscription-audit', 'costco-membership'] as const;
  return (['es', 'fr', 'de'] as EditorialLocale[]).flatMap((locale) =>
    released.map((tool) => ({ params: { locale, tool } })),
  );
}

const locale = Astro.params.locale as EditorialLocale;
const slug = Astro.params.tool!;
const content = coreToolContent[locale]?.[slug];
if (!content) throw new Error(`Missing core tool content for ${locale}/${slug}`);
const guides = slug === 'subscription-audit'
  ? subscriptionGuides
  : slug === 'costco-membership'
    ? paidMembershipGuides
    : installmentGuides;
const costcoSources = {
  es: { label: 'Costco España — cuota Gold Star y almacenes en España', href: 'https://www.costco.es/sobre-nosotros' },
  fr: { label: 'Costco France — adhésion Privilège, cotisation et remboursement', href: 'https://www.costco.fr/faq_informations_adhesion' },
  de: { label: 'Costco — Standorte weltweit im Bericht zum dritten Quartal 2026', href: 'https://investor.costco.com/news/news-details/2026/Costco-Wholesale-Corporation-Reports-Third-Quarter-and-Year-To-Date-Operating-Results-For-Fiscal-2026/default.aspx' },
};
const guide = {
  ...guides[locale],
  cta: undefined,
  sources: slug === 'costco-membership' ? [costcoSources[locale], ...guides[locale].sources] : guides[locale].sources,
};
const related = content.related.map((item) => ({ title: item.title, href: localizedPath(locale, item.path) }));
---

<ToolLayout
  title={content.title}
  description={content.description}
  locale={locale}
  tool={{ name: content.title }}
  faq={content.faq}
  related={related}
  alternateLocales={['en', 'zh', 'es', 'fr', 'de']}
  showReview={false}
>
  <LocalizedCoreCalculator content={content} />
  <DecisionGuide content={guide} />
</ToolLayout>
