---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import DecisionMathCalculator from '../../components/DecisionMathCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { trueHourlyWageGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type L = 'en' | 'zh' | 'es' | 'fr' | 'de';
const articles: Record<L, { title: string; description: string; faq: FaqItem[] }> = {
  en: { title: 'True hourly wage after commuting and work expenses', description: 'Compare jobs with take-home pay, paid and unpaid time, commute, supplies and incremental meals—without confusing labor law.', faq: [{ question: 'What is the true-hourly-wage formula?', answer: 'Take-home pay minus unreimbursed job costs, divided by paid hours plus required unpaid time and commute.' }, { question: 'Should I use gross or net pay?', answer: 'Show both: gross pay for the advertised rate, actual take-home for spendable hourly value.' }, { question: 'Does ordinary commuting count as FLSA work time?', answer: 'DOL generally says no, but this personal comparison still counts the time you give up.' }, { question: 'What work costs belong?', answer: 'Only incremental, unreimbursed transport, tools, clothing, credentials, phone and meal differences caused by the job.' }, { question: 'Is this a minimum-wage calculator?', answer: 'No. Legal wage and compensable-time questions require the applicable law and facts.' }] },
  zh: { title: '扣掉通勤和工作支出後，你的真實時薪是多少', description: '用同一期薪資單，把實領、未報銷成本、有薪工時、必要時間與通勤放入同一模型。', faq: [{ question: '真實時薪公式是什麼？', answer: '實際發給減未報銷工作成本，再除以有薪工時、必要未計薪時間與通勤的總和。' }, { question: '應發和實領用哪一個？', answer: '兩者都顯示：應發算表面稅前時薪，實領算真正可支配價值。' }, { question: '通勤是法定工時嗎？', answer: '本模型只是個人時間成本；法定認定要看是否受雇主指揮監督等具體事實。' }, { question: '工作餐費整筆都扣嗎？', answer: '只扣因上班比原本飲食多出的差額，避免把日常吃飯重複算成工作成本。' }, { question: '可以拿來判斷最低工資嗎？', answer: '不可以，最低工資、加班與短付爭議要另依法律算法。' }] },
  es: { title: 'Cómo calcular tu salario real por hora tras desplazamientos y gastos', description: 'Compara nómina neta, horas pagadas, tiempo exigido, trayecto, material y comida incremental sin convertirlo en cálculo legal.', faq: [{ question: '¿Cuál es la fórmula?', answer: 'Líquido cobrado menos gastos no reembolsados, dividido entre horas pagadas, tiempo laboral no incluido y desplazamiento.' }, { question: '¿Uso bruto o neto?', answer: 'Muestra ambos: bruto para la tarifa anunciada y líquido real para el valor disponible.' }, { question: '¿Todo el intervalo fichado es trabajo efectivo?', answer: 'La guía oficial recomienda registrar pausas para evitar esa presunción; depende de la organización y la norma.' }, { question: '¿Qué gastos resto?', answer: 'Solo transporte, material, ropa, teléfono y comida incremental causados por el empleo y no reembolsados.' }, { question: '¿Es un cálculo legal de salario?', answer: 'No. Jornada, salario mínimo y horas extra exigen la norma y los hechos aplicables.' }] },
  fr: { title: 'Comment calculer son vrai salaire horaire après trajets et frais', description: 'Comparez net perçu, temps payé et requis, trajets et frais non remboursés sans en faire un calcul juridique.', faq: [{ question: 'Quelle est la formule ?', answer: 'Net perçu moins frais professionnels non remboursés, divisé par heures payées, temps requis non inclus et trajets.' }, { question: 'Faut-il utiliser le brut ou le net ?', answer: 'Affichez les deux : le brut pour le taux annoncé, le net réel pour la valeur disponible.' }, { question: 'Les frais remboursés doivent-ils être retirés ?', answer: 'Non. Ne soustrayez que le reste réellement à votre charge.' }, { question: 'Le repas entier est-il un frais ?', answer: 'Non : seulement le surcoût causé par le travail par rapport à votre repas habituel.' }, { question: 'Est-ce un calcul du Smic ?', answer: 'Non. Smic, heures supplémentaires et temps effectif exigent les règles et faits applicables.' }] },
  de: { title: 'Tatsächlicher Stundenlohn nach Pendel- und Arbeitskosten', description: 'Nettoauszahlung, bezahlte und zusätzliche Zeit, Pendeln und nicht erstattete Kosten in einem Zeitraum vergleichen.', faq: [{ question: 'Wie lautet die Formel?', answer: 'Nettoauszahlung minus nicht erstattete Arbeitskosten, geteilt durch bezahlte Stunden, Zusatzzeit und Pendelzeit.' }, { question: 'Brutto oder netto?', answer: 'Beides zeigen: Brutto für den ausgeschriebenen Satz, ausgezahltes Netto für den verfügbaren Stundenwert.' }, { question: 'Ist die Entfernungspauschale eine Kostenerstattung?', answer: 'Nein. Sie ist ein steuerlicher Abzug; tatsächliche Entlastung hängt von Ihrer Steuer ab.' }, { question: 'Welche Ausgaben abziehen?', answer: 'Nur jobbedingte, nicht erstattete Mehrkosten für Fahrt, Mittel, Kleidung, Telefon und Essen.' }, { question: 'Ist das eine Mindestlohnprüfung?', answer: 'Nein. Vergütung und Arbeitszeit müssen rechtlich getrennt geprüft werden.' }] },
};

const fields = {
  en: [{ key: 'grossPay', label: 'Gross pay for period', step: .01 }, { key: 'takeHomePay', label: 'Actual take-home pay', step: .01 }, { key: 'paidHours', label: 'Paid hours' }, { key: 'unpaidHours', label: 'Required time not included', step: .25 }, { key: 'commuteHours', label: 'Commute hours', step: .25 }, { key: 'workCosts', label: 'Unreimbursed job costs', step: .01 }, { key: 'targetHourly', label: 'Personal target per hour', step: .01 }],
  zh: [{ key: 'grossPay', label: '同一期應發工資', step: 1 }, { key: 'takeHomePay', label: '同一期實際發給', step: 1 }, { key: 'paidHours', label: '已計薪工時' }, { key: 'unpaidHours', label: '必要但未納入時間', step: .25 }, { key: 'commuteHours', label: '往返通勤總時數', step: .25 }, { key: 'workCosts', label: '未報銷工作增量成本', step: 1 }, { key: 'targetHourly', label: '個人目標真實時薪', step: 1 }],
  es: [{ key: 'grossPay', label: 'Bruto del periodo', step: .01 }, { key: 'takeHomePay', label: 'Líquido realmente cobrado', step: .01 }, { key: 'paidHours', label: 'Horas pagadas' }, { key: 'unpaidHours', label: 'Tiempo exigido no incluido', step: .25 }, { key: 'commuteHours', label: 'Horas de desplazamiento', step: .25 }, { key: 'workCosts', label: 'Gastos no reembolsados', step: .01 }, { key: 'targetHourly', label: 'Objetivo personal por hora', step: .01 }],
  fr: [{ key: 'grossPay', label: 'Brut de la période', step: .01 }, { key: 'takeHomePay', label: 'Net réellement perçu', step: .01 }, { key: 'paidHours', label: 'Heures rémunérées', step: .01 }, { key: 'unpaidHours', label: 'Temps requis non inclus', step: .25 }, { key: 'commuteHours', label: 'Heures de trajet', step: .25 }, { key: 'workCosts', label: 'Frais restant à charge', step: .01 }, { key: 'targetHourly', label: 'Objectif personnel net/heure', step: .01 }],
  de: [{ key: 'grossPay', label: 'Brutto im Zeitraum', step: .01 }, { key: 'takeHomePay', label: 'Tatsächliche Nettoauszahlung', step: .01 }, { key: 'paidHours', label: 'Bezahlte Stunden', step: .01 }, { key: 'unpaidHours', label: 'Erforderliche Zusatzzeit', step: .25 }, { key: 'commuteHours', label: 'Pendelstunden', step: .25 }, { key: 'workCosts', label: 'Nicht erstattete Jobkosten', step: .01 }, { key: 'targetHourly', label: 'Persönliches Netto-Stundenziel', step: .01 }],
};
const calculators = {
  en: { currency: 'USD' as const, defaults: { grossPay: 4000, takeHomePay: 3100, paidHours: 160, unpaidHours: 10, commuteHours: 20, workCosts: 350, targetHourly: 15 }, fields: fields.en, copy: { heading: 'True hourly wage calculator', intro: 'Use one matching pay period and actual paystub figures.', output1: 'True take-home per committed hour', output2: 'Headline gross per paid hour', output3: 'Total committed hours', verdictPositive: 'Your true hourly value meets the personal target entered.', verdictNegative: 'Your true hourly value is below the personal target entered.', privacy: 'Personal comparison only—not a legal wage determination.' } },
  zh: { currency: 'TWD' as const, defaults: { grossPay: 60000, takeHomePay: 52000, paidHours: 160, unpaidHours: 8, commuteHours: 22, workCosts: 5000, targetHourly: 250 }, fields: fields.zh, copy: { heading: '通勤與支出後真實時薪計算器', intro: '全部使用同一計薪期間與本人薪資單實際數字。', output1: '每投入一小時實領價值', output2: '每有薪小時表面應發', output3: '總投入時數', verdictPositive: '真實時薪達到你輸入的個人目標。', verdictNegative: '真實時薪低於你輸入的個人目標。', privacy: '僅供個人比較，不是法定工資認定。' } },
  es: { currency: 'EUR' as const, defaults: { grossPay: 2400, takeHomePay: 1900, paidHours: 160, unpaidHours: 8, commuteHours: 20, workCosts: 220, targetHourly: 10 }, fields: fields.es, copy: { heading: 'Calculadora de salario real por hora', intro: 'Usa un mismo periodo y cifras reales de tu nómina.', output1: 'Neto por hora comprometida', output2: 'Bruto por hora pagada', output3: 'Horas totales comprometidas', verdictPositive: 'El valor real por hora alcanza tu objetivo personal.', verdictNegative: 'El valor real por hora queda bajo tu objetivo personal.', privacy: 'Comparación personal, no determinación legal del salario.' } },
  fr: { currency: 'EUR' as const, defaults: { grossPay: 3200, takeHomePay: 2500, paidHours: 151.67, unpaidHours: 6, commuteHours: 18, workCosts: 260, targetHourly: 13 }, fields: fields.fr, copy: { heading: 'Calculateur du vrai net horaire', intro: 'Utilisez une même période et les chiffres réels du bulletin.', output1: 'Net par heure mobilisée', output2: 'Brut par heure rémunérée', output3: 'Heures totales mobilisées', verdictPositive: 'Le net horaire réel atteint votre objectif personnel.', verdictNegative: 'Le net horaire réel reste sous votre objectif personnel.', privacy: 'Comparaison personnelle, pas détermination juridique du salaire.' } },
  de: { currency: 'EUR' as const, defaults: { grossPay: 3800, takeHomePay: 2600, paidHours: 173.33, unpaidHours: 5, commuteHours: 20, workCosts: 300, targetHourly: 12 }, fields: fields.de, copy: { heading: 'Rechner für den tatsächlichen Netto-Stundenwert', intro: 'Einen Abrechnungszeitraum und echte Abrechnungswerte verwenden.', output1: 'Netto je gebundener Stunde', output2: 'Brutto je bezahlter Stunde', output3: 'Gesamte gebundene Stunden', verdictPositive: 'Der tatsächliche Netto-Stundenwert erreicht Ihr persönliches Ziel.', verdictNegative: 'Der tatsächliche Netto-Stundenwert liegt unter Ihrem persönlichen Ziel.', privacy: 'Persönlicher Vergleich, keine rechtliche Lohnfeststellung.' } },
};

export function getStaticPaths() { return ['en', 'zh', 'es', 'fr', 'de'].map((locale) => ({ params: { locale } })); }
const locale = Astro.params.locale as L;
const article = articles[locale];
const guide = trueHourlyWageGuides[locale]!;
const calculator = calculators[locale];
---
<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={['en', 'zh', 'es', 'fr', 'de']}>
  {locale === 'en' && <><p>A job’s advertised hourly rate prices paid work only. A personal decision also needs spendable pay, required extra time, commuting and costs the employer does not reimburse.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="true-hourly-calculator" mode="hourlyWage" locale={locale} {...calculator}/><h2>Keep two clocks</h2><p>For personal comparison, count every hour the job takes from you. For labor-law questions, preserve a separate record: DOL says ordinary commuting is generally not work time, while suffered or permitted off-the-clock work and job-site travel may be compensable.</p><h2>Use the paystub boundary</h2><p>The IRS distinguishes gross pay before deductions from net take-home after deductions. Enter both from the same pay period; do not apply an average tax percentage to a different salary or location.</p><p class="privacy-note">General education, not tax, legal, employment or financial advice.</p></>}
  {locale === 'zh' && <><p>職缺寫的時薪只看有薪時間；個人選擇還要看真正實領、必要額外時間、通勤與公司未報銷的成本。</p><DecisionGuide content={guide}/><DecisionMathCalculator id="true-hourly-calculator" mode="hourlyWage" locale={locale} {...calculator}/><h2>個人時間成本與法定工時分開</h2><p>個人比較可以把所有通勤都放入分母；但勞動部對工作時間的認定重點是是否受雇主指揮監督、提供或等待提供勞務。疑似未付工時要另存出勤、訊息與指示，不要只在計算器裡當成本。</p><h2>同一期薪資單才能對齊</h2><p>勞動部要求薪資明細列出總額、各項給付、合法扣除與實際發給。應發與實領必須取同一期，並把雇主已報銷款項排除。</p><p class="privacy-note">一般教育資訊，不是稅務、法律、勞資或財務建議。</p></>}
  {locale === 'es' && <><p>La tarifa anunciada divide el bruto entre horas pagadas. Para elegir empleo también importan el líquido, el tiempo exigido, el trayecto y los gastos que la empresa no devuelve.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="true-hourly-calculator" mode="hourlyWage" locale={locale} {...calculator}/><h2>Separar la métrica personal del registro legal</h2><p>Cuenta el desplazamiento para valorar tu tiempo, pero no lo declares automáticamente jornada. La guía de MITES exige registrar inicio y final y recomienda identificar pausas; las obligaciones concretas dependen del trabajo y la organización.</p><h2>La nómina debe ser del mismo periodo</h2><p>El modelo oficial separa devengos y deducciones. Usa el líquido realmente cobrado y las horas correspondientes; no apliques un porcentaje fiscal genérico ni restes gastos ya reembolsados.</p><p class="privacy-note">Información general; no es asesoramiento fiscal, jurídico, laboral ni financiero.</p></>}
  {locale === 'fr' && <><p>Le taux brut annoncé ne mesure ni le temps de trajet ni ce qui reste réellement sur le compte. Pour comparer deux emplois, alignez bulletin, heures, trajets et frais sur le même mois.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="true-hourly-calculator" mode="hourlyWage" locale={locale} {...calculator}/><h2>Ne pas soustraire deux fois les frais professionnels</h2><p>L’Urssaf rappelle que les dépenses engagées pour l’activité sont des frais professionnels que l’employeur doit rembourser. Retirez seulement le montant restant à votre charge après remboursement, prise en charge du transport ou indemnité.</p><h2>Brut et net ont deux fonctions</h2><p>Service-Public distingue le brut avant cotisations du net perçu après déduction. Le premier explique l’offre, le second alimente la comparaison de trésorerie ; aucun pourcentage moyen ne remplace votre bulletin.</p><p class="privacy-note">Information générale, sans conseil fiscal, juridique, social ou financier.</p></>}
  {locale === 'de' && <><p>Der ausgeschriebene Bruttostundensatz blendet Pendeln, Zusatzzeit und selbst getragene Kosten aus. Für den persönlichen Vergleich müssen Abrechnung und Stunden denselben Monat abdecken.</p><DecisionGuide content={guide}/><DecisionMathCalculator id="true-hourly-calculator" mode="hourlyWage" locale={locale} {...calculator}/><h2>Arbeitszeit rechtlich getrennt dokumentieren</h2><p>BMAS beschreibt die Pflicht zur Arbeitszeiterfassung. Wenn Vor- oder Nachbereitung angeordnet ist, sollten Sie diese nicht bloß als Opportunitätskosten verbuchen, sondern separat dokumentieren und prüfen lassen.</p><h2>Pendlerpauschale ist nicht der Benzinpreis</h2><p>Die Entfernungspauschale senkt Werbungskosten und ab 2026 gilt der genannte Satz ab dem ersten Kilometer. Sie ist keine vollständige Barauszahlung. Verwenden Sie im Rechner die tatsächlichen Kosten und spiegeln Sie Steuerwirkung nur einmal über Ihr reales Netto.</p><p class="privacy-note">Allgemeine Information, keine Steuer-, Rechts-, Arbeits- oder Finanzberatung.</p></>}
  <FAQ items={article.faq}/>
</ArticleLayout>
