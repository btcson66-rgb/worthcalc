---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import PhoneKeepUpgradeCalculator from '../../components/PhoneKeepUpgradeCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { phoneUpgradeGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type EditorialLocale = 'en' | 'zh' | 'es';
const articles: Record<EditorialLocale, { title: string; description: string; faq: FaqItem[] }> = {
  en: {
    title: 'Upgrade your phone or keep it? Compare repair, trade-in, and monthly cost',
    description: 'Compare repairing a phone with upgrading using remaining life, trade-in value, plan difference, holding months, resale and data-transfer cost.',
    faq: [
      { question: 'Should I compare phone prices or monthly costs?', answer: 'Compare both. The out-the-door price exposes the real purchase commitment; normalized device cost plus service plan shows options held for different lengths on one monthly basis.' },
      { question: 'How many remaining months should I give a repaired phone?', answer: 'Use a conservative period supported by battery health, repair diagnosis, software support and your actual workload. Run shorter and longer cases because no calculator can predict failure timing.' },
      { question: 'Does a bill-credit trade-in equal cash?', answer: 'Not necessarily. Credits may require an eligible plan and continued service for 24 or 36 months. Enter only the value you keep after any likely early exit or disqualification.' },
      { question: 'Where does data transfer belong?', answer: 'Include paid setup, storage, cables and the value you deliberately assign to backup, authentication and app reconfiguration. Keep a separate zero-time-value scenario.' },
      { question: 'What should I do before trading in a phone?', answer: 'Back up needed data, sign out and disconnect accounts and paired devices, remove SIM and removable storage, reset the phone, verify the wipe and retain shipping or handoff evidence.' },
    ],
  },
  zh: {
    title: '手機該換還是繼續用？比較維修、舊換新、資費與每月成本',
    description: '用剩餘壽命、維修費、舊換新折抵、資費差額、持有月數、殘值與資料移轉成本比較續用或換機。',
    faq: [
      { question: '應比較手機價格還是每月成本？', answer: '兩者都要。完整實付價揭露購買承諾；設備月成本再加相同基礎的資費，才能比較持有期不同的舊機與新機。' },
      { question: '維修後剩餘壽命怎麼填？', answer: '依電池健康、故障診斷、安全更新、零件與實際使用強度保守估計，並測試較短與較長情境，不要把原廠宣稱年限直接當結果。' },
      { question: '分月回饋的舊換新等於現金嗎？', answer: '不一定。若要綁指定資費並持續 24 或 36 個月，提前離開可能失去尚未入帳回饋；只能填你確定能保留的經濟價值。' },
      { question: '資料移轉成本怎麼算？', answer: '可列入付費設定、雲端空間、線材，以及你自行選定的備份、驗證碼與應用程式重設時間價值；另跑一次時間價值為零的情境。' },
      { question: '送修或折抵前要做什麼？', answer: '先備份、記錄 IMEI 與外觀、確認保固與檢測費；交付舊機前登出帳號、解除配對、移除卡片與儲存裝置、恢復原廠設定並確認資料已清除。' },
    ],
  },
  es: {
    title: '¿Cambiar de móvil o conservarlo? Reparación, recompra, tarifa y coste mensual',
    description: 'Compara reparación y cambio con vida restante, recompra, diferencia de tarifa, tenencia, reventa y coste de migración de datos.',
    faq: [
      { question: '¿Comparo el precio del móvil o el coste mensual?', answer: 'Ambos. El precio final revela el compromiso de compra; el coste del dispositivo normalizado más la tarifa permite comparar periodos de tenencia distintos.' },
      { question: '¿Qué vida restante debo poner tras reparar?', answer: 'Usa un periodo prudente según batería, diagnóstico, actualizaciones y uso real. Prueba escenarios más corto y largo porque la fecha de fallo no puede predecirse.' },
      { question: '¿Una recompra abonada en factura equivale a efectivo?', answer: 'No siempre. Puede exigir una tarifa y permanencia durante muchos meses. Introduce solo el valor que conservarías después de una salida anticipada razonable.' },
      { question: '¿Dónde incluyo la migración de datos?', answer: 'Incluye configuración pagada, almacenamiento, cables y el valor que decidas asignar a copias, autenticación y ajustes. Ejecuta también un escenario sin valorar el tiempo.' },
      { question: '¿Qué hago antes de entregar el móvil?', answer: 'Haz copia de lo necesario, cierra y desvincula cuentas, retira SIM y almacenamiento, restaura el dispositivo, comprueba el borrado y conserva prueba de entrega o envío.' },
    ],
  },
};

const calculators = {
  en: { currency: 'USD' as const, defaults: { repairCost: 200, remainingMonths: 18, currentResaleLater: 50, tradeInNow: 250, newPhonePrice: 999, upgradeFees: 50, transferCost: 30, currentPlanMonthly: 45, newPlanMonthly: 55, newHoldingMonths: 36, newResaleLater: 300 }, copy: { heading: 'Phone keep-or-upgrade monthly-cost calculator', intro: 'Normalize different holding periods, then compare device cost and like-for-like service plans.', repairCost: 'Repair and diagnosis now', remainingMonths: 'Usable months after repair', currentResaleLater: 'Current phone resale after keeping', tradeInNow: 'Guaranteed trade-in now', newPhonePrice: 'New phone out-the-door price', upgradeFees: 'Activation/accessory/upgrade fees', transferCost: 'Data transfer and setup cost', currentPlanMonthly: 'Current service plan per month', newPlanMonthly: 'New service plan per month', newHoldingMonths: 'Months you will keep the new phone', newResaleLater: 'New phone resale at end', keepDeviceMonthly: 'Keep: device cost/month', upgradeDeviceMonthly: 'Upgrade: device cost/month', keepFullMonthly: 'Keep: full cost/month', upgradeFullMonthly: 'Upgrade: full cost/month', breakEvenTradeIn: 'Trade-in needed to break even', verdictKeep: 'Keeping is lower per month by', verdictUpgrade: 'Upgrading is lower per month by', privacy: 'Planning model only. It does not predict failure, trade-in inspection, bill credits or security-support dates.' } },
  zh: { currency: 'TWD' as const, defaults: { repairCost: 4500, remainingMonths: 18, currentResaleLater: 1000, tradeInNow: 6000, newPhonePrice: 30000, upgradeFees: 1000, transferCost: 800, currentPlanMonthly: 599, newPlanMonthly: 799, newHoldingMonths: 36, newResaleLater: 8000 }, copy: { heading: '手機續用或換機每月成本計算器', intro: '先把不同持有期換算成設備月成本，再加入同一基礎的資費比較。', repairCost: '現在維修與檢測費', remainingMonths: '維修後可用月數', currentResaleLater: '續用後舊機殘值', tradeInNow: '現在確定折抵額', newPhonePrice: '新機完整實付價', upgradeFees: '啟用／配件／換機費', transferCost: '資料移轉與設定成本', currentPlanMonthly: '現行每月資費', newPlanMonthly: '換機後每月資費', newHoldingMonths: '新機預計持有月數', newResaleLater: '新機期末殘值', keepDeviceMonthly: '續用：設備月成本', upgradeDeviceMonthly: '換機：設備月成本', keepFullMonthly: '續用：完整月成本', upgradeFullMonthly: '換機：完整月成本', breakEvenTradeIn: '損益所需折抵額', verdictKeep: '續用每月較少', verdictUpgrade: '換機每月較少', privacy: '僅供情境規劃；不預測故障、折抵檢測、分月回饋或安全更新終止日。' } },
  es: { currency: 'EUR' as const, defaults: { repairCost: 160, remainingMonths: 18, currentResaleLater: 40, tradeInNow: 200, newPhonePrice: 800, upgradeFees: 30, transferCost: 25, currentPlanMonthly: 20, newPlanMonthly: 25, newHoldingMonths: 36, newResaleLater: 220 }, copy: { heading: 'Calculadora mensual para conservar o cambiar de móvil', intro: 'Normaliza periodos de uso distintos y compara dispositivo más tarifas equivalentes.', repairCost: 'Reparación y diagnóstico ahora', remainingMonths: 'Meses útiles tras reparar', currentResaleLater: 'Reventa del móvil actual después', tradeInNow: 'Recompra garantizada hoy', newPhonePrice: 'Precio final del móvil nuevo', upgradeFees: 'Activación/accesorios/cambio', transferCost: 'Migración y configuración', currentPlanMonthly: 'Tarifa actual por mes', newPlanMonthly: 'Tarifa nueva por mes', newHoldingMonths: 'Meses de uso del móvil nuevo', newResaleLater: 'Reventa final del móvil nuevo', keepDeviceMonthly: 'Conservar: dispositivo/mes', upgradeDeviceMonthly: 'Cambiar: dispositivo/mes', keepFullMonthly: 'Conservar: total/mes', upgradeFullMonthly: 'Cambiar: total/mes', breakEvenTradeIn: 'Recompra necesaria para equilibrio', verdictKeep: 'Conservar cuesta menos al mes por', verdictUpgrade: 'Cambiar cuesta menos al mes por', privacy: 'Modelo de planificación. No predice averías, inspección, abonos ni fin de actualizaciones.' } },
};

export function getStaticPaths() { return ['en', 'zh', 'es'].map((locale) => ({ params: { locale } })); }
const locale = Astro.params.locale as EditorialLocale;
const article = articles[locale];
const guide = phoneUpgradeGuides[locale]!;
const calculator = calculators[locale];
---

<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={[locale]}>
  {locale === 'en' && <>
    <p>A “free upgrade” can cost more than keeping a repaired phone once the required plan, lost credits, fees and setup are counted. Compare the device economics separately, then add the service plan difference.</p>
    <DecisionGuide content={guide} />
    <PhoneKeepUpgradeCalculator locale={locale} {...calculator} />
    <h2>Convert promotions into value you actually retain</h2>
    <p>A headline trade-in may arrive as monthly bill credits. Record the credit schedule, eligible plan, device condition, deadline and amount lost if you leave early. Treat a financed balance and an unlock restriction as decision constraints, not as discounts.</p>
    <h2>Give the current phone a defensible remaining life</h2>
    <p>Start with diagnosis, battery health, repair availability and security-support horizon. Run nine-, 18- and 24-month cases. A lower monthly result that assumes an unsafe battery or unavailable critical app is not a usable recommendation.</p>
    <h2>Protect the data handoff</h2>
    <p>The FTC recommends backing up the phone, removing SIM and storage cards, resetting it and disconnecting accounts and paired devices before sale or trade-in. Keep proof of condition and shipment until the value is final.</p>
    <p class="privacy-note">General education only, not financial, legal, tax, security, telecom, repair or product-safety advice.</p>
  </>}
  {locale === 'zh' && <>
    <p>「零元換機」不等於零成本。指定高資費、分月回饋、提前離開損失、啟用與移轉都可能讓換機比維修續用更貴。先算設備，再把資費差額獨立加回。</p>
    <DecisionGuide content={guide} />
    <PhoneKeepUpgradeCalculator locale={locale} {...calculator} />
    <h2>把舊換新廣告還原成真正可保留價值</h2>
    <p>確認折抵是立即折價、現金還是 24／36 個月帳單回饋，並記錄指定方案、外觀與功能檢測、交件期限及提前解約損失。尚未清償的分期不是折扣。</p>
    <h2>送修前先固定報價、資料與責任</h2>
    <p>行政院消保處提醒先備份、記錄 IMEI 與外觀，並確認保固、檢測費、維修項目及報價同意。若有電池膨脹、過熱或其他安全異常，應先停止冒險使用並依原廠安全指引處理。</p>
    <h2>折抵或回收不是只刪除照片</h2>
    <p>先完成新機資料驗證，再登出帳號、解除裝置綁定、移除 SIM／記憶卡、恢復原廠設定並重新確認。保留交付、寄送與檢測結果，直到折抵入帳。</p>
    <p class="privacy-note">一般教育資訊，不是財務、法律、稅務、資安、電信、維修或產品安全建議。</p>
  </>}
  {locale === 'es' && <>
    <p>Un móvil “incluido” puede salir caro si exige una tarifa superior, créditos mensuales, permanencia y gastos de configuración. Separa el coste del dispositivo de la tarifa y usa solo la recompra que realmente conservarás.</p>
    <DecisionGuide content={guide} />
    <PhoneKeepUpgradeCalculator locale={locale} {...calculator} />
    <h2>Aplica primero la garantía legal</h2>
    <p>En España, el CEC explica que los bienes nuevos cuentan con carácter general con tres años de garantía legal. Si la falta de conformidad está cubierta, confirma reparación o sustitución con el vendedor antes de pagar una reparación privada o cambiar de terminal.</p>
    <h2>Desmonta la promoción de recompra</h2>
    <p>Anota valor sujeto a inspección, tarifa obligatoria, créditos pendientes, permanencia y penalización. Una cifra repartida durante 36 meses no equivale a efectivo hoy si existe una posibilidad razonable de cambiar de operador.</p>
    <h2>Entrega el móvil sin entregar tus datos</h2>
    <p>La AEPD e INCIBE recomiendan realizar copia, desvincular cuentas, restaurar el dispositivo y comprobar el borrado antes de venderlo. Conserva justificante de entrega, estado e IMEI hasta el abono definitivo.</p>
    <p class="privacy-note">Información general; no es asesoramiento financiero, jurídico, fiscal, de seguridad, telecomunicaciones, reparación o producto.</p>
  </>}
  <FAQ items={article.faq} />
</ArticleLayout>
