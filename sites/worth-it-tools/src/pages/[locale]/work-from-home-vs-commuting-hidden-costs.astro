---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import DecisionGuide from '../../components/DecisionGuide.astro';
import WfhCommuteCalculator from '../../components/WfhCommuteCalculator.astro';
import FAQ from '../../components/FAQ.astro';
import { wfhCommuteGuides } from '../../data/decisionGuides';
import type { FaqItem } from '../../lib/seo';

type EditorialLocale = 'en' | 'zh' | 'es' | 'fr' | 'de';

const articles: Record<EditorialLocale, { title: string; description: string; faq: FaqItem[] }> = {
  en: {
    title: 'Work from home vs commuting: compare the hidden monthly costs',
    description: 'Compare remote, office and hybrid work from commute, meals, home energy, equipment, fixed costs, reimbursements and optional commute time.',
    faq: [
      { question: 'Is working from home always cheaper?', answer: 'No. It often removes commute and office-day costs, but may add heating or cooling, electricity, equipment, internet upgrades and coworking. Compare only incremental costs and reimbursements.' },
      { question: 'Should I include my full internet bill?', answer: 'Usually not if you would pay for the same plan anyway. Include only a required upgrade, work-only line or incremental usage that changes the bill.' },
      { question: 'Can an employee claim the US home office deduction?', answer: 'The IRS says employees are not eligible for the home office deduction. Self-employed people face separate exclusive-and-regular-use rules. Do not count an assumed tax saving as monthly cash.' },
      { question: 'How should hybrid work be calculated?', answer: 'Count actual home and office days, apply each daily cost to its days, then add fixed costs that remain in the month. A parking pass or internet upgrade may not fall with fewer days.' },
      { question: 'Is commute time worth my hourly wage?', answer: 'Not automatically. Keep hours visible, use zero for cash-only comparison and add a personal value only as a sensitivity scenario.' },
    ],
  },
  zh: {
    title: '在家工作還是通勤？比較每月隱藏成本',
    description: '用實際居家與進公司天數，比較交通、餐食、住家電費、設備攤提、固定費、公司補助與選擇性通勤時間。',
    faq: [
      { question: '在家工作一定比較省嗎？', answer: '不一定。通勤、外食可能下降，但冷氣、照明、設備、網路升級或共用工作空間可能增加。只比較真的因工作模式改變的增量。' },
      { question: '家裡整張電費都算工作成本嗎？', answer: '不應。用同季節、相近居住狀況的帳單或插座電表估算增量；台電採級距與夏月計價，不能把總帳單除以度數後當成固定單價。' },
      { question: '公司一定要補助居家設備嗎？', answer: '應先看勞動契約、工作規則與實際安排。勞動部居家工作參考指引要求合理風險評估並提及必要設備，但個人可領金額不能由計算器自行推定。' },
      { question: '混合辦公怎麼算？', answer: '用當月實際居家日與進公司日，分別乘每日增量，再加仍然存在的固定費。月票、停車位、網路升級不一定隨天數等比例下降。' },
      { question: '省下通勤時間等於多賺薪水嗎？', answer: '不是。除非那段時間確實轉成有薪工作。先以 0 元保留現金結果，再測休息、照顧或接案對你個人的時間價值。' },
    ],
  },
  es: {
    title: 'Teletrabajo o desplazamiento: comparar los costes mensuales ocultos',
    description: 'Compara teletrabajo, oficina y modalidad híbrida con transporte, comida, energía doméstica, equipo, gastos fijos, compensación y tiempo opcional.',
    faq: [
      { question: '¿El teletrabajo siempre cuesta menos?', answer: 'No. Reduce trayectos y algunos gastos de oficina, pero puede añadir climatización, electricidad, equipo, conexión o espacio de trabajo. Cuenta solo incrementos reales y compensación.' },
      { question: '¿La empresa debe compensar gastos de teletrabajo en España?', answer: 'La Ley 10/2021 establece dotación y mantenimiento de medios y que el trabajo a distancia regular sea sufragado o compensado; convenio y acuerdo concretan el mecanismo. Introduce solo lo pactado y cobrado.' },
      { question: '¿Incluyo toda la factura de internet?', answer: 'No si pagarías el mismo plan. Incluye una mejora obligatoria, segunda línea o importe incremental atribuible al trabajo.' },
      { question: '¿Cómo calculo una semana híbrida?', answer: 'Pasa la semana a días reales del mes. Multiplica cada coste diario por días de casa u oficina y añade abonos, equipo o conexión que sigan siendo fijos.' },
      { question: '¿El tiempo ahorrado vale mi sueldo por hora?', answer: 'No automáticamente. Usa cero para el presupuesto y un valor personal solo como sensibilidad, sin presentarlo como salario ganado.' },
    ],
  },
  fr: {
    title: 'Télétravail ou trajets quotidiens : comparer les coûts mensuels cachés',
    description: 'Comparez télétravail, présence et mode hybride avec énergie, repas, équipement, abonnement, indemnités réellement versées et temps facultatif.',
    faq: [
      { question: 'Le télétravail coûte-t-il toujours moins cher ?', answer: 'Non. Il évite des trajets et certains repas mais ajoute chauffage, électricité, connexion, équipement ou espace. Comparez uniquement les coûts supplémentaires et les remboursements réels.' },
      { question: 'Quel forfait télétravail utiliser en France en 2026 ?', answer: 'L’Urssaf publie des limites d’exonération, pas une somme automatiquement due à chaque salarié. Sans accord collectif, elle indique 2,70 € par jour dans la limite de 59,40 € par mois ; utilisez seulement le montant prévu et versé.' },
      { question: 'Puis-je compter toute la facture internet ?', answer: 'Non si l’abonnement serait identique sans télétravail. Comptez une hausse de débit nécessaire, une ligne dédiée ou la quote-part réellement remboursée.' },
      { question: 'Comment calculer un rythme hybride ?', answer: 'Appliquez les coûts journaliers aux jours réels, puis ajoutez les abonnements et équipements qui restent fixes. Le remboursement transport et l’indemnité télétravail doivent être saisis séparément.' },
      { question: 'Le temps gagné vaut-il mon salaire horaire ?', answer: 'Pas automatiquement. Gardez 0 € pour la trésorerie et testez une valeur personnelle séparée, sans la présenter comme un revenu.' },
    ],
  },
  de: {
    title: 'Homeoffice oder Pendeln: Versteckte monatliche Kosten vergleichen',
    description: 'Vergleiche Homeoffice, Büro und Hybridmodell mit Energie, Essen, Ausstattung, Ticket, Zuschüssen und optionaler Pendelzeit.',
    faq: [
      { question: 'Ist Homeoffice immer günstiger?', answer: 'Nein. Pendel- und Bürokosten sinken, dafür können Heizung, Strom, Internet, Ausstattung oder Coworking steigen. Entscheidend sind Mehrkosten und tatsächliche Zuschüsse.' },
      { question: 'Bekomme ich 6 € Homeoffice-Pauschale pro Tag ausgezahlt?', answer: 'Nein. Die Tagespauschale ist bei erfüllten Voraussetzungen ein steuerlicher Abzugsbetrag von 6 € je Tag, höchstens 1.260 € im Jahr. Steuerwirkung und Auszahlung sind nicht gleich.' },
      { question: 'Soll die gesamte Internetrechnung zählen?', answer: 'Nur wenn sie wegen der Arbeit vollständig zusätzlich entsteht. Meist zählt eine notwendige Tarifstufe, eine separate Leitung oder der selbst getragene Mehrbetrag.' },
      { question: 'Wie wird hybrides Arbeiten gerechnet?', answer: 'Tageskosten werden den echten Homeoffice- und Bürotagen zugeordnet. Deutschlandticket, Parkplatz, Internetupgrade und Ausstattung können als Fixkosten gleichzeitig bestehen bleiben.' },
      { question: 'Ist gesparte Pendelzeit gleich Stundenlohn?', answer: 'Nein. Für die reine Haushaltsrechnung bleibt der Zeitwert null; ein persönlicher Wert ist nur eine Sensitivität und kein zusätzlicher Lohn.' },
    ],
  },
};

const calculators = {
