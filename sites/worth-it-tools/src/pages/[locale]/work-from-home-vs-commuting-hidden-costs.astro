    currency: 'USD' as const,
    defaults: { workdays: 20, homeDays: 12, homeEnergy: 2.5, homeMeals: 6, homeOther: 1, homeFixed: 60, homeReimbursement: 0, officeCommute: 18, officeMeals: 14, officeOther: 3, officeFixed: 160, officeReimbursement: 0, commuteMinutes: 60, timeValue: 10 },
    copy: { heading: 'Remote, office and hybrid monthly cost calculator', intro: 'Enter incremental costs for one normal month. Baseline rent, internet and meals you would buy either way should not be counted twice.', workdays: 'Paid workdays in the month', homeDays: 'Days worked at home', homeEnergy: 'Extra home energy per day', homeMeals: 'Home workday food per day', homeOther: 'Other home cost per day', homeFixed: 'Home-work fixed cost/month', homeReimbursement: 'Home-work reimbursement/month', officeCommute: 'Commute cash per office day', officeMeals: 'Office-day food premium', officeOther: 'Other office cost per day', officeFixed: 'Office fixed costs/month', officeReimbursement: 'Commute/office reimbursement', commuteMinutes: 'Round-trip minutes per office day', timeValue: 'Optional personal time value/hour', allHome: 'All-home monthly cash', allOffice: 'All-office monthly cash', hybridCash: 'Chosen hybrid cash', commuteHours: 'Hybrid commute hours', hybridFull: 'Hybrid cash + optional time', officePremium: 'All-office minus all-home', verdictHome: 'All-home costs less by', verdictOffice: 'All-office costs less by', privacy: 'Educational estimate. Inputs stay in the browser. Verify bills, policy, agreement and tax treatment.' },
  },
  zh: {
    currency: 'TWD' as const,
    defaults: { workdays: 22, homeDays: 14, homeEnergy: 35, homeMeals: 90, homeOther: 15, homeFixed: 400, homeReimbursement: 0, officeCommute: 180, officeMeals: 150, officeOther: 20, officeFixed: 1200, officeReimbursement: 0, commuteMinutes: 70, timeValue: 150 },
    copy: { heading: '居家、進公司與混合辦公月成本計算器', intro: '只填因工作模式改變的增量。原本就會支付的房租、網路與餐食不要重複列入。', workdays: '當月工作日', homeDays: '實際居家工作日', homeEnergy: '每個居家日增量電費', homeMeals: '居家工作日餐食', homeOther: '每個居家日其他成本', homeFixed: '每月居家固定成本', homeReimbursement: '每月居家實領補助', officeCommute: '每個進公司日通勤現金', officeMeals: '進公司日餐食增量', officeOther: '每個進公司日其他成本', officeFixed: '每月進公司固定成本', officeReimbursement: '每月通勤／辦公補助', commuteMinutes: '每個進公司日來回分鐘', timeValue: '選擇性每小時時間價值', allHome: '全居家每月現金', allOffice: '全進公司每月現金', hybridCash: '選定混合模式現金', commuteHours: '混合模式通勤時數', hybridFull: '混合現金＋選擇性時間', officePremium: '全進公司減全居家', verdictHome: '全居家較省', verdictOffice: '全進公司較省', privacy: '一般教育試算，輸入只留在瀏覽器。請查核帳單、公司制度、契約與適用稅務。' },
  },
  es: {
    currency: 'EUR' as const,
    defaults: { workdays: 20, homeDays: 12, homeEnergy: 2, homeMeals: 5, homeOther: 1, homeFixed: 35, homeReimbursement: 25, officeCommute: 6, officeMeals: 12, officeOther: 2, officeFixed: 45, officeReimbursement: 0, commuteMinutes: 70, timeValue: 8 },
    copy: { heading: 'Calculadora mensual de teletrabajo, oficina e híbrido', intro: 'Introduce incrementos de un mes normal. No dupliques alquiler, internet o comida que pagarías en cualquier modalidad.', workdays: 'Días laborables del mes', homeDays: 'Días reales de teletrabajo', homeEnergy: 'Energía extra por día en casa', homeMeals: 'Comida por día en casa', homeOther: 'Otros gastos diarios en casa', homeFixed: 'Gasto fijo mensual en casa', homeReimbursement: 'Compensación mensual de teletrabajo', officeCommute: 'Transporte por día presencial', officeMeals: 'Sobrecoste de comida presencial', officeOther: 'Otros gastos por día presencial', officeFixed: 'Gastos fijos de oficina/mes', officeReimbursement: 'Reembolso de transporte/oficina', commuteMinutes: 'Minutos ida y vuelta por día', timeValue: 'Valor personal opcional por hora', allHome: 'Caja mensual todo teletrabajo', allOffice: 'Caja mensual toda oficina', hybridCash: 'Caja de la modalidad híbrida', commuteHours: 'Horas de trayecto híbrido', hybridFull: 'Caja híbrida + tiempo opcional', officePremium: 'Toda oficina menos teletrabajo', verdictHome: 'Todo teletrabajo cuesta menos por', verdictOffice: 'Toda oficina cuesta menos por', privacy: 'Estimación educativa; datos en el navegador. Verifica facturas, convenio, acuerdo y fiscalidad.' },
  },
  fr: {
    currency: 'EUR' as const,
    defaults: { workdays: 20, homeDays: 12, homeEnergy: 2.5, homeMeals: 5, homeOther: 1, homeFixed: 40, homeReimbursement: 32.4, officeCommute: 0, officeMeals: 8, officeOther: 2, officeFixed: 90, officeReimbursement: 45, commuteMinutes: 70, timeValue: 10 },
    copy: { heading: 'Calculateur mensuel télétravail, présence et hybride', intro: 'Saisissez les coûts supplémentaires d’un mois normal. Loyer, internet et alimentation de base ne doivent pas être comptés deux fois.', workdays: 'Jours travaillés dans le mois', homeDays: 'Jours réels de télétravail', homeEnergy: 'Énergie supplémentaire/jour à domicile', homeMeals: 'Repas d’un jour à domicile', homeOther: 'Autres frais/jour à domicile', homeFixed: 'Frais fixes télétravail/mois', homeReimbursement: 'Indemnité télétravail versée/mois', officeCommute: 'Trajet variable/jour de présence', officeMeals: 'Surcoût repas/jour de présence', officeOther: 'Autres frais/jour de présence', officeFixed: 'Abonnements/frais fixes présence', officeReimbursement: 'Prise en charge transport/bureau', commuteMinutes: 'Minutes aller-retour/jour de présence', timeValue: 'Valeur personnelle facultative/heure', allHome: 'Trésorerie tout télétravail', allOffice: 'Trésorerie toute présence', hybridCash: 'Trésorerie du mode hybride', commuteHours: 'Heures de trajet hybride', hybridFull: 'Hybride + temps facultatif', officePremium: 'Présence moins télétravail', verdictHome: 'Le télétravail coûte moins de', verdictOffice: 'La présence coûte moins de', privacy: 'Estimation pédagogique, données dans le navigateur. Vérifiez justificatifs, accord, convention et fiscalité.' },
  },
  de: {
    currency: 'EUR' as const,
    defaults: { workdays: 20, homeDays: 12, homeEnergy: 3, homeMeals: 5, homeOther: 1, homeFixed: 40, homeReimbursement: 0, officeCommute: 0, officeMeals: 10, officeOther: 2, officeFixed: 63, officeReimbursement: 0, commuteMinutes: 60, timeValue: 12 },
    copy: { heading: 'Monatsrechner für Homeoffice, Büro und Hybrid', intro: 'Nur zusätzliche Kosten eines normalen Monats eintragen. Miete, Grundinternet und ohnehin nötige Mahlzeiten nicht doppelt zählen.', workdays: 'Arbeitstage im Monat', homeDays: 'Tatsächliche Homeoffice-Tage', homeEnergy: 'Zusätzliche Energie je Heimtag', homeMeals: 'Essen je Heimtag', homeOther: 'Weitere Kosten je Heimtag', homeFixed: 'Homeoffice-Fixkosten/Monat', homeReimbursement: 'Ausgezahlter Homeoffice-Zuschuss', officeCommute: 'Variable Fahrtkosten je Bürotag', officeMeals: 'Mehrkosten Essen je Bürotag', officeOther: 'Weitere Kosten je Bürotag', officeFixed: 'Ticket/Büro-Fixkosten pro Monat', officeReimbursement: 'Fahrt-/Bürozuschuss pro Monat', commuteMinutes: 'Hin- und Rückweg-Minuten je Bürotag', timeValue: 'Optionaler persönlicher Zeitwert/Stunde', allHome: 'Nur Homeoffice Geldkosten', allOffice: 'Nur Büro Geldkosten', hybridCash: 'Gewähltes Hybridmodell Geldkosten', commuteHours: 'Pendelstunden Hybridmodell', hybridFull: 'Hybrid + optionaler Zeitwert', officePremium: 'Büro minus Homeoffice', verdictHome: 'Homeoffice kostet weniger um', verdictOffice: 'Büro kostet weniger um', privacy: 'Unverbindliche Lernrechnung; Eingaben bleiben im Browser. Belege, Vereinbarung, Zuschüsse und Steuerfall prüfen.' },
  },
};

export function getStaticPaths() {
  return ['en', 'zh', 'es', 'fr', 'de'].map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as EditorialLocale;
const article = articles[locale];
const guide = wfhCommuteGuides[locale]!;
const calculator = calculators[locale];
---

<ArticleLayout title={article.title} description={article.description} locale={locale} updated="2026-07-19" alternateLocales={['en', 'zh', 'es', 'fr', 'de']}>
  {locale === 'en' && <>
    <p>Remote work can remove a large commute without making the home free. The fair comparison uses incremental cash: extra HVAC and equipment at home versus transport, parking, meals and office-only purchases, then subtracts reimbursements actually received.</p>
    <p>Hybrid work needs its own line because fixed costs can survive on both sides. A parking pass and upgraded internet can remain even when each is used only part of the month.</p>
    <DecisionGuide content={guide} />
    <WfhCommuteCalculator locale={locale} {...calculator} />
    <h2>Use the counterfactual bill, not the entire household</h2>
    <p>Rent, base internet and ordinary groceries usually continue under either arrangement. Count only the upgrade or usage that would disappear if the job returned to the office. Metered electricity and seasonal bill comparisons are stronger than a generic remote-work allowance.</p>
    <h2>Keep employee tax treatment outside the base case</h2>
    <p>The IRS says employees cannot claim the federal home office deduction. A self-employed person may face exclusive-and-regular-use tests, but that is a different decision. The calculator therefore accepts cash reimbursement, not an invented tax benefit.</p>
    <h2>Office days have variable and fixed costs</h2>
    <p>Daily commute, lunch premium, coffee and incidental purchases vary with attendance. Parking permits, transit passes, wardrobe care and a second car may be monthly. Record what actually changes when office days move from five to two.</p>
    <h2>Time remains a separate sensitivity</h2>
    <p>The base example shows $610 less cash for all-home than all-office. For 8 hybrid office days, 8 commute hours at $10/hour add an optional $80 to the $614 hybrid cash total. That is a preference value, not wage income.</p>
    <p class="privacy-note">General education only, not employment, tax, energy, housing or financial advice.</p>
  </>}

  {locale === 'zh' && <>
    <p>在家工作省下通勤，不代表家裡沒有成本；進公司有交通與外食，也不代表整筆車貸或整張月票都因工作而生。最可重複的做法是比較「工作模式改變時，哪一筆現金真的跟著改變」。</p>
    <p>混合辦公要另外算，因為網路升級、停車月租或月票可能同時保留，不能用三天居家就直接把全居家節省乘 3/5。</p>
    <DecisionGuide content={guide} />
    <WfhCommuteCalculator locale={locale} {...calculator} />
    <h2>住家電費用增量，不用整張帳單</h2>
    <p>台電住宅用電有級距與夏月差異；冷氣所在級距可能比筆電耗電更影響結果。用同季節帳單、智慧插座或設備瓦數×小時估算，再以真正邊際電價換算。不要把全家冰箱、熱水器與晚間用電都算到工作。</p>
    <h2>設備與職安先看公司安排</h2>
    <p>勞動部「居家工作職業安全衛生參考指引」提到雇主應在合理可行範圍提供必要設備或讓工作者攜回設備，並做工作環境風險評估。這不等於每位工作者都有固定現金補助；計算時只扣已核定、實際領到的金額。</p>
    <h2>餐食只算差額</h2>
    <p>人不論在哪都要吃飯，因此應比較居家餐食與進公司餐食的差額，不是把公司附近午餐全額視為額外損失。若公司供餐、加班餐或餐費補助，則以實際自付為準。</p>
    <h2>把月票、停車與時間留下來</h2>
    <p>算例全居家 NT$3,480、全進公司 NT$8,900，相差 NT$5,420；14 天居家、8 天進公司時，現金是 NT$6,360。70 分鐘×8 天為 9.3 小時，自訂 NT$150/小時後完整情境 NT$7,760，但不代表薪資增加。</p>
    <p class="privacy-note">一般教育用途，不是勞動、稅務、電價、住宅或財務建議。</p>
  </>}

  {locale === 'es' && <>
    <p>En España, comparar teletrabajo y presencialidad no consiste en trasladar todo el alquiler y la conexión al empleo. Se cuentan los importes incrementales: climatización, electricidad, mejora de internet o equipo en casa frente a transporte, comida y gastos presenciales.</p>
    <p>La modalidad híbrida puede mantener gastos fijos en ambos lugares; por eso necesita un cálculo mensual propio.</p>
    <DecisionGuide content={guide} />
    <WfhCommuteCalculator locale={locale} {...calculator} />
    <h2>El acuerdo de trabajo a distancia cambia el coste neto</h2>
    <p>La Ley 10/2021 reconoce dotación y mantenimiento de medios y exige sufragar o compensar gastos del trabajo a distancia regular. El convenio o acuerdo concreta el mecanismo. No uses una cifra genérica nacional: introduce la compensación que figure y se cobre.</p>
    <h2>Separa consumo adicional y gasto habitual</h2>
    <p>Una tarifa de internet que no cambia vale cero de incremento. Para electricidad, compara periodos semejantes o mide ordenador y climatización; el precio marginal de la factura puede diferir del promedio. Amortiza solo equipo que pagues tú y necesites para trabajar.</p>
    <h2>Comida y transporte se calculan por presencia real</h2>
    <p>Cuenta el sobrecoste de comer fuera, no toda la alimentación. En transporte, usa billetes o coste incremental del coche y conserva abonos fijos por separado. Restar días teóricos sin revisar festivos, vacaciones y viajes produce una falsa precisión.</p>
    <h2>Ejemplo híbrido con compensación</h2>
    <p>Con los valores del ejemplo, todo teletrabajo cuesta 170 € y toda oficina 445 €: 275 € de diferencia. Doce días en casa y ocho presenciales dan 311 € de caja; 9,3 horas de trayecto a 8 €/hora elevan el escenario opcional a 385,67 €.</p>
    <p class="privacy-note">Información educativa; no es asesoramiento laboral, fiscal, energético, inmobiliario o financiero.</p>
  </>}

  {locale === 'fr' && <>
    <p>En France, le coût net du télétravail dépend des dépenses réellement supplémentaires, de l’accord applicable et des remboursements versés. Le plafond social publié par l’Urssaf n’est ni une dépense automatique du salarié ni une indemnité garantie.</p>
    <p>Le mode hybride doit conserver séparément l’abonnement de transport, sa prise en charge, les frais fixes à domicile et l’indemnité télétravail.</p>
    <DecisionGuide content={guide} />
    <WfhCommuteCalculator locale={locale} {...calculator} />
    <h2>L’indemnité Urssaf est une limite d’exonération</h2>
    <p>Pour 2026, l’Urssaf indique, hors accord collectif, 2,70 € par jour de télétravail dans la limite de 59,40 € par mois ; un accord collectif permet d’autres limites publiées. Cela ne remplace pas la convention, l’accord ou les justificatifs. Le calcul déduit uniquement 32,40 € effectivement versés pour douze jours.</p>
    <h2>Transport public : coût brut et prise en charge restent visibles</h2>
    <p>L’exemple conserve un abonnement de 90 € et une prise en charge de 45 €. Cette structure évite de présenter 45 € comme le prix facial et permet de tester un autre remboursement. Les tickets, le vélo, la voiture et le forfait mobilités durables suivent leurs propres conditions.</p>
    <h2>Énergie, internet et matériel sont des suppléments</h2>
    <p>Une facture d’électricité complète ne devient pas professionnelle. Mesurez chauffage, écran et ordinateur supplémentaires, puis ajoutez seulement l’augmentation d’abonnement internet ou le matériel payé par le salarié et non remboursé.</p>
    <h2>Le double fixe peut rendre l’hybride moins intuitif</h2>
    <p>Dans l’exemple, tout télétravail coûte 177,60 € et toute présence 245 €, soit 67,40 € de différence. Douze jours à domicile et huit au bureau coûtent 234,60 € en trésorerie ; 9,3 heures à 10 €/h portent le scénario facultatif à 327,93 €.</p>
    <p class="privacy-note">Estimation pédagogique, pas un conseil social, fiscal, professionnel, énergétique ou financier.</p>
  </>}

