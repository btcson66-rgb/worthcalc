---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localizedPath } from '../../i18n/utils';

const locale = 'en';
const tools = [
  {
    title: 'Installment True APR Calculator',
    href: localizedPath(locale, '/tools/installment-true-apr'),
    description: 'See the real interest rate hiding behind "0%" installment and BNPL plans.',
  },
  {
    title: 'Subscription Audit Calculator',
    href: localizedPath(locale, '/tools/subscription-audit'),
    description: 'Add up every subscription and see what you really pay per month, year, and 5 years.',
  },
  {
    title: 'Costco Membership Calculator',
    href: localizedPath(locale, '/tools/costco-membership'),
    description: 'Find the monthly spend where a Gold Star or Executive membership pays for itself.',
  },
  {
    title: 'EV vs Gas Car TCO Calculator',
    href: localizedPath(locale, '/tools/ev-vs-gas'),
    description: 'Compare total cost of ownership — purchase, energy, maintenance — and the break-even year.',
  },
  {
    title: 'Rent vs Buy Calculator',
    href: localizedPath(locale, '/tools/rent-vs-buy'),
    description: 'Weigh mortgage, appreciation, and invested down payment against renting.',
  },
  {
    title: 'Commute Cost Calculator',
    href: localizedPath(locale, '/tools/commute-cost'),
    description: 'Compare car, transit, rideshare, and bike costs per month — including your time.',
  },
  {
    title: 'Latte Factor Calculator',
    href: localizedPath(locale, '/tools/latte-factor'),
    description: 'What a daily habit really costs per year — and what it could grow to if invested.',
  },
  {
    title: 'Cashback Break-even Calculator',
    href: localizedPath(locale, '/tools/cashback-breakeven'),
    description: 'Check whether an annual-fee card beats a no-fee 1% card at your spending level.',
  },
];
---

<BaseLayout
  title="WorthCalc — Free Calculators That Tell You If It's Worth It"
  description="Free browser-based calculators for real money decisions: installments, subscriptions, Costco, EV vs. gas, rent vs. buy, commuting, daily habits, and cashback cards."
  locale={locale}
>
  <section class="hero">
    <h1>WorthCalc — free calculators that tell you if it's actually worth it.</h1>
    <p>
      Before you sign up, sign the lease, or swipe the card, run the numbers.
      Every calculator below does real math on real money decisions, right in
      your browser. No sign-up, no data sent anywhere, no vague advice —
      just a clear verdict.
    </p>
  </section>

  <section id="tools">
    <h2>Calculators</h2>
    <div class="grid">
      {tools.map((tool) => (
        <article class="card">
          <h3><a href={tool.href}>{tool.title}</a></h3>
          <p>{tool.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
