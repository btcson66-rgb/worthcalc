---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import FAQ from '../../components/FAQ.astro';
import { localizedPath } from '../../i18n/utils';
import type { Locale } from '../../consts';

const locale = 'zh';
const alternateLocales: Locale[] = ['en', 'zh'];
const faq = [
  {
    question: '湊免運到底划不划算？',
    answer:
      '一條判斷式：湊單品是「本來就會買的東西」→ 划算（提前購買而已）；是「為了湊而找的東西」→ 你花了 199 去省 80 運費，虧 119。免運門檻的設計目的就是讓你做第二種行為，平台的客單價數據證明它非常有效。',
  },
  {
    question: '差一點點到門檻，怎麼決定？',
    answer:
      '比大小而已：差額 vs 運費。差 30 元到免運、運費 80 → 隨便加一個 30 元以上「會用到的」品項就賺。差 250 元、運費 60 → 付運費比較便宜，除非那 250 元本來就在購物清單上。',
  },
  {
    question: '「加購商品」值得看嗎？',
    answer:
      '加購區是平台精算過的高毛利小物專區，單價低、用不到的機率高。規則同上：清單裡有的才拿。比較健康的做法是家裡維持一張「消耗品補貨清單」（洗衣精、牙膏、電池），湊單永遠從這張清單拿，永遠不虧。',
  },
  {
    question: '訂閱制免運（平台會員）怎麼算？',
    answer:
      '年費 ÷ 你的年下單次數 ＝ 每單攤提，低於平均運費就值。月訂 10 次以上的重度使用者幾乎必值；月訂 1-2 次的輕度使用者通常不值——別忘了會員費本身也會改變你的行為（「都付會員了要多買」），這是另一層成本。',
  },
  {
    question: '湊單心理學上有什麼陷阱？',
    answer:
      '運費被大腦歸類為「純損失」（什麼都沒買到的錢），所以人願意多花 199 避免損失 80——行為經濟學的損失趨避。知道這個機制後，把運費重新框架成「送貨服務費」，抗拒感會下降，決策會回到數學。',
  },
];
---

<ArticleLayout
  title="湊免運划算嗎？門檻心理學與一條永不虧的湊單規則"
  description="為了省 80 運費多買 199 的東西＝虧 119——但大腦把運費當純損失，所以人人都這樣做。損失趨避的機制、差額 vs 運費的判斷式、以及「補貨清單湊單法」讓你永遠不虧。"
  locale={locale}
  alternateLocales={alternateLocales}
  updated="2026-07-24"
>
  <p>
    購物車 721 元，紅字寫著「再買 79 元享免運」。你回去逛了
    十分鐘，加了一個 199 元的手機支架。恭喜：你成功用 199 元
    避開了 80 元的運費，<strong>淨虧 119</strong>——而且你會有
    「賺到了」的感覺。這篇講清楚為什麼會這樣，以及怎麼讓湊單
    真的變成賺。
  </p>

  <h2>為什麼運費這麼令人討厭：損失趨避</h2>
  <p>
    行為經濟學的解釋很直接：商品的錢換到東西，運費的錢「什麼都
    沒換到」——大腦把它歸類為<strong>純損失</strong>，而人對損失的
    厭惡感約是等額獲得的兩倍。所以「多花 199 買個東西」（有獲得感）
    勝過「付 80 運費」（純損失感），即使前者客觀上多虧 119。
    免運門檻是平台對這個心理機制的精準收割：它不是優惠，
    是<strong>提高客單價的定價工具</strong>——這也是門檻永遠設在
    「平均客單價再高一點點」的原因。
  </p>

  <h2>判斷式：一條夠用</h2>
  <p>
    <strong>湊單品是否在你的「本來就會買」清單上？</strong>
  </p>
  <ul>
    <li><strong>是 →</strong> 湊單＝提前購買，運費省下是純賺。差額多大都成立。</li>
    <li><strong>否 →</strong> 比大小：湊單金額 vs 運費。為省 80 運費多花 199＝虧 119；為省 80 多花 49（且東西勉強有用）＝小虧或打平。<strong>為湊而買的東西，價格全額計入成本</strong>——「反正才 xx 元」是門檻設計者幫你準備好的台詞。</li>
  </ul>

  <h2>永不虧的做法：補貨清單湊單法</h2>
  <p>
    讓「本來就會買」隨時有存貨：家裡維持一張<strong>消耗品補貨
    清單</strong>——洗衣精、牙膏、電池、垃圾袋、貓砂，這類
    「遲早要買、不會過期、價格穩定」的品項。每次差額出現，
    從清單裡拿一件補上：免運到手、買的是必需品、零決策疲勞。
    這張清單同時是<a href={localizedPath(locale, '/bulk-buying-waste-math')}>大包裝划算數學</a>的
    好搭檔：清單品項剛好都是「閉眼買大包」的安全區。
  </p>

  <h2>三個進階情境</h2>
  <ol>
    <li><strong>訂閱制免運（平台會員）</strong>：年費 ÷ 年下單次數 vs 平均運費。重度使用者必值；輕度使用者注意會員費的行為副作用——「都付了會員」會讓你下單更頻繁，這層成本不在帳面上。會員費類決策的通用算法見<a href={localizedPath(locale, '/costco-math')}>Costco 會員費的數學</a>。</li>
    <li><strong>「滿額再折」疊加</strong>：滿 1,000 折 100 的結構跟免運同理，但更兇——折扣感更強、門檻更高。同一條判斷式適用：湊的是清單品才是折扣，湊的是慾望品就是加購。</li>
    <li><strong>分兩單 vs 湊一單</strong>：兩單各付運費 vs 湊到免運多買——把「多買的非清單品全額」當成本算進去比，常常兩單各付 60 反而便宜。運費不是恥辱，是服務費。</li>
  </ol>

  <h2>把運費重新框架</h2>
  <p>
    最後一個心法：把運費從「損失」改叫「<strong>送貨服務費</strong>」——
    有人開車把東西送到你家門口，這件事本來就值錢。用
    <a href={localizedPath(locale, '/price-in-work-hours')}>工時定價</a>看：
    80 元運費對真實時薪 215 的人＝22 分鐘；自己出門取貨來回
    往往不只 22 分鐘。框架換掉，損失趨避的緊繃感消失，
    「付運費」與「湊免運」回到同一張數學桌上公平比較——
    這正是所有免運門檻最怕的事。
  </p>

  <FAQ items={faq} />

  <p class="privacy-note">
    本文為一般性消費心理與數學參考，非任何平台或方案之推薦。
    站內計算機皆在瀏覽器本地執行，輸入不上傳任何伺服器。
  </p>
</ArticleLayout>
