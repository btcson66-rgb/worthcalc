---
import { SITE } from '../consts';
import { getLocaleFromUrl, localizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <p>{t('site.tagline')}</p>
    <section aria-labelledby="footer-legal-heading">
      <h2 id="footer-legal-heading">{t('footer.legal')}</h2>
      <nav class="footer-links" aria-label={t('footer.legal')}>
        <a href={localizedPath(locale, '/about')}>{t('footer.about')}</a>
        <a href={localizedPath(locale, '/privacy')}>{t('footer.privacy')}</a>
        <a href={localizedPath(locale, '/terms')}>{t('footer.terms')}</a>
        <a href={localizedPath(locale, '/contact')}>{t('footer.contact')}</a>
        <a href={localizedPath(locale, '/disclaimer')}>{t('footer.disclaimer')}</a>
        <a href={localizedPath(locale, '/changelog')}>{t('footer.changelog')}</a>
      </nav>
    </section>
    <p>&copy; {year} {SITE.name}. {t('footer.rights')}</p>
  </div>
</footer>
