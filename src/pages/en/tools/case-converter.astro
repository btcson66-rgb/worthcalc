---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ExportButtons from '../../../components/ExportButtons.astro';
import { localizedPath } from '../../../i18n/utils';

const locale = 'en';
const title = 'Case Converter';
const description = 'Convert text to uppercase, lowercase, title case, or sentence case in your browser.';
const faq = [
  {
    question: 'Does the converter change my text permanently?',
    answer: 'The selected conversion writes back into the textarea so you can copy or export the result. Use your browser undo if you need to revert.',
  },
  {
    question: 'Is the conversion private?',
    answer: 'Yes. The conversion runs in your browser and does not require a backend service.',
  },
];
const related = [
  {
    title: 'Word Counter',
    href: localizedPath(locale, '/tools/word-counter'),
  },
];
---

<ToolLayout
  title={title}
  description={description}
  locale={locale}
  tool={{ name: title }}
  faq={faq}
  related={related}
>
  <label for="cc-input">Text to convert</label>
  <textarea id="cc-input" rows="12" placeholder="Paste or type text here"></textarea>

  <div class="button-row" aria-label="Case conversion actions">
    <button type="button" data-case-action="upper">UPPERCASE</button>
    <button type="button" data-case-action="lower">lowercase</button>
    <button type="button" data-case-action="title">Title Case</button>
    <button type="button" data-case-action="sentence">Sentence case</button>
  </div>

  <ExportButtons targetId="cc-input" filename="case-converted.txt" />

  <script>
    import { bindPersistentField } from '../../../lib/storage';

    const input = document.getElementById('cc-input');
    const buttons = document.querySelectorAll('[data-case-action]');

    function toTitleCase(value: string): string {
      return value.toLocaleLowerCase().replace(/[\p{L}\p{N}]+(?:['-][\p{L}\p{N}]+)*/gu, (word: string) => {
        const chars = Array.from(word);
        const first = chars.shift();
        return first ? `${first.toLocaleUpperCase()}${chars.join('')}` : word;
      });
    }

    function toSentenceCase(value: string): string {
      const lower = value.toLocaleLowerCase();
      return lower.replace(/(^\s*|[.!?。！？]\s+)(\p{L})/gu, (match: string, prefix: string, letter: string) => {
        if (match === '') return match;
        return `${prefix}${letter.toLocaleUpperCase()}`;
      });
    }

    function convert(action: string, value: string): string {
      if (action === 'upper') return value.toLocaleUpperCase();
      if (action === 'lower') return value.toLocaleLowerCase();
      if (action === 'title') return toTitleCase(value);
      if (action === 'sentence') return toSentenceCase(value);
      return value;
    }

    if (input instanceof HTMLTextAreaElement) {
      bindPersistentField(input, 'case-converter:input');
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const action = button.getAttribute('data-case-action') ?? '';
          input.value = convert(action, input.value);
          input.dispatchEvent(new Event('input', { bubbles: true }));
        });
      });
    }
  </script>
</ToolLayout>
