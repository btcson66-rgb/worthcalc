---
import { getLocaleFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  targetId: string;
  filename?: string;
}

const { targetId, filename = 'export.txt' } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
---

<div
  class="export-actions"
  data-target-id={targetId}
  data-filename={filename}
  data-copy-label={t('export.copy')}
  data-copied-label={t('export.copied')}
>
  <button type="button" data-action="copy">{t('export.copy')}</button>
  <button type="button" data-action="txt">{t('export.txt')}</button>
  <button type="button" data-action="json">{t('export.json')}</button>
  <button type="button" data-action="clear">{t('export.clear')}</button>
</div>

<script is:inline>
  (function () {
    var script = document.currentScript;
    var root = script && script.previousElementSibling;
    if (!root) return;

    var targetId = root.getAttribute('data-target-id') || '';
    var filename = root.getAttribute('data-filename') || 'export.txt';
    var copyLabel = root.getAttribute('data-copy-label') || 'Copy';
    var copiedLabel = root.getAttribute('data-copied-label') || 'Copied!';

    function target() {
      return document.getElementById(targetId);
    }

    function content() {
      var el = target();
      if (!el) return '';
      if ('value' in el) return el.value || '';
      return el.textContent || '';
    }

    function download(name, type, value) {
      var blob = new Blob([value], { type: type });
      var url = URL.createObjectURL(blob);
      var link = document.createElement('a');
      link.href = url;
      link.download = name;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    function jsonFilename(name) {
      return name.endsWith('.txt') ? name.slice(0, -4) + '.json' : 'export.json';
    }

    root.addEventListener('click', function (event) {
      var clicked = event.target;
      if (!clicked || !clicked.closest) return;

      var button = clicked.closest('button[data-action]');
      if (!button) return;

      var action = button.getAttribute('data-action');
      var value = content();

      if (action === 'copy') {
        if (!navigator.clipboard) return;
        navigator.clipboard.writeText(value).then(function () {
          button.textContent = copiedLabel;
          window.setTimeout(function () {
            button.textContent = copyLabel;
          }, 1400);
        });
      }

      if (action === 'txt') {
        download(filename || 'export.txt', 'text/plain;charset=utf-8', value);
      }

      if (action === 'json') {
        download(jsonFilename(filename), 'application/json;charset=utf-8', JSON.stringify({ content: value }, null, 2));
      }

      if (action === 'clear') {
        var el = target();
        if (!el) return;
        if ('value' in el) {
          el.value = '';
        } else {
          el.textContent = '';
        }
        el.dispatchEvent(new Event('input', { bubbles: true }));
      }
    });
  })();
</script>
