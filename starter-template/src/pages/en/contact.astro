---
import ArticleLayout from '../../layouts/ArticleLayout.astro';

const locale = 'en';
---

<!-- [Customize this page for your site] -->
<ArticleLayout
  title="Contact"
  description="Contact information for feedback, corrections, and partnership inquiries."
  locale={locale}
  updated="2026-06-28"
>
  <p>
    This static starter does not include a backend contact form. To keep the site
    simple and easy to host, publish a direct email address instead.
  </p>
  <p>
    Email: hello@example.com
  </p>
  <p>
    You can use this address for feedback, bug reports, correction requests, and
    partnership inquiries. Replace it with your real support or business email
    before publishing.
  </p>
</ArticleLayout>
