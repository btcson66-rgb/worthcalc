---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ExportButtons from '../../../components/ExportButtons.astro';
import { localizedPath } from '../../../i18n/utils';

const locale = 'en';
const title = 'Word Counter';
const description = 'Count characters, words, sentences, lines, and estimated reading time in your browser.';
const faq = [
  {
    question: 'How does the word counter work?',
    answer: 'It splits Latin text on whitespace and punctuation patterns, and also counts CJK characters as words for a more useful mixed-language estimate.',
  },
  {
    question: 'Is my text private?',
    answer: 'Yes. Counting happens in your browser, and the text is not sent to a custom backend server.',
  },
  {
    question: 'Can I use it offline?',
    answer: 'After the page is loaded, the counter logic runs locally. Full offline availability depends on how you host and cache the site.',
  },
];
const related = [
  {
    title: 'Case Converter',
    href: localizedPath(locale, '/tools/case-converter'),
  },
];
---

<ToolLayout
  title={title}
  description={description}
  locale={locale}
  tool={{ name: title }}
  faq={faq}
  related={related}
>
  <label for="wc-input">Text to count</label>
  <textarea id="wc-input" rows="12" placeholder="Paste or type text here"></textarea>

  <ExportButtons targetId="wc-input" filename="word-count.txt" />

  <div class="results" aria-live="polite">
    <p>Characters: <strong id="wc-characters">0</strong></p>
    <p>Characters without spaces: <strong id="wc-characters-no-spaces">0</strong></p>
    <p>Words: <strong id="wc-words">0</strong></p>
    <p>Sentences: <strong id="wc-sentences">0</strong></p>
    <p>Lines: <strong id="wc-lines">0</strong></p>
    <p>Estimated reading time: <strong id="wc-reading-time">0 min</strong></p>
  </div>

  <script>
    import { bindPersistentField } from '../../../lib/storage';

    const input = document.getElementById('wc-input');
    const characters = document.getElementById('wc-characters');
    const charactersNoSpaces = document.getElementById('wc-characters-no-spaces');
    const words = document.getElementById('wc-words');
    const sentences = document.getElementById('wc-sentences');
    const lines = document.getElementById('wc-lines');
    const readingTime = document.getElementById('wc-reading-time');
    const cjkPattern = /[\u3400-\u4dbf\u4e00-\u9fff\uf900-\ufaff\u3040-\u30ff\uac00-\ud7af]/gu;
    const latinWordPattern = /[\p{L}\p{N}]+(?:['-][\p{L}\p{N}]+)*/gu;

    function countWords(value: string): number {
      const cjkMatches = value.match(cjkPattern) ?? [];
      const withoutCjk = value.replace(cjkPattern, ' ');
      const latinMatches = withoutCjk.match(latinWordPattern) ?? [];
      return cjkMatches.length + latinMatches.length;
    }

    function setText(element: HTMLElement | null, value: string): void {
      if (element) element.textContent = value;
    }

    function updateStats() {
      if (!(input instanceof HTMLTextAreaElement)) return;
      const value = input.value;
      const wordCount = countWords(value);
      const trimmed = value.trim();
      const sentenceCount = trimmed === '' ? 0 : (trimmed.match(/[^.!?。！？]+[.!?。！？]?/g) ?? []).length;
      const lineCount = value === '' ? 0 : value.split(/\r\n|\r|\n/).length;
      const minutes = wordCount === 0 ? 0 : Math.max(1, Math.ceil(wordCount / 200));

      setText(characters, String(Array.from(value).length));
      setText(charactersNoSpaces, String(Array.from(value.replace(/\s/g, '')).length));
      setText(words, String(wordCount));
      setText(sentences, String(sentenceCount));
      setText(lines, String(lineCount));
      setText(readingTime, `${minutes} min`);
    }

    if (input instanceof HTMLTextAreaElement) {
      bindPersistentField(input, 'word-counter:input');
      input.addEventListener('input', updateStats);
      updateStats();
    }
  </script>
</ToolLayout>
