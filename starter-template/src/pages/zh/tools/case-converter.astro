---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ExportButtons from '../../../components/ExportButtons.astro';
import { localizedPath } from '../../../i18n/utils';

const locale = 'zh';
const title = '大小寫轉換';
const description = '在瀏覽器中將文字轉換為大寫、小寫、標題式大小寫或句首大寫。';
const faq = [
  {
    question: '轉換會直接覆蓋文字嗎？',
    answer: '會。選擇轉換後，結果會寫回文字框，方便複製或匯出。需要還原時可使用瀏覽器復原功能。',
  },
  {
    question: '轉換過程是私密的嗎？',
    answer: '是。轉換邏輯在你的瀏覽器中執行，不需要後端服務。',
  },
];
const related = [
  {
    title: '字數統計',
    href: localizedPath(locale, '/tools/word-counter'),
  },
];
---

<ToolLayout
  title={title}
  description={description}
  locale={locale}
  tool={{ name: title }}
  faq={faq}
  related={related}
>
  <label for="cc-input">要轉換的文字</label>
  <textarea id="cc-input" rows="12" placeholder="在這裡貼上或輸入文字"></textarea>

  <div class="button-row" aria-label="大小寫轉換操作">
    <button type="button" data-case-action="upper">轉為大寫</button>
    <button type="button" data-case-action="lower">轉為小寫</button>
    <button type="button" data-case-action="title">標題式大小寫</button>
    <button type="button" data-case-action="sentence">句首大寫</button>
  </div>

  <ExportButtons targetId="cc-input" filename="case-converted.txt" />

  <script>
    import { bindPersistentField } from '../../../lib/storage';

    const input = document.getElementById('cc-input');
    const buttons = document.querySelectorAll('[data-case-action]');

    function toTitleCase(value: string): string {
      return value.toLocaleLowerCase().replace(/[\p{L}\p{N}]+(?:['-][\p{L}\p{N}]+)*/gu, (word: string) => {
        const chars = Array.from(word);
        const first = chars.shift();
        return first ? `${first.toLocaleUpperCase()}${chars.join('')}` : word;
      });
    }

    function toSentenceCase(value: string): string {
      const lower = value.toLocaleLowerCase();
      return lower.replace(/(^\s*|[.!?。！？]\s+)(\p{L})/gu, (match: string, prefix: string, letter: string) => {
        if (match === '') return match;
        return `${prefix}${letter.toLocaleUpperCase()}`;
      });
    }

    function convert(action: string, value: string): string {
      if (action === 'upper') return value.toLocaleUpperCase();
      if (action === 'lower') return value.toLocaleLowerCase();
      if (action === 'title') return toTitleCase(value);
      if (action === 'sentence') return toSentenceCase(value);
      return value;
    }

    if (input instanceof HTMLTextAreaElement) {
      bindPersistentField(input, 'case-converter:input');
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const action = button.getAttribute('data-case-action') ?? '';
          input.value = convert(action, input.value);
          input.dispatchEvent(new Event('input', { bubbles: true }));
        });
      });
    }
  </script>
</ToolLayout>
